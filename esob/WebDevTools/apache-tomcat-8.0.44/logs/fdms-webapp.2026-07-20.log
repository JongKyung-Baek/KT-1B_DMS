               u.type,
               u.sort,
               u.useYn
          FROM (
                SELECT TREE_CD AS id,
                       COALESCE(UPPER_TREE_CD, '#') AS parent,
                       TREE_NM AS text,
                       COALESCE(FUNCTION_CD, TREE_CD) AS functionCd,
                       CAST(TREE_DEPTH AS VARCHAR) AS "level",
                       'group' AS type,
                       COALESCE(SORT_ORDER, 0) AS sort,
                       COALESCE(USE_YN, 'Y') AS useYn
                  FROM DOCS_SW_TREE
                 WHERE COALESCE(USE_YN, 'Y') = 'Y'
                   AND COALESCE(TREE_DEPTH, 0) = 1
                   AND COALESCE(UPPER_TREE_CD, '') = 'ROOT'
                UNION ALL
                SELECT TREE_CD AS id,
                       COALESCE(UPPER_TREE_CD, '#') AS parent,
                       TREE_NM AS text,
                       COALESCE(FUNCTION_CD, TREE_CD) AS functionCd,
                       CAST(TREE_DEPTH AS VARCHAR) AS "level",
                       'group' AS type,
                       COALESCE(SORT_ORDER, 0) AS sort,
                       COALESCE(USE_YN, 'Y') AS useYn
                  FROM DOCS_PRODUCT_TREE
                 WHERE COALESCE(USE_YN, 'Y') = 'Y'
                   AND COALESCE(TREE_DEPTH, 0) = 1
                   AND COALESCE(UPPER_TREE_CD, '') = 'ROOT'
                UNION ALL
                SELECT TREE_CD AS id,
                       COALESCE(UPPER_TREE_CD, '#') AS parent,
                       TREE_NM AS text,
                       COALESCE(FUNCTION_CD, TREE_CD) AS functionCd,
