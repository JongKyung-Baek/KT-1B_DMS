[INFO ] 2026-07-20 10:43:16.045 [k.esob.fdms.commonlogic.menu.MenuDao.list(82)]  - Query Id - sql.Menu.getMenuSubList
[INFO ] 2026-07-20 10:43:16.046 [jdbc.sqlonly.sqlOccurred(31)]  - SQL:

        WITH RECURSIVE parent (MENU_CD, PARENT_MENU_CD, MENU_NM, MESSAGE_CD, MENU_LEVEL, MENU_TYPE, MENU_URL, SORT_SEQ, TREE_TYPE, DEL_YN, USE_YN, TOOLTIP, MENU_DESC, ROLE_CD, MENU_PATH_CD, MENU_PATH, MAIN_CD) AS (
        SELECT menu.MENU_CD,
               menu.PARENT_MENU_CD,
               COALESCE(lang.LANG_DESC, menu.MENU_NM) AS MENU_NM,
               menu.MESSAGE_CD,
               1 AS MENU_LEVEL,
               menu.MENU_TYPE,
               menu.MENU_URL,
               menu.SORT_SEQ,
               CASE
                   WHEN (SELECT COUNT(*) FROM DOCS_MENU T WHERE T.PARENT_MENU_CD = menu.MENU_CD AND T.MENU_TYPE = 'M') > 0 THEN 'branch'
                   ELSE 'leaf'
               END TREE_TYPE,
               menu.DEL_YN,
               menu.USE_YN,
               menu.TOOLTIP,
               menu.MENU_DESC,
               menu.ROLE_CD,
               CAST(menu.MENU_CD AS VARCHAR) AS MENU_PATH_CD,
               CAST(COALESCE(lang.LANG_DESC, menu.MENU_NM) AS VARCHAR) AS MENU_PATH,
               menu.MENU_CD AS MAIN_CD
        FROM DOCS_MENU menu
        JOIN DOCS_REL_ROLE_GROUP roleGroup ON menu.ROLE_CD = roleGroup.ROLE_CD
        LEFT JOIN DOCS_LANG lang
        ON lang.LANG_CD = menu.MESSAGE_CD
        AND lang.LANG_TYPE = 'ko'
        WHERE AUTH_SITE IN ('I', 'B')
        AND MENU.TREE_TYPE = 'root'
        AND MENU.USE_YN = 'Y'
        AND MENU.DEL_YN = 'N'
        AND roleGroup.GROUP_CD = 'RG_011'
        UNION ALL
        SELECT menu.MENU_CD,
               menu.PARENT_MENU_CD,
               COALESCE(lang.LANG_DESC, menu.MENU_NM) AS MENU_NM,
               menu.MESSAGE_CD,
               parent.MENU_LEVEL + 1 AS MENU_LEVEL,
               menu.MENU_TYPE,
               menu.MENU_URL,
               menu.SORT_SEQ,
               CASE
                   WHEN (SELECT COUNT(*) FROM DOCS_MENU T WHERE T.PARENT_MENU_CD = menu.MENU_CD AND T.MENU_TYPE = 'M') > 0 THEN 'branch'
                   ELSE 'leaf'
               END TREE_TYPE,
               menu.DEL_YN,
               menu.USE_YN,
               menu.TOOLTIP,
               menu.MENU_DESC,
               menu.ROLE_CD,
               parent.MENU_PATH_CD || ' > ' || MENU.MENU_CD AS MENU_PATH_CD,
               parent.MENU_PATH || ' > ' || COALESCE(lang.LANG_DESC, menu.MENU_NM) AS MENU_PATH,
               parent.MAIN_CD AS MAIN_CD
        FROM DOCS_MENU menu
        JOIN parent ON menu.PARENT_MENU_CD = parent.MENU_CD
        JOIN DOCS_REL_ROLE_GROUP roleGroup ON menu.ROLE_CD = roleGroup.ROLE_CD
        LEFT JOIN DOCS_LANG lang
        ON lang.LANG_CD = menu.MESSAGE_CD
        AND lang.LANG_TYPE = 'ko'
        WHERE menu.USE_YN = 'Y'
        AND menu.DEL_YN = 'N'
        AND roleGroup.GROUP_CD = 'RG_011'
    )
    SELECT *
    FROM parent T
    ORDER BY SORT_SEQ

