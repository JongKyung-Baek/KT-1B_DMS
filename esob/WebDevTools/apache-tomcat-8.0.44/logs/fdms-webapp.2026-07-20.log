        SELECT TO_CHAR(info.insert_dt, 'YYYY-MM-DD') AS useEndYmd,
               'PMPCB' AS objectType,
               'PMPCB' AS objectTypeNm,
               COALESCE(info.document_no, '-') AS objectNo,
               info.insert_dt AS sortDt
        FROM docs_dxf_document info
        WHERE COALESCE(info.deleted_yn, 'N') = 'N'
          AND COALESCE(info.status, '') IN ('승인진행중', 'APPROVAL')
          AND (
              EXISTS (
                  SELECT 1
                  FROM regexp_split_to_table(REPLACE(COALESCE(info.approver, ''), ' ', ''), ',') ap(token)
                  WHERE (
                      ap.token = REPLACE(COALESCE('kt1b사용자', ''), ' ', '')
                      OR ap.token LIKE REPLACE(COALESCE('kt1b사용자', ''), ' ', '') || '|%'
                      OR ap.token = REPLACE(COALESCE('kt-1b-user1', ''), ' ', '')
                      OR ap.token LIKE REPLACE(COALESCE('kt-1b-user1', ''), ' ', '') || '|%'
                  )
                  AND NOT EXISTS (
                      SELECT 1
                      FROM regexp_split_to_table(REPLACE(COALESCE(info.approved_users, info.status, ''), ' ', ''), ',') au(token)
                      WHERE split_part(TRIM(au.token), '|', 1) = ap.token
                  )
              )
              OR EXISTS (
                  SELECT 1
                  FROM regexp_split_to_table(REPLACE(COALESCE(info.revieweruser, ''), ' ', ''), ',') rv(token)
                  WHERE (
                      rv.token = REPLACE(COALESCE('kt1b사용자', ''), ' ', '')
                      OR rv.token LIKE REPLACE(COALESCE('kt1b사용자', ''), ' ', '') || '|%'
                      OR rv.token = REPLACE(COALESCE('kt-1b-user1', ''), ' ', '')
                      OR rv.token LIKE REPLACE(COALESCE('kt-1b-user1', ''), ' ', '') || '|%'
                  )
                  AND NOT EXISTS (
                      SELECT 1
                      FROM regexp_split_to_table(REPLACE(COALESCE(info.approved_users, info.status, ''), ' ', ''), ',') au(token)
                      WHERE split_part(TRIM(au.token), '|', 1) = rv.token
                  )
              )
          )
    ) t
    ORDER BY t.sortDt DESC
    LIMIT 10

