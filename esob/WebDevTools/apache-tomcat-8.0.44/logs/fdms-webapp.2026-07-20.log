[INFO ] 2026-07-20 10:24:33.118 [k.e.f.c.i.o.insideuser.InsideuserDao.list(82)]  - Query Id - sql.OrganizationmanageInsideuser.selectList
[INFO ] 2026-07-20 10:24:33.125 [jdbc.sqlonly.sqlOccurred(31)]  - SQL:

        SELECT
        B1.*
        FROM
        (
        SELECT
        A1.*,
        ROW_NUMBER() OVER () AS pageIndex
        FROM
        (
        SELECT userInfo.USER_ID        AS userId,          /* 사용자계정 */
        userInfo.USER_CD        AS userCd,
        userInfo.USER_NM        AS userNm,          /* 사용자성명 */
        userInfo.DEPT_CD        AS deptCd,          /* 부서코드 */
        docsDept.DEPT_NM        AS deptNm,          /* 부서이름 */
        dPostion.POSITION_NM    AS positionNm,      /* 직위 */
        userInfo.LAST_LOGIN_DT  AS lastLoginDt,     /* 최종로그인 */
        userInfo.LOCK_YN        AS accountLockYn,   /* 계정잠금여부 */
        userInfo.LOGIN_COUNT    AS loginCount,      /* 비밀번호틀린회수 */
        userInfo.USE_YN         AS useYn,           /* 재직구분 */
        dRoleGroup.GROUP_NM     AS roleGroup        /* 사용자권한 */
        FROM DOCS_USER userInfo
        LEFT JOIN DOCS_DEPT docsDept
        ON userInfo.DEPT_CD = docsDept.DEPT_CD
        LEFT JOIN DOCS_POSITION dPostion
        ON userInfo.POSITION_CD = dPostion.POSITION_CD
        LEFT JOIN DOCS_ROLE_GROUP_MEMBER dRoleGroupMem
        ON userInfo.USER_CD = dRoleGroupMem.MEMBER_CD
        LEFT JOIN DOCS_ROLE_GROUP dRoleGroup
        ON dRoleGroupMem.GROUP_CODE = dRoleGroup.GROUP_CODE
        WHERE userInfo.AUTH_SITE IN ('I', 'B')
          AND userInfo.USE_YN = 'Y'
        ) A1
        WHERE 1=1
        ) B1
        WHERE 1=1
            AND B1.pageIndex   <=   30
            AND B1.pageIndex >= 1

