    , COALESCE((SELECT LANG_DESC FROM DOCS_LANG WHERE LANG_TYPE = 'ko' AND LANG_CD = A1.TOOLTIP), A1.TOOLTIP) AS comboTooltip
    FROM DOCS_COMBO A1
    WHERE COMBO_CD = 'logType'
    AND USE_YN = 'Y'
    ORDER BY SEQ ASC

