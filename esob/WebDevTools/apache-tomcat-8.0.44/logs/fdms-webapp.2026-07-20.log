[INFO ] 2026-07-20 10:24:16.840 [k.e.f.c.i.d.v.HistoryDao.list(82)]  - Query Id - sql.ViewPrintHistory.selectList
[INFO ] 2026-07-20 10:24:16.852 [jdbc.sqlonly.sqlOccurred(31)]  - SQL:

        SELECT
        B1.*
        FROM (
        SELECT
        A1.*
        --         , ROW_NUMBER() OVER(ORDER BY A1.insertDt DESC) AS PAGEINDEX
        , ROW_NUMBER() OVER(
        ORDER BY
            A1.insertDt DESC
        ) AS PAGEINDEX
        FROM (
        SELECT
        CASE
            WHEN info.DISTRIBUTION_TYPE = 'FunctionCode' THEN 'Documents'
            WHEN info.DISTRIBUTION_TYPE = 'CCB' THEN '기술자료관리'
            ELSE info.DISTRIBUTION_TYPE
        END AS distributionType,
        info.DRAWING_NO AS drawingNo,
        info.OBJECT_ID AS objectId,
        info.ORG_FILE_NM AS orgFileNm,
        info.REVISION AS revision,
        info.USER_ID AS userId,
        info.INSERT_DATE AS insertDt,
        info.USER_NM AS userNm,
        info.LOG_TYPE AS logType,
        '' AS checkSum
        FROM DOCS_HISTORY info
        WHERE 1=1
            ORDER BY info.INSERT_DATE DESC
        ) A1
        ) B1
        WHERE 1=1
