             LEFT JOIN DOCS_LANG lang ON lang.LANG_CD = grid.LANG_CD AND lang.LANG_TYPE = 'ko'
    WHERE GRID_ID = 'gridSwRequestList'
    ORDER BY COLUMN_SEQ ASC

