                 (SELECT GROUP_CODE FROM DOCS_ROLE_GROUP_MEMBER T1 WHERE T1.MEMBER_CD = docsUser.USER_CD AND GROUP_TYPE = 'USER' LIMIT 1) AS userRoleGroup,
                 (SELECT GROUP_CODE FROM DOCS_ROLE_GROUP_MEMBER T2 WHERE T2.MEMBER_CD = docsUser.DEPT_CD AND GROUP_TYPE = 'DEPT' LIMIT 1) AS deptRoleGroup
