[INFO ] 2026-07-20 11:07:09.678 [k.e.f.c.i.d.swrequest.SwRequestDao.obj(65)]  - Query Id - sql.swRequest.selectListCount
[INFO ] 2026-07-20 11:07:09.681 [jdbc.sqlonly.sqlOccurred(31)]  - SQL:

        SELECT COUNT(*) AS TOTAL_COUNT
        FROM
        (
        SELECT
        A1.*
        FROM
        (
        SELECT info.*
        , insertuser.USER_NM AS insertUserNm
        , updateUser.USER_NM AS updateUserNm
                FROM (
                SELECT info.BUSINESS_TYPE_CD AS businessTypeCd,
                FN_GET_CD_NM('businessTypeCd', info.BUSINESS_TYPE_CD, 'ko') AS businessTypeNm,
                info.SW_TYPE_CD AS swTypeCd,
                FN_GET_CD_NM('swTypeCd', info.SW_TYPE_CD, 'ko') AS swTypeNm,
                info.DISTRIBUTE_TYPE_CD AS distributeTypeCd,
--                 FN_GET_CD_NM('distributeTypeCd', info.DISTRIBUTE_TYPE_CD, 'ko') AS distributeTypeNm,
                info.DISTRIBUTE_TYPE_NAME AS distributeTypeNm,
                info.SW_NO AS swNo,
                info.SW_NM AS swNm,
                info.SW_VERSION_No AS swVersionNo,
                info.OBJECT_ID AS objectId,
                info.REV_NO AS revNo,
                info.INSERT_UID AS insertUid,
                info.UPDATE_UID AS updateUid,
                info.ecn_insert_uid AS ecn_insert_uid,
                info.REGISTER_USER AS registerUser,
                info.INSERT_DEPT_NM AS insertDeptNm,
                info.STD_GAPP_DT AS stdGappDt,
                info.CHANGE_GAPP_DT AS changeGappDt,
                info.ECN_NO AS ecnNo,
                info.BUSINESS_AREA_CD AS businessAreaCd,
                FN_GET_CD_NM('businessAreaCdAll', info.BUSINESS_AREA_CD, 'ko') AS businessAreaNm,
                info.PROTECT_YN AS protectYn,
                info.PROTECT_YN AS protectYnView,
                info.UPDATE_DT AS updateDt,
                info.INSERT_DT AS insertDt,
                info.CREATE_DT AS createDt,
                info.INTERFACE_DT AS interfaceDt,
                info.PRODUCT_CD AS productCd,
                COALESCE(info.PRODUCT_CD, '') AS productNm,
                (SELECT COUNT(*) FROM DOCS_SW_FILE swFile WHERE swFile.OBJECT_ID = info.OBJECT_ID) AS fileCount,
                fileInfo.FILE_NO AS fileNo,
                fileInfo.ORG_FILE_NM AS fileViewNm,
                fileInfo.FILE_NM AS fileNm,
                fileInfo.FILE_SIZE AS fileSize,
                fileInfo.ORG_FILE_NM AS orgFileNm,
                fileInfo.FILE_PATH_NM AS filePath,
                info.VALID_TYPE AS validType
                FROM DOCS_SW_FILE fileInfo
                JOIN DOCS_SW info ON fileInfo.OBJECT_ID = info.OBJECT_ID
        WHERE 1=1 AND info.DELETED_YN = 'N'
        ) info
        LEFT JOIN DOCS_USER insertUser ON insertUser.USER_ID = info.insertUid
        LEFT JOIN DOCS_USER updateUser ON updateUser.USER_ID = info.updateUid
        ) A1
        WHERE 1=1
        ) B1

