        SELECT menu.MENU_CD AS menuCd,
           menu.PARENT_MENU_CD AS parentMenuCd,
           COALESCE(lang.LANG_DESC, menu.MENU_NM) AS menuNm,
           menu.MESSAGE_CD AS messageCd,
           menu.MENU_LEVEL AS menuLevel,
           menu.MENU_TYPE AS menuType,
           menu.MENU_URL AS menuUrl,
           menu.SORT_SEQ AS sortSeq,
           menu.TREE_TYPE AS treeType,
           menu.DEL_YN AS delYn,
           menu.USE_YN AS useYn,
           menu.TOOLTIP AS tooltip,
           menu.MENU_DESC AS menuDesc,
           menu.ROLE_CD AS roleCd,
           menu.MENU_ICON AS menuIcon
    FROM DOCS_MENU menu
    JOIN DOCS_REL_ROLE_GROUP role
    ON menu.ROLE_CD = role.ROLE_CD
    LEFT JOIN DOCS_LANG lang
    ON lang.LANG_CD = menu.MESSAGE_CD
    AND lang.LANG_TYPE = 'en'
    WHERE menu.TREE_TYPE = 'root'
    AND menu.MENU_TYPE != 'H'
    AND menu.AUTH_SITE IN ('I', 'B')
    AND role.GROUP_CD = 'RG_001'
    AND DEL_YN = 'N'
    AND USE_YN = 'Y'
    ORDER BY SORT_SEQ

