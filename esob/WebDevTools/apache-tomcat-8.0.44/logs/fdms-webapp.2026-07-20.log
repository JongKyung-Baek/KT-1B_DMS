[INFO ] 2026-07-20 10:43:45.079 [jdbc.sqlonly.sqlOccurred(31)]  - SQL:

        SELECT tree.TREE_CD AS id
             , COALESCE(tree.UPPER_TREE_CD, '#') AS parent
             , tree.TREE_NM AS text
             , CAST(tree.TREE_DEPTH AS VARCHAR) AS "level"
             , CASE
                   WHEN tree.UPPER_TREE_CD IS NULL THEN 'root'
                   WHEN EXISTS (SELECT 1 FROM DOCS_SW_TREE child WHERE child.UPPER_TREE_CD = tree.TREE_CD AND COALESCE(child.USE_YN, 'Y') = 'Y') THEN 'group'
                   ELSE 'item'
               END AS "type"
             , tree.SORT_ORDER AS sort
             , COALESCE(tree.USE_YN, 'Y') AS useYn
             , CASE
                   WHEN EXISTS (SELECT 1 FROM DOCS_SW_TREE child WHERE child.UPPER_TREE_CD = tree.TREE_CD AND COALESCE(child.USE_YN, 'Y') = 'Y') THEN ''
                   ELSE 'swTreeCd'
               END AS filterType
             , tree.TREE_NM AS filterValue
             , tree.TREE_CD AS swTreeCd
             , '' AS distributeTypeCd
        FROM DOCS_SW_TREE tree
        WHERE COALESCE(tree.USE_YN, 'Y') = 'Y'
        ORDER BY tree.TREE_PATH, tree.SORT_ORDER, tree.TREE_NM

[INFO ] 2026-07-20 10:43:45.085 [jdbc.sqlonly.sqlOccurred(31)]  - SQL:

        SELECT
        B1.*
        FROM (
        SELECT
        A1.*,
        ROW_NUMBER() OVER(
        ORDER BY
            A1.insertDt DESC
        ) AS PAGEINDEX
        FROM (
        SELECT
        info.*,
        insertUser.USER_NM AS insertUserNm,
        updateUser.USER_NM AS updateUserNm,
        ecnInsert.USER_NM AS ecnUserNm
        FROM (
                SELECT
                info.BUSINESS_TYPE_CD AS businessTypeCd,
                FN_GET_CD_NM('businessTypeCd', info.BUSINESS_TYPE_CD, 'ko') AS businessTypeNm,
                info.SW_TYPE_CD AS swTypeCd,
                FN_GET_CD_NM('swClassCd1', info.SW_TYPE_CD, 'ko') AS swTypeNm,
                info.DISTRIBUTE_TYPE_CD AS distributeTypeCd,
--                 FN_GET_CD_NM('distributeTypeCd', info.DISTRIBUTE_TYPE_CD, 'ko') AS distributeTypeNm,
                info.DISTRIBUTE_TYPE_NAME AS distributeTypeNm,
                info.SW_NO AS swNo,
                info.SW_NM AS swNm,
                info.SW_VERSION_No AS swVersionNo,
                info.OBJECT_ID AS objectId,
                info.REV_NO AS revNo,
                info.INSERT_UID AS insertUid,
                info.UPDATE_UID AS updateUid,
                info.ecn_insert_uid AS ecn_insert_uid,
                info.REGISTER_USER AS registerUser,
                info.INSERT_DEPT_NM AS insertDeptNm,
                info.STD_GAPP_DT AS stdGappDt,
                info.CHANGE_GAPP_DT AS changeGappDt,
                info.ECN_NO AS ecnNo,
                info.BUSINESS_AREA_CD AS businessAreaCd,
                FN_GET_CD_NM('businessAreaCdAll', info.BUSINESS_AREA_CD, 'ko') AS businessAreaNm,
                info.PROTECT_YN AS protectYn,
                info.PROTECT_YN AS protectYnView,
                info.UPDATE_DT AS updateDt,
                info.INSERT_DT AS insertDt,
                info.CREATE_DT AS createDt,
                info.CCBDATE AS ccbDate,
                info.APPROVER AS approver,
                info.REVIEWERUSER AS reviewerUser,
                COALESCE(fileInfo.PROCESSING_STATUS, '') AS processingStatus,
                CASE
                    WHEN info.STATUS = '승인완료' THEN '승인완료'
                    WHEN COALESCE(NULLIF(TRIM(info.APPROVER), ''), '') <> ''
                        AND NOT EXISTS (
                            SELECT 1
                            FROM regexp_split_to_table(REPLACE(info.APPROVER, ' ', ''), ',') AS ap(token)
                            WHERE ap.token <> ''
                                AND POSITION(',' || ap.token || ',' IN ',' || REPLACE(COALESCE(info.APPROVED_USERS, info.STATUS, ''), ' ', '') || ',') = 0
                        )
                        AND (
                            COALESCE(NULLIF(TRIM(info.REVIEWERUSER), ''), '') = ''
                            OR NOT EXISTS (
                                SELECT 1
                                FROM regexp_split_to_table(REPLACE(info.REVIEWERUSER, ' ', ''), ',') AS rv(token)
                                WHERE rv.token <> ''
                                    AND POSITION(',' || rv.token || ',' IN ',' || REPLACE(COALESCE(info.APPROVED_USERS, info.STATUS, ''), ' ', '') || ',') = 0
                            )
                        ) THEN '승인완료'
                    ELSE '승인진행중'
                END AS status,
                info.INTERFACE_DT AS interfaceDt,
                info.PRODUCT_CD AS productCd,
                COALESCE(info.PRODUCT_CD, '') AS productNm,
                (SELECT COUNT(*) FROM DOCS_SW_FILE swFile WHERE swFile.OBJECT_ID = info.OBJECT_ID) AS fileCount,
                fileInfo.FILE_NO AS fileNo,
                fileInfo.ORG_FILE_NM AS fileViewNm,
                fileInfo.FILE_NM AS fileNm,
                fileInfo.FILE_SIZE AS fileSize,
                fileInfo.ORG_FILE_NM AS orgFileNm,
                fileInfo.FILE_PATH_NM AS filePath,
                info.VALID_TYPE AS validType
                FROM DOCS_SW_FILE fileInfo
                JOIN DOCS_SW info ON fileInfo.OBJECT_ID = info.OBJECT_ID
        WHERE 1=1 AND info.DELETED_YN = 'N'
        ) info
        LEFT JOIN DOCS_USER insertUser ON insertUser.USER_ID = info.insertUid
        LEFT JOIN DOCS_USER updateUser ON updateUser.USER_ID = info.updateUid
        LEFT JOIN DOCS_USER ecnInsert ON ecnInsert.USER_ID = info.ecn_insert_uid
            ORDER BY insertDT DESC, swNo, revNo DESC, fileNo
        ) A1
        ) B1
        WHERE 1=1
            AND PAGEINDEX  <=  30
            AND PAGEINDEX >= 1

