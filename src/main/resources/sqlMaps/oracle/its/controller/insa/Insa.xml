<update id="updatePurchaserTeam">
	UPDATE DOCS_USER
	SET ROLE_GROUP = #{groupCode}
	WHERE USER_CD IN
		  (
			  SELECT docsUser.USER_CD
			  FROM DOCS_INSA_DEPT_CD insa
					   JOIN DOCS_DEPT dept ON insa.DEPT_CD = dept.DEPT_CD
					   JOIN DOCS_USER docsUser ON dept.DEPT_CD = docsUser.DEPT_CD
			  WHERE COLUMN_NM = 'PURCHASE_TEAM_YN'
