<update id="updateRoleGroupDept">
	UPDATE DOCS_USER docsUser
	SET docsUser.ROLE_GROUP =
			(
				SELECT groupMember.GROUP_CODE
				FROM DOCS_ROLE_GROUP_MEMBER groupMember
				WHERE groupMember.GROUP_TYPE = 'DEPT'
				  AND groupMember.MEMBER_CD = docsUser.DEPT_CD
			)
	WHERE EXISTS
			  (
				  SELECT 0 FROM DOCS_ROLE_GROUP_MEMBER groupMember WHERE
					  groupMember.GROUP_TYPE = 'DEPT'
																	 AND groupMember.MEMBER_CD = docsUser.DEPT_CD
			  )
</update>

<update id="updateRoleGroupUser">
	UPDATE DOCS_USER docsUser
	SET docsUser.ROLE_GROUP =
			(
				SELECT groupMember.GROUP_CODE
				FROM DOCS_ROLE_GROUP_MEMBER groupMember
				WHERE groupMember.GROUP_TYPE = 'USER'
				  AND groupMember.MEMBER_CD = docsUser.USER_CD
					LIMIT 1
			)
	WHERE EXISTS
			  (
				  SELECT 0 FROM DOCS_ROLE_GROUP_MEMBER groupMember WHERE
					  groupMember.GROUP_TYPE = 'USER'
																	 AND groupMember.MEMBER_CD = docsUser.USER_CD
			  )
</update>
</mapper>
