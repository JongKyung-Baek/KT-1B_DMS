<select id="selectItnVendor" resultType="HashMap">
	SELECT
		BUSINESS_AREA_CD
		 , VENDOR_NM AS COMPANY_NM
		 , VENDOR_CD AS BIZ_NO
		 , 'E' AS COMPANY_TYPE
		 , '19000101' AS USE_START_DT
		 , '99991231' AS USE_END_DT
		 , (
		SELECT USER_CD
		FROM DOCS_USER t
		WHERE t.USER_ID = DIST_PURCHASER_UID
	) AS DIST_PURCHASER_USER_CD
		 , DIST_PURCHASER_UID_EMAIL AS DIST_PURCHASER_EMAIL
		 , (
		SELECT USER_CD
		FROM DOCS_USER t
		WHERE t.USER_ID = CR_PURCHASER_UID
	) AS CR_PURCHASER_USER_CD
		 , CR_PURCHASER_UID_EMAIL AS CR_PURCHASER_EMAIL
		 , CASE VENDOR_STATUS WHEN 'Y' THEN 'N' ELSE 'Y' END AS DEL_YN
		 , 'Y' AS USE_YN
		 , CN_SERIAL AS COMAPNY_CD_CUSTOM
	FROM ITN_VENDOR
	ORDER BY CN_SERIAL
</select>

