	</if>
	<if test='EMAIL != null and !EMAIL.equals("")'>
		, EMAIL =  CASE WHEN USER_CD IN ('USER_0000012187','USER_0000012137') THEN 'df.wanggeun.lee@hanwha-ds.com'
		ELSE #{EMAIL}
		END
	</if>
	, USE_YN = #{USE_YN}
	, DEL_YN = 'N'
	<if test='BUSINESS_AREA_CD != null and !BUSINESS_AREA_CD.equals("")'>
