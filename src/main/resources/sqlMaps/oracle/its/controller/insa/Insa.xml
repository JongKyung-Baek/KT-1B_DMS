	<if test='DEPT_CD != null and !DEPT_CD.equals("")'>
		, DEPT_CD
	</if>
	<if test='POSITION_CD != null and !POSITION_CD.equals("")'>
		, POSITION_CD
	</if>
	<if test='EMAIL != null and !EMAIL.equals("")'>
