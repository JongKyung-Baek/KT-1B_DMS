<update id="updateDocsDept">
	INSERT INTO DOCS_DEPT (DEPT_CD, PARENT_DEPT_CD, DEPT_NM, DEPT_ENG_NM, COMPANY_CD, USE_YN, DEL_YN, SORT_SEQ, UPDATE_DT, PURCHASE_YN, PURCHASE_TEAM_YN, PURCHASE_PLAN_TEAM_YN, ILS_TEAM_YN, PRODUCT_TEAM_YN, DEPT_SHORT_PATH, DEPT_LONG_PATH, LVL, DEPT_TYPE, START_DATE, END_DATE)
	VALUES (#{DEPT_CD}, #{PARENT_DEPT_CD}, #{DEPT_NM}, #{DEPT_ENG_NM}, #{COMPANY_CD}, #{USE_YN}, 'N', #{SORT_SEQ}, #{UPDATE_DT}, #{PURCHASE_YN}, #{PURCHASE_TEAM_YN}, #{PURCHASE_PLAN_TEAM_YN}, #{ILS_TEAM_YN}, #{PRODUCT_TEAM_YN}, #{DEPT_SHORT_PATH}, #{DEPT_LONG_PATH}, #{LVL}, #{DEPT_TYPE}, #{START_DATE}, #{END_DATE})
		ON CONFLICT (DEPT_CD)
        DO UPDATE SET
		PARENT_DEPT_CD = EXCLUDED.PARENT_DEPT_CD,
					   DEPT_NM = EXCLUDED.DEPT_NM,
					   DEPT_ENG_NM = EXCLUDED.DEPT_ENG_NM,
					   COMPANY_CD = EXCLUDED.COMPANY_CD,
					   USE_YN = EXCLUDED.USE_YN,
					   DEL_YN = 'N',
					   SORT_SEQ = EXCLUDED.SORT_SEQ,
					   UPDATE_DT = EXCLUDED.UPDATE_DT,
					   PURCHASE_YN = EXCLUDED.PURCHASE_YN,
					   PURCHASE_TEAM_YN = EXCLUDED.PURCHASE_TEAM_YN,
					   PURCHASE_PLAN_TEAM_YN = EXCLUDED.PURCHASE_PLAN_TEAM_YN,
					   ILS_TEAM_YN = EXCLUDED.ILS_TEAM_YN,
					   PRODUCT_TEAM_YN = EXCLUDED.PRODUCT_TEAM_YN,
					   DEPT_SHORT_PATH = EXCLUDED.DEPT_SHORT_PATH,
					   DEPT_LONG_PATH = EXCLUDED.DEPT_LONG_PATH,
					   LVL = EXCLUDED.LVL,
					   DEPT_TYPE = EXCLUDED.DEPT_TYPE,
					   START_DATE = EXCLUDED.START_DATE,
					   END_DATE = EXCLUDED.END_DATE
</update>

