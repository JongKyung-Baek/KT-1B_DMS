<select id="selectItnUser" resultType="HashMap">
	SELECT *
	FROM (
			 SELECT
				 A1.*
				  , ROW_NUMBER() OVER () AS PAGEINDEX
			 FROM (
					  SELECT
						  USERID AS USER_ID
						   , NAME AS USER_NM
						   , DEPTCODE AS DEPT_CD
						   , (SELECT POSITION_CD FROM DOCS_POSITION t WHERE t.POSITION_CD_CUSTOM = u.JIKWICODE) AS POSITION_CD
						   , MAIL AS EMAIL
						   , CASE UPDATESTATE WHEN 2 THEN 'Y' ELSE 'N' END AS USE_YN
						   , CASE PERSONAL_PLACE_CD
								 WHEN 'J' THEN '1210'        /* 1사업장 */
								 WHEN 'V' THEN '1310'         /* 2사업장 */
								 WHEN 'C' THEN '3000'        /* 판교 */
								 WHEN 'A' THEN '4000'        /* 본사 */
						  END BUSINESS_AREA_CD
						   , WORK_PLACE_CD
						   , JICHKCODE
					  FROM ITN_USER u
					  ORDER BY NAME
				  ) A1
		 ) B1
	WHERE PAGEINDEX BETWEEN #{start} AND #{end}
</select>

