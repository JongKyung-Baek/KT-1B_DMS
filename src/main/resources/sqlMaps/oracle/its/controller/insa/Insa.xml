	</if>
	, PROTECT_YN = 'N'
	<if test='WORK_PLACE_CD != null and !WORK_PLACE_CD.equals("")'>
		, WORK_PLACE_CD = #{WORK_PLACE_CD}
	</if>
	WHERE USER_CD = #{USER_CD}
