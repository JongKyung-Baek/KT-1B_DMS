	VALUES (
	#{USER_CD}
	, #{USER_ID}
	<if test='USER_NM != null and !USER_NM.equals("")'>
		, #{USER_NM}
	</if>
	, 'COMP_0000000999'
	<if test='DEPT_CD != null and !DEPT_CD.equals("")'>
		, #{DEPT_CD}
	</if>
	<if test='POSITION_CD != null and !POSITION_CD.equals("")'>
		, #{POSITION_CD}
	</if>
	<if test='EMAIL != null and !EMAIL.equals("")'>
		, #{EMAIL}
	</if>
	, #{USE_YN}
	, 'N'
	<if test='BUSINESS_AREA_CD != null and !BUSINESS_AREA_CD.equals("")'>
		, #{BUSINESS_AREA_CD}
	</if>
	, 'N'
	<if test='WORK_PLACE_CD != null and !WORK_PLACE_CD.equals("")'>
		, #{WORK_PLACE_CD}
	</if>
	, 'RG_001'
	, 'I'
	)
</insert>

