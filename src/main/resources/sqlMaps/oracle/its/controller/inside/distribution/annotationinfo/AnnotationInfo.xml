<mapper namespace="sql.AnnotationInfo">

<select id="selectAnnotationPopupList" resultType="kr.esob.fdms.controller.inside.distribution.annotationinfo.AnnotationInfoListVO">
    SELECT val.TIMESTAMP, val.DATA, du.USER_NM
    FROM VIEW_ANNOTATIONS_LOG val
             JOIN VIEW_ANNOTATIONS va ON va.idx = val.document_idx
             JOIN DOCS_USER du ON du.USER_CD = val.USER_NAME
    WHERE va.OBJECT_ID = #{objectId}
</select>

</mapper>
