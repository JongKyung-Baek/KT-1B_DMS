<mapper namespace="sql.commonApproval">

<!-- 배포승인 리스트 [2019.09.24(최금영)]-->
<select id="selectApprovalList" parameterType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonApprovalParam" resultType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonApprovalPopupListVO">
	SELECT A.*
	<if test='sortColumn == null or "".equals(sortColumn)'>
		, ROW_NUMBER() OVER(ORDER BY objectNm asc) AS PAGEINDEX
	</if>
	<if test='sortColumn != null and !"".equals(sortColumn)'>
		, ROW_NUMBER() OVER(ORDER BY ${sortColumn} ${order}) AS PAGEINDEX
	</if>
	FROM (
	SELECT REQ_MAP.BUSINESS_TYPE_CD 				AS businessTypeCd
	, REQ_MAP.DISTRIBUTE_TYPE_CD 				AS distributeTypeCd
	, REQ.OBJECT_TYPE 							AS objectType
	, CASE WHEN REQ.PRINT_YN = 'Y' THEN 'viewPrint'
	WHEN REQ.DEPLOY_NORMAL_YN = 'Y' THEN 'general'
	WHEN REQ.DEPLOY_SPECIAL_YN = 'Y' THEN 'security'
	ELSE 'viewPrint'
	END 									AS distributionMethodCd
	, REQ_MAP.OBJECT_NO 						AS objectNo
	, REQ_MAP.OBJECT_NM 						AS objectNm
	, REQ_MAP.CURRENT_PAGE_NO 					AS page
	, REQ_MAP.TOTAL_PAGE_NO 					AS totalPage
	, REQ_MAP.SW_VERSION_NO 					AS swVersion
	, REQ_MAP.DOC_VERSION_NO 					AS docVersionNo
	, REQ_MAP.PRODUCT_CD 						AS productNo
	, REQ_MAP.REV_NO 							AS rev
	, REQ_MAP.STD_GAPP_DT 						AS stdGappDt
	, REQ_MAP.CHANGE_GAPP_DT 					AS changeGappDt
	, REQ.BUSINESS_AREA_CD 						AS businessAreaCd
	, REQ_MAP.PROTECT_YN 						AS protectYn
	, REQ_MAP.OBJECT_ID							AS objectId
	, REQ.REQUEST_NO							AS requestNo
	, FILE_INFO.FILE_NO							AS fileNo
	, FILE_INFO.ORG_FILE_NM						AS orgFileNm
	, FILE_INFO.USE_START_YMD					AS useStartYmd
	, FILE_INFO.USE_END_YMD						AS useEndYmd
	, FILE_INFO.FILE_NM							AS fileNm
	FROM DOCS_REQUEST_FILE FILE_INFO
	JOIN DOCS_REQUEST_MAPPING REQ_MAP
	ON FILE_INFO.OBJECT_ID = REQ_MAP.OBJECT_ID AND FILE_INFO.REQUEST_NO = REQ_MAP.REQUEST_NO
	JOIN DOCS_REQUEST REQ
	ON REQ.REQUEST_NO = REQ_MAP.REQUEST_NO
	WHERE REQ.REQUEST_NO = #{requestNo}
	) A
</select>

<!-- 배포 승인 요청 메시지 조회 [2019.09.24(최금영)]-->
<select id="getDistributionApprovalRequestDesc" parameterType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonApprovalParam" resultType="String">
	SELECT REQUEST_DESC
	FROM DOCS_REQUEST_DETAIL
	WHERE REQUEST_NO = #{requestNo}
	  AND APPROVAL_STATUS_CD = 'REQUEST'
</select>

<!-- 구매팀장 결재 후 방산팀장으로 요청 [2019.09.25(최금영)] -->
<update id="updateRequestDefInfo" parameterType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonApprovalParam">
	UPDATE DOCS_REQUEST
	SET CURRENT_PROCESS_SEQ_NO = '4'
	WHERE REQUEST_NO = #{requestNo}
</update>

<!-- 배포 승인 결과 수정 [2019.09.25(최금영)] -->
<update id="updateRequestInfo" parameterType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonApprovalParam">
	UPDATE DOCS_REQUEST
	SET STATUS_CD = #{statusCd}
	<if test='"APPROVAL".equals(statusCd)'>
		, APPROVAL_DT = CURRENT_TIMESTAMP
	</if>
	WHERE REQUEST_NO = #{requestNo}
</update>

<!-- 배포 요청 상세 수정 [2019.09.25(최금영)] -->
<update id="updateRequestDetail" parameterType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonApprovalParam">
	UPDATE DOCS_REQUEST_DETAIL
	SET REQUEST_DESC = #{rejectDesc}
	  , ACTION_CD = #{actionCd}
	  , ACTION_DT = CURRENT_TIMESTAMP
	WHERE REQUEST_NO = #{requestNo}
	  AND APPROVAL_STATUS_CD = #{approvalStatusCd}
	  AND APPROVAL_GRADE_CD = #{approvalGradeCd}
</update>

<!-- 승인 요청 아이템 리스트 갯수 조회[2019.10.01(최금영)]  -->
<select id="selectListCount" resultType="Integer" parameterType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonApprovalParam">
	SELECT COUNT(*) AS totalCount
	FROM DOCS_REQUEST_MAPPING REQ_MAP
			 JOIN DOCS_REQUEST REQ
				  ON REQ.REQUEST_NO = REQ_MAP.REQUEST_NO
	WHERE REQ.REQUEST_NO = #{requestNo}
</select>

<!-- 최종 승인 데이터에 입력할 아이템 리스트 조회 [2019.10.01(최금영)]-->
<select id="selectItemList" resultType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonApprovalPopupListVO" parameterType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonApprovalParam">
	SELECT mapping.OBJECT_ID AS objectId
		 , mapping.OBJECT_NO AS objectNo
		 , mapping.REV_NO AS rev
		 , mapping.REQUEST_NO AS requestNo
		 , mapping.BUSINESS_AREA_CD AS businessArea
		 , mapping.CURRENT_PAGE_NO AS currentPage
		 , deploy.DEPLOY_USER_CD AS deployUserCd
		 , fileInfo.FILE_NO AS fileNo
		 , req.OBJECT_TYPE AS objectTypeCd
		 , req.deploy_company_cd AS deployCompanyCd
	FROM DOCS_REQUEST_MAPPING mapping
			 INNER JOIN DOCS_REQUEST req
						ON req.REQUEST_NO = mapping.REQUEST_NO
			 INNER JOIN DOCS_REQUEST_DEPLOY deploy
						ON mapping.REQUEST_NO = deploy.REQUEST_NO
			 INNER JOIN DOCS_REQUEST_FILE fileInfo
						ON fileInfo.REQUEST_NO = mapping.REQUEST_NO
							AND fileInfo.OBJECT_ID = mapping.OBJECT_ID
	WHERE mapping.REQUEST_NO = #{requestNo}
	  AND mapping.USE_YN = 'Y'
</select>

