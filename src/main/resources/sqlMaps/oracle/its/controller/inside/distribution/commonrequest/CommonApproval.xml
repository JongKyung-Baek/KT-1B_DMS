<!-- 이전 버전 폐기할 아이템 리스트 조회 [2019.10.18(최금영)] -->
<!-- OBJECT_NO(NOT INDEX, NOT UNIQUE)로 이전 REV을 찾아야해서 INDEX를 절대 태울수 없으므로 걍 이렇게함 (APPROVAL_FILE INDEX : REQUEST_NO, OBJECT_ID, DESTROY_USER_CD)-->
<update id="updateRequestFileDestroy">
	UPDATE DOCS_REQUEST_FILE
	SET DESTROY_TYPE = '2'
	, DESTROY_STATUS_CD = '1'
	WHERE (OBJECT_ID, REQUEST_NO, FILE_NO) IN
	(
	SELECT reqMapping.OBJECT_ID AS objectId
	, req.REQUEST_NO AS requestNo
	, fileInfo.FILE_NO AS fileNo
	FROM DOCS_REQUEST_MAPPING reqMapping
	INNER JOIN DOCS_REQUEST req
	ON req.REQUEST_NO = reqMapping.REQUEST_NO
	INNER JOIN DOCS_REQUEST_FILE fileInfo
	ON fileInfo.REQUEST_NO = reqMapping.REQUEST_NO
	AND fileInfo.OBJECT_ID = reqMapping.OBJECT_ID
	AND fileInfo.DESTROY_STATUS_CD IS NULL
	WHERE  1=1
	AND req.deploy_company_cd = #{deployCompanyCd}
	AND reqMapping.OBJECT_NO = #{objectNo}
	AND req.REQUEST_NO != #{requestNo}
	AND REV_NO <![CDATA[ <= ]]> #{rev}
	<if test='"DRAWING".equals(objectType)'>
		AND reqMapping.CURRENT_PAGE_NO = #{currentPage}
	</if>
	AND req.STATUS_CD = 'APPROVAL'
	AND req.REQUEST_TYPE = 'DISTRIBUTION'
	)
</update>

<!-- 이전 버전 폐기 요청 추가 [2019.10.18(최금영)] -->
<insert id="insertDestroyRequest" parameterType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonApprovalParam">
	<selectKey keyProperty="destroyRequestNo" resultType="String" order="BEFORE">
		SELECT TO_CHAR(CURRENT_DATE,'YYYYMMDD')||'-X'||LPAD(COALESCE(SUBSTR(MAX(DESTROY_REQUEST_NO),11)::INTEGER,0)+1,4,'0') AS DESTROY_REQUEST_NO
		FROM DOCS_DESTROY_REQUEST
		WHERE SUBSTR(DESTROY_REQUEST_NO,1,10) = TO_CHAR(CURRENT_DATE,'YYYYMMDD')||'-X'
	</selectKey>
	INSERT INTO DOCS_DESTROY_REQUEST
	( DESTROY_REQUEST_NO
	, APPROVAL_LINE_ID
	, CURRENT_PROCESS_SEQ_NO
	, STATUS_CD
	, INSERT_USER_CD
	, INSERT_DT
	, APPROVAL_DT
	, DESTROY_TYPE
	, DESTROY_STATUS_CD
	, BUSINESS_AREA_CD
	, REQUEST_TYPE
	)
	VALUES
	( #{destroyRequestNo}
	, '5'
	, '1'
	, 'APPROVAL'
	, #{sessionUser.userCd}
	, CURRENT_TIMESTAMP
	, CURRENT_TIMESTAMP
	, '2'
	, '1'
	, #{businessAreaCd}
	, #{requestType}
	)
</insert>

<insert id="insertDestroyRequestDetail" parameterType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonApprovalParam">
	INSERT INTO DOCS_DESTROY_REQUEST_DETAIL
	( DESTROY_REQUEST_NO
	, PROCESS_SEQ
	, APPROVAL_STATUS_CD
	, ACTION_CD
	, ORIGINAL_USER_CD
	, ACTUAL_USER_CD
	, ACTION_DT
	)
	VALUES
		( #{destroyRequestNo}
		, CAST(#{processSeq} AS INTEGER)
		, #{approvalStatusCd}
		, 'APPROVAL'
		, #{sessionUser.userCd}
		, #{sessionUser.userCd}
		, CURRENT_TIMESTAMP
		)
</insert>

