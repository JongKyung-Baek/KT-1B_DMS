<!-- 현재 결재 라인 조회  -->
<select id="getCurrentApprovalInfo" parameterType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonApprovalParam" resultType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonApprovalParam">
	SELECT lineDtl.APPROVAL_GRADE_CD	AS approvalGradeCd
		 , lineDtl.APPROVAL_STATUS_CD	AS approvalStatusCd
		 , lineDtl.APPROVAL_LINE_ID		AS approvalLineId
		 , req.CURRENT_PROCESS_SEQ_NO	AS currentProcessSeqNo
		 , req.PROTECT_YN				AS protectYn
		 , deploy.DEPLOY_USER_CD			AS deployUserCd
		 , req.OBJECT_TYPE				AS objectType
	FROM DOCS_APPROVAL_LINE_DETAIL lineDtl
			 JOIN DOCS_APPROVAL_LINE line
				  ON lineDtl.APPROVAL_LINE_ID = line.APPROVAL_LINE_ID
			 JOIN DOCS_REQUEST req
				  ON line.APPROVAL_LINE_ID = req.APPROVAL_LINE_ID
					  AND req.REQUEST_NO = #{requestNo}
			 JOIN DOCS_REQUEST_DEPLOY deploy
				  ON req.REQUEST_NO = deploy.REQUEST_NO
	WHERE lineDtl.PROCESS_SEQ_NO = req.CURRENT_PROCESS_SEQ_NO
</select>

<update id="updatePassTarget">
	UPDATE DOCS_REQUEST_DETAIL
	SET ACTUAL_USER_CD = #{passTarget}
	WHERE REQUEST_NO = #{requestNo}
	  AND APPROVAL_STATUS_CD = 'APPROVAL'
	  AND APPROVAL_GRADE_CD = 'DEF'
</update>

<select id="selectRequestInfo" resultType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonApprovalParam">
