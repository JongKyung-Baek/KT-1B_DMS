<mapper namespace="sql.DownHistory">

    <select id="selectList" resultType="kr.esob.fdms.controller.inside.distribution.downhistory.HistoryListVO">
        SELECT
        B1.*
        FROM (
        SELECT
        A1.*,
        ROW_NUMBER() OVER(ORDER BY A1.downDate DESC) AS PAGEINDEX
        FROM (
        SELECT
        downHistory.REQUEST_NO AS requestNo,       /* мҡ”мІӯлІҲнҳё */
        downHistory.USER_NM AS userNm,
        downHistory.OBJECT_NO AS objectNo,        /* мһҗлЈҢлІҲнҳё */
        downHistory.OBJECT_ID AS objectId,
        downHistory.DOWNLOADED_NAME AS downloadedName,
        downHistory.OBJECT_NM AS objectNm,        /* мһҗлЈҢлӘ… */
        downHistory.DOWN_DATE AS downDate,
        downHistory.DOWN_COUNT AS downCount
        FROM DOCS_DOWN_HISTORY downHistory
        ) A1
        ) B1
        WHERE 1=1
        <if test='requestNo != null and !requestNo.isEmpty()'>
            AND requestNo LIKE '%' || #{requestNo} || '%'
        </if>
        <if test='objectNm != null and !objectNm.isEmpty()'>
            AND objectNm LIKE '%' || #{objectNm} || '%'
        </if>
        <if test='objectNo != null and !objectNo.isEmpty()'>
            AND objectNo LIKE '%' || #{objectNo} || '%'
        </if>
        <if test='userNm != null and !userNm.isEmpty()'>
            AND userNm LIKE '%' || #{userNm} || '%'
        </if>
        <if test='end != null and end > 0'>
            AND PAGEINDEX <![CDATA[ <= ]]> #{end}
        </if>
        <if test='start != null and start > 0'>
            AND PAGEINDEX >= #{start}
        </if>
    </select>

    <select id="selectListCount" resultType="Integer">
        SELECT COUNT(*) AS TOTAL_COUNT
        FROM (
                 SELECT
                     downHistory.REQUEST_NO AS requestNo,       /* мҡ”мІӯлІҲнҳё */
                     downHistory.USER_NM AS userNm,
                     downHistory.OBJECT_NO AS objectNo,        /* мһҗлЈҢлІҲнҳё */
                     downHistory.OBJECT_ID AS objectId,
                     downHistory.DOWNLOADED_NAME AS downloadedName,
                     downHistory.OBJECT_NM AS objectNm,        /* мһҗлЈҢлӘ… */
                     downHistory.DOWN_DATE AS downDate,
                     downHistory.DOWN_COUNT AS downCount
                 FROM DOCS_DOWN_HISTORY downHistory
             ) A1
    </select>

    <select id="selectDownHistoryPopupList" resultType="kr.esob.fdms.controller.inside.distribution.downhistory.HistoryListVO">
        SELECT
            REQUEST_NO,
            USER_NM,
            OBJECT_NO,
            OBJECT_NM,
            DOWN_DATE,
            DOWN_COUNT,
            DOWNLOADED_NAME
        FROM DOCS_DOWN_HISTORY
        WHERE REQUEST_NO = #{requestNo} AND OBJECT_ID = #{objectId}
    </select>

    <select id="selectActLogPopupList" resultType="kr.esob.fdms.controller.inside.distribution.downhistory.HistoryListVO">
        SELECT
            UUID,
            ACT_TIME,
            ACT_TYPE
        FROM DOCS_DOCUMENT_ACT_LOG
        WHERE UUID = #{downloadedName}
    </select>

</mapper>

