<mapper namespace="sql.OldCrHistory">

<select id="selectList" resultType="kr.esob.fdms.controller.inside.distribution.oldcr.HistoryListVO">
	SELECT
	B1.*
	FROM (
	SELECT
	A1.*,
	ROW_NUMBER() OVER (ORDER BY creationDate DESC) AS PAGEINDEX
	FROM (
	SELECT
	OBJECT_ID AS objectId,          -- 제의번호
	CN_DRAW_NUMBER AS cnDrawNumber, -- 도번
	FILE_NAME AS fileName,          -- 도명
	REVISION AS revision,           -- REV
	CN_TITLE AS cnTitle,            -- 제목
	FIRST_NAME AS firstName,        -- 구매담당자
	CREATION_DATE AS creationDate,  -- 요청일
	APPROVAL_DATE AS approvalDate,  -- 승인일
	STATE AS state,                 -- 진행상태
	USERNAME AS userName,           -- 업체담당자
	REJECT_COMMENT AS rejectComment,-- 요청거부사유
	CN_ERP_MAT_NO AS cnErpMatNo,    -- 자재코드
	CN_PART_NUMBER AS cnPartNumber, -- 규격화품번
	CN_RESULT AS cnResult,          -- 검토의견
	USAGE_VAL AS usageVal,          -- 제의사유코드
	OUTUSER_ID AS outuserId,        -- 업체담당자 ID
	IN_USER_ID AS inUserId,         -- 구매담당자 ID
	STATE2 AS state2,               -- 진행상태
	REQUESTDATE AS requestDate
	FROM ECR_INFO
	<if test='sortColumn == null or "".equals(sortColumn)'>
		ORDER BY creationDate DESC
	</if>
	<if test='sortColumn != null and !"".equals(sortColumn)'>
		ORDER BY ${sortColumn} ${order}
	</if>
	) A1
	WHERE 1=1
	<if test='objectId != null and !objectId.equals("")'>
		AND UPPER(TRIM(objectId)) LIKE '%' || UPPER(TRIM(#{objectId})) || '%'
	</if>
	<if test='usageVal != null and !usageVal.equals("")'>
		AND usageVal = #{usageVal}
	</if>
	<if test='inUserId != null and !inUserId.equals("")'>
		AND inUserId = #{inUserId}
	</if>
	<if test='outuserId != null and !outuserId.equals("")'>
		AND outuserId = #{outuserId}
	</if>
	<if test='state2 != null and !state2.equals("")'>
		AND state2 = #{state2}
	</if>
	<if test='startCreationDate != null and !startCreationDate.equals("")'>
		AND requestDate BETWEEN TO_DATE(#{startCreationDate}, 'YYYY-MM-DD') AND TO_DATE(#{closeCreationDate}, 'YYYY-MM-DD') + INTERVAL '1 DAY'
	</if>
	<if test='end != null and !end.equals("")'>
		AND ROWNUM <![CDATA[ <= ]]> #{end}
	</if>
	) B1
	<if test='start != null and !start.equals("")'>
		WHERE PAGEINDEX >= #{start}
	</if>
</select>

<select id="selectListCount" resultType="Integer">
	SELECT COUNT(*) AS TOTAL_COUNT
	FROM (
	SELECT
	A1.*
	FROM (
	SELECT
	OBJECT_ID AS objectId,          -- 제의번호
	CN_DRAW_NUMBER AS cnDrawNumber, -- 도번
	FILE_NAME AS fileName,          -- 도명
	REVISION AS revision,           -- REV
	CN_TITLE AS cnTitle,            -- 제목
	FIRST_NAME AS firstName,        -- 구매담당자
	CREATION_DATE AS creationDate,  -- 요청일
	APPROVAL_DATE AS approvalDate,  -- 승인일
	STATE AS state,                 -- 진행상태
	USERNAME AS userName,           -- 업체담당자
	REJECT_COMMENT AS rejectComment,-- 요청거부사유
	CN_ERP_MAT_NO AS cnErpMatNo,    -- 자재코드
	CN_PART_NUMBER AS cnPartNumber, -- 규격화품번
	CN_RESULT AS cnResult,          -- 검토의견
	USAGE_VAL AS usageVal,          -- 제의사유코드
	OUTUSER_ID AS outuserId,        -- 업체담당자 ID
	IN_USER_ID AS inUserId,         -- 구매담당자 ID
	STATE2 AS state2,               -- 진행상태
	REQUESTDATE AS requestDate
	FROM ECR_INFO
	<if test='sortColumn == null or "".equals(sortColumn)'>
		ORDER BY creationDate DESC
	</if>
	<if test='sortColumn != null and !"".equals(sortColumn)'>
		ORDER BY ${sortColumn} ${order}
	</if>
	) A1
	WHERE 1=1
	<if test='objectId != null and !objectId.equals("")'>
		AND UPPER(TRIM(objectId)) LIKE '%' || UPPER(TRIM(#{objectId})) || '%'
	</if>
	<if test='usageVal != null and !usageVal.equals("")'>
		AND usageVal = #{usageVal}
	</if>
	<if test='inUserId != null and !inUserId.equals("")'>
		AND inUserId = #{inUserId}
	</if>
	<if test='outuserId != null and !outuserId.equals("")'>
		AND outuserId = #{outuserId}
	</if>
	<if test='state2 != null and !state2.equals("")'>
		AND state2 = #{state2}
	</if>
	<if test='startCreationDate != null and !startCreationDate.equals("")'>
		AND requestDate BETWEEN TO_DATE(#{startCreationDate}, 'YYYY-MM-DD') AND TO_DATE(#{closeCreationDate}, 'YYYY-MM-DD') + INTERVAL '1 DAY'
	</if>
	) B1
</select>

