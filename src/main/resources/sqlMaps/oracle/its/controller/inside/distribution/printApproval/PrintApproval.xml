<mapper namespace="sql.PrintApproval">

	<select id="selectList" resultType="kr.esob.fdms.controller.inside.distribution.printapproval.PrintApprovalListVO" parameterType="kr.esob.fdms.controller.inside.distribution.printapproval.PrintApprovalListParam">
		SELECT
		B1.*
		FROM (
		SELECT
		A1.*,
		ROW_NUMBER() OVER (ORDER BY A1.requestDt DESC) AS PAGEINDEX
		FROM (
		SELECT
		OBJECT_TYPE AS objectType,
		FN_GET_CD_NM('objectTypeWithP', OBJECT_TYPE, #{sessionLang}) AS objectTypeNm,
		REQ.REQUEST_NO AS requestNo,
		STATUS_CD AS statusCd,
		FN_GET_CD_NM('requestStatusCd', STATUS_CD, #{sessionLang}) AS statusNm,
		REQUEST_PURPOSE AS requestPurpose,
		FN_GET_CD_NM('requestPurpose', REQUEST_PURPOSE, #{sessionLang}) AS requestPurposeNm,
		REQ.INSERT_USER_CD AS requestUserCd,
		(SELECT USER_NM FROM DOCS_USER WHERE DOCS_USER.USER_CD = REQ.INSERT_USER_CD) AS requestUserNm,
		REQ.INSERT_DT AS requestDt,
		TO_CHAR(TO_TIMESTAMP(req.DESTROY_TODO_YMD, 'YYYYMMDD'), 'YYYY-MM-DD') AS destroyTodoYmd,
		BUSINESS_AREA_CD AS businessAreaCd,
		FN_GET_CD_NM('realBusinessAreaCd', BUSINESS_AREA_CD, #{sessionLang}) AS businessAreaNm,
		REQ.PROTECT_YN AS protectYn
		FROM DOCS_REQUEST REQ
		INNER JOIN DOCS_REQUEST_DETAIL DETAIL ON DETAIL.REQUEST_NO = REQ.REQUEST_NO AND DETAIL.PROCESS_SEQ = REQ.CURRENT_PROCESS_SEQ_NO
		LEFT JOIN DOCS_APPROVAL_FILE APPROVAL_FILE ON APPROVAL_FILE.REQUEST_NO = REQ.REQUEST_NO
		WHERE DETAIL.APPROVAL_STATUS_CD = 'APPROVAL'
		AND DETAIL.ACTUAL_USER_CD = #{sessionUser.userCd}
		AND REQ.STATUS_CD = 'REQUEST'
		AND REQUEST_TYPE = 'PRINT'
		<if test='sortColumn == null or "".equals(sortColumn)'>
			ORDER BY requestDt DESC, requestNo DESC
		</if>
		<if test='sortColumn != null and !"".equals(sortColumn)'>
			ORDER BY ${sortColumn} ${order}, requestNo ${order}
		</if>
		) A1
		) B1
		<if test='start != null and !start.equals("")'>
			WHERE PAGEINDEX >= #{start}
		</if>
		<if test='end != null and !end.equals("")'>
			LIMIT #{end}
		</if>
		<if test='objectType != null and !objectType.equals("")'>
			AND objectType = #{objectType}
		</if>
		<if test='requestUserCd != null and !requestUserCd.equals("")'>
			AND requestUserCd = #{requestUserCd}
		</if>
		<if test='requestPurpose != null and !requestPurpose.equals("")'>
			AND requestPurpose = #{requestPurpose}
		</if>
		<if test='businessAreaCd != null and !businessAreaCd.equals("")'>
			AND businessAreaCd = #{businessAreaCd}
		</if>
		<if test='requestStartDt != null and !requestStartDt.equals("")'>
			AND requestDt BETWEEN TO_TIMESTAMP(#{requestStartDt}, 'YYYY-MM-DD') AND TO_TIMESTAMP(#{requestEndDt}, 'YYYY-MM-DD') + INTERVAL '1 DAY'
		</if>
	</select>

	<select id="selectListCount" resultType="Integer">
		SELECT COUNT(*) AS TOTAL_COUNT
		FROM (
		SELECT
		B1.*
		FROM (
		SELECT
		A1.*
		FROM (
		SELECT
		REQ.OBJECT_TYPE AS objectType,
		REQ.STATUS_CD AS statusCd,
		REQ.REQUEST_NO AS requestNo,
		REQ.REQUEST_PURPOSE AS requestPurpose,
		REQ.INSERT_USER_CD AS requestUserCd,
		(SELECT USER_NM FROM DOCS_USER WHERE DOCS_USER.USER_CD = REQ.INSERT_USER_CD) AS requestUserNm,
		TO_CHAR(REQ.INSERT_DT, 'YYYY-MM-DD') AS requestDt,
		REQ.DESTROY_TODO_YMD AS destroyTodoYmd,
		REQ.BUSINESS_AREA_CD AS businessAreaCd,
		DETAIL.ACTUAL_USER_CD AS currentUser,
		DESTROY_STATUS_CD AS destroyStatus
		FROM DOCS_REQUEST REQ
		INNER JOIN DOCS_REQUEST_DETAIL DETAIL ON DETAIL.REQUEST_NO = REQ.REQUEST_NO AND DETAIL.PROCESS_SEQ = REQ.CURRENT_PROCESS_SEQ_NO
		LEFT JOIN DOCS_APPROVAL_FILE APPROVAL_FILE ON APPROVAL_FILE.REQUEST_NO = REQ.REQUEST_NO
		WHERE DETAIL.APPROVAL_STATUS_CD = 'APPROVAL'
		AND DETAIL.ACTUAL_USER_CD = #{sessionUser.userCd}
		AND REQ.STATUS_CD = 'REQUEST'
		AND REQUEST_TYPE = 'PRINT'
		) A1
		WHERE 1=1
		<if test='objectType != null and !objectType.equals("")'>
			AND objectType = #{objectType}
		</if>
		<if test='requestUserCd != null and !requestUserCd.equals("")'>
			AND requestUserCd = #{requestUserCd}
		</if>
		<if test='requestPurpose != null and !requestPurpose.equals("")'>
			AND requestPurpose = #{requestPurpose}
		</if>
		<if test='businessAreaCd != null and !businessAreaCd.equals("")'>
			AND businessAreaCd = #{businessAreaCd}
		</if>
		<if test='requestStartDt != null and !requestStartDt.equals("")'>
			AND requestDt BETWEEN TO_TIMESTAMP(#{requestStartDt}, 'YYYY-MM-DD') AND TO_TIMESTAMP(#{requestEndDt}, 'YYYY-MM-DD') + INTERVAL '1 DAY'
		</if>
		) B1
		) C1
	</select>

</mapper>
