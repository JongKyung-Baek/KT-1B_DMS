<mapper namespace="sql.PrintHistory">

	<select id="selectList" resultType="kr.esob.fdms.controller.inside.distribution.printhistory.HistoryListVO">
		SELECT
		B1.*
		FROM (
		SELECT
		A1.*,
		ROW_NUMBER() OVER () AS PAGEINDEX
		FROM (
		SELECT
		mapping.BUSINESS_TYPE_CD AS businessTypeCd,
		FN_GET_CD_NM('businessTypeCd', mapping.BUSINESS_TYPE_CD, #{sessionLang}) AS businessTypeNm,
		req.REQUEST_NO AS requestNo,
		req.OBJECT_TYPE AS objectType,
		FN_GET_CD_NM('objectTypeWithP', req.OBJECT_TYPE, #{sessionLang}) AS objectTypeNm,
		mapping.OBJECT_NO AS objectNo,
		mapping.OBJECT_ID AS objectId,
		mapping.REV_NO AS revNo,
		mapping.SW_VERSION_NO AS swVersionNo,
		mapping.DOC_VERSION_NO AS docVersionNo,
		mapping.OBJECT_NM AS objectNm,
		mapping.CURRENT_PAGE_NO AS currentPageNo,
		mapping.TOTAL_PAGE_NO AS totalPageNo,
		mapping.ECN_NO AS ecnNo,
		req.REQUEST_PURPOSE AS requestPurpose,
		FN_GET_CD_NM('printRequestType', req.REQUEST_PURPOSE, #{sessionLang}) AS requestPurposeNm,
		(SELECT USER_NM FROM DOCS_USER tmp WHERE tmp.USER_CD = req.INSERT_USER_CD) AS requestUserNm,
		req.INSERT_USER_CD AS requestUserCd,
		req.INSERT_DT AS requestDt,
		fileInfo.PRINT_COUNT AS printCount,
		TO_CHAR(fileInfo.USE_END_YMD::DATE, 'YYYY-MM-DD') AS useEndYmd,
		CASE WHEN (CURRENT_DATE > fileInfo.USE_END_YMD::DATE) THEN 'Y' ELSE 'N' END AS useEndYmdYn,
		TO_CHAR(req.DESTROY_TODO_YMD::DATE, 'YYYY-MM-DD') AS destroyTodoYmd,
		mapping.STD_GAPP_DT AS stdGappDt,
		mapping.CHANGE_GAPP_DT AS changeGappDt,
		COALESCE(mapping.PRODUCT_CD, '') AS productNm,
		mapping.PRODUCT_CD AS productCd,
		mapping.BUSINESS_AREA_CD AS businessAreaCd,
		FN_GET_CD_NM('businessAreaCd', mapping.BUSINESS_AREA_CD, #{sessionLang}) AS businessAreaNm,
		mapping.PROTECT_YN AS protectYn,
		reqDetail.REQUEST_DESC AS requestDesc,
		destroyReq.INSERT_USER_CD AS destroyRequestUserCd,
		(SELECT USER_NM FROM DOCS_USER tmp WHERE tmp.USER_CD = destroyReq.INSERT_USER_CD) AS destroyRequestUserNm,
		destroyReq.APPROVAL_DT AS destroyApprovalDt,
		destroyReq.DESTROY_STATUS_CD AS destroyStatusCd,
		FN_GET_CD_NM('destroyStatusCd', destroyReq.DESTROY_STATUS_CD, #{sessionLang}) AS destroyStatusNm,
		destroyReq.DESTROY_TYPE AS destroyType,
		FN_GET_CD_NM('destroyType', destroyReq.DESTROY_TYPE, #{sessionLang}) AS destroyTypeNm,
		approvalFile.DESTROY_DT AS destroyDt,
		fileInfo.FILE_NO AS fileNo,
		fileInfo.ORG_FILE_NM AS orgFileNm,
		appDetail.ACTUAL_USER_CD AS approvalUserCd,
		(SELECT USER_NM FROM DOCS_USER tmp WHERE tmp.USER_CD = appDetail.ACTUAL_USER_CD) AS approvalUserNm
		FROM DOCS_REQUEST_FILE fileInfo
		INNER JOIN DOCS_REQUEST_MAPPING mapping ON fileInfo.REQUEST_NO = mapping.REQUEST_NO AND fileInfo.OBJECT_ID = mapping.OBJECT_ID
		INNER JOIN DOCS_REQUEST req ON mapping.REQUEST_NO = req.REQUEST_NO
		INNER JOIN DOCS_REQUEST_DETAIL reqDetail ON reqDetail.REQUEST_NO = req.REQUEST_NO AND reqDetail.APPROVAL_STATUS_CD = 'REQUEST'
		LEFT JOIN DOCS_APPROVAL_FILE approvalFile ON approvalFile.REQUEST_NO = mapping.REQUEST_NO AND approvalFile.OBJECT_ID = mapping.OBJECT_ID
		LEFT JOIN DOCS_DESTROY_REQUEST_MAPPING destroyMapping ON destroyMapping.REQUEST_NO = mapping.REQUEST_NO AND destroyMapping.OBJECT_ID = mapping.OBJECT_ID
		LEFT JOIN DOCS_DESTROY_REQUEST destroyReq ON destroyReq.DESTROY_REQUEST_NO = destroyMapping.DESTROY_REQUEST_NO
		LEFT JOIN DOCS_DESTROY_REQUEST_DETAIL destroyReqDtl ON destroyReqDtl.DESTROY_REQUEST_NO = destroyReq.DESTROY_REQUEST_NO AND destroyReqDtl.APPROVAL_STATUS_CD = 'REQUEST'
		LEFT JOIN DOCS_REQUEST_DETAIL appDetail ON appDetail.REQUEST_NO = req.REQUEST_NO AND appDetail.APPROVAL_STATUS_CD = 'APPROVAL'
		WHERE req.REQUEST_TYPE = 'PRINT'
		AND req.STATUS_CD = 'APPROVAL'
		<if test='requestStartDt != null and !requestStartDt.equals("")'>
			AND req.INSERT_DT BETWEEN TO_DATE(#{requestStartDt}, 'YYYY-MM-DD') AND TO_DATE(#{requestEndDt}, 'YYYY-MM-DD') + INTERVAL '1 DAY'
		</if>
		<if test='printTermYn != null and printTermYn.equals("Y")'>
			AND fileInfo.USE_END_YMD >= TO_CHAR(CURRENT_DATE - (SELECT SYSTEM_CONFIG_VALUE::INTEGER FROM DOCS_SYSTEM_CONFIG t WHERE t.SYSTEM_CONFIG_GROUP = 'SYSTEM_CONFIG' AND t.SYSTEM_CONFIG_CD = 'VALID_TERM'), 'YYYYMMDD')
			AND fileInfo.USE_END_YMD <![CDATA[ <= ]]> TO_CHAR(CURRENT_DATE, 'YYYYMMDD')
		</if>
		<if test='printDisposalTermYn != null and printDisposalTermYn.equals("Y")'>
			AND req.DESTROY_TODO_YMD >= TO_CHAR(CURRENT_DATE - (SELECT SYSTEM_CONFIG_VALUE::INTEGER FROM DOCS_SYSTEM_CONFIG t WHERE t.SYSTEM_CONFIG_GROUP = 'SYSTEM_CONFIG' AND t.SYSTEM_CONFIG_CD = 'VALID_TERM'), 'YYYYMMDD')
			AND req.DESTROY_TODO_YMD <![CDATA[ <= ]]> TO_CHAR(CURRENT_DATE, 'YYYYMMDD')
		</if>
		<if test='sortColumn == null or "".equals(sortColumn)'>
			<choose>
				<when test='printTermYn.equals("Y")'>
					ORDER BY useEndYmd DESC
				</when>
				<when test='printDisposalTermYn.equals("Y")'>
					ORDER BY destroyTodoYmd DESC
				</when>
				<otherwise>
					<if test='requestStartDt != null and !requestStartDt.equals("")'>
						ORDER BY requestDt DESC, requestNo DESC
					</if>
				</otherwise>
			</choose>
		</if>
		<if test='sortColumn != null and !"".equals(sortColumn)'>
			ORDER BY ${sortColumn} ${order}, requestNo ${order}
		</if>
		<if test='sortColumn == null or "".equals(sortColumn)'>
			ORDER BY requestDt DESC
		</if>
		) A1
		) B1
		<if test='requestNo != null and !requestNo.equals("")'>
			AND requestNo = #{requestNo}
		</if>
		<if test='objectType != null and !objectType.equals("")'>
			AND objectType = #{objectType}
		</if>
		<if test='requestUserCd != null and !requestUserCd.equals("")'>
			AND requestUserCd = #{requestUserCd}
		</if>
		<if test='requestPurpose != null and !requestPurpose.equals("")'>
			AND requestPurpose = #{requestPurpose}
		</if>
		<if test='destroyStatusCd != null and !destroyStatusCd.equals("")'>
			AND destroyStatusCd = #{destroyStatusCd}
		</if>
		<if test='businessAreaCd != null and !businessAreaCd.equals("")'>
			AND businessAreaCd = #{businessAreaCd}
		</if>
		<if test='destroyRequestUserCd != null and !destroyRequestUserCd.equals("")'>
			AND destroyRequestUserCd = #{destroyRequestUserCd}
		</if>
	</select>

	<select id="selectListCount" resultType="Integer">
		SELECT COUNT(*) AS TOTAL_COUNT
		FROM (
		SELECT
		A1.*
		FROM (
		SELECT
		mapping.BUSINESS_TYPE_CD AS businessTypeCd,
		FN_GET_CD_NM('businessTypeCd', mapping.BUSINESS_TYPE_CD, #{sessionLang}) AS businessTypeNm,
		req.REQUEST_NO AS requestNo,
		req.OBJECT_TYPE AS objectType,
		FN_GET_CD_NM('objectTypeWithP', req.OBJECT_TYPE, #{sessionLang}) AS objectTypeNm,
		mapping.OBJECT_NO AS objectNo,
		mapping.OBJECT_ID AS objectId,
		mapping.REV_NO AS revNo,
		mapping.SW_VERSION_NO AS swVersionNo,
		mapping.DOC_VERSION_NO AS docVersionNo,
		mapping.OBJECT_NM AS objectNm,
		mapping.CURRENT_PAGE_NO AS currentPageNo,
		mapping.TOTAL_PAGE_NO AS totalPageNo,
		mapping.ECN_NO AS ecnNo,
		req.REQUEST_PURPOSE AS requestPurpose,
		FN_GET_CD_NM('printRequestType', req.REQUEST_PURPOSE, #{sessionLang}) AS requestPurposeNm,
		(SELECT USER_NM FROM DOCS_USER tmp WHERE tmp.USER_CD = req.INSERT_USER_CD) AS requestUserNm,
		req.INSERT_USER_CD AS requestUserCd,
		req.INSERT_DT AS requestDt,
		fileInfo.PRINT_COUNT AS printCount,
		TO_CHAR(fileInfo.USE_END_YMD::DATE, 'YYYY-MM-DD') AS useEndYmd,
		CASE WHEN (CURRENT_DATE > fileInfo.USE_END_YMD::DATE) THEN 'Y' ELSE 'N' END AS useEndYmdYn,
		TO_CHAR(req.DESTROY_TODO_YMD::DATE, 'YYYY-MM-DD') AS destroyTodoYmd,
		mapping.STD_GAPP_DT AS stdGappDt,
		mapping.CHANGE_GAPP_DT AS changeGappDt,
		COALESCE(mapping.PRODUCT_CD, '') AS productNm,
		mapping.PRODUCT_CD AS productCd,
		mapping.BUSINESS_AREA_CD AS businessAreaCd,
		FN_GET_CD_NM('businessAreaCd', mapping.BUSINESS_AREA_CD, #{sessionLang}) AS businessAreaNm,
		mapping.PROTECT_YN AS protectYn,
		reqDetail.REQUEST_DESC AS requestDesc,
		destroyReq.INSERT_USER_CD AS destroyRequestUserCd,
		(SELECT USER_NM FROM DOCS_USER tmp WHERE tmp.USER_CD = destroyReq.INSERT_USER_CD) AS destroyRequestUserNm,
		destroyReq.APPROVAL_DT AS destroyApprovalDt,
		destroyReq.DESTROY_STATUS_CD AS destroyStatusCd,
		FN_GET_CD_NM('destroyStatusCd', destroyReq.DESTROY_STATUS_CD, #{sessionLang}) AS destroyStatusNm,
		destroyReq.DESTROY_TYPE AS destroyType,
		FN_GET_CD_NM('destroyType', destroyReq.DESTROY_TYPE, #{sessionLang}) AS destroyTypeNm,
		approvalFile.DESTROY_DT AS destroyDt,
		fileInfo.FILE_NO AS fileNo,
		fileInfo.ORG_FILE_NM AS orgFileNm,
		appDetail.ACTUAL_USER_CD AS approvalUserCd,
		(SELECT USER_NM FROM DOCS_USER tmp WHERE tmp.USER_CD = appDetail.ACTUAL_USER_CD) AS approvalUserNm
		FROM DOCS_REQUEST_FILE fileInfo
		INNER JOIN DOCS_REQUEST_MAPPING mapping ON fileInfo.REQUEST_NO = mapping.REQUEST_NO AND fileInfo.OBJECT_ID = mapping.OBJECT_ID
		INNER JOIN DOCS_REQUEST req ON mapping.REQUEST_NO = req.REQUEST_NO
		INNER JOIN DOCS_REQUEST_DETAIL reqDetail ON reqDetail.REQUEST_NO = req.REQUEST_NO AND reqDetail.APPROVAL_STATUS_CD = 'REQUEST'
		LEFT JOIN DOCS_APPROVAL_FILE approvalFile ON approvalFile.REQUEST_NO = mapping.REQUEST_NO AND approvalFile.OBJECT_ID = mapping.OBJECT_ID
		LEFT JOIN DOCS_DESTROY_REQUEST_MAPPING destroyMapping ON destroyMapping.REQUEST_NO = mapping.REQUEST_NO AND destroyMapping.OBJECT_ID = mapping.OBJECT_ID
		LEFT JOIN DOCS_DESTROY_REQUEST destroyReq ON destroyReq.DESTROY_REQUEST_NO = destroyMapping.DESTROY_REQUEST_NO
		LEFT JOIN DOCS_DESTROY_REQUEST_DETAIL destroyReqDtl ON destroyReqDtl.DESTROY_REQUEST_NO = destroyReq.DESTROY_REQUEST_NO AND destroyReqDtl.APPROVAL_STATUS_CD = 'REQUEST'
		LEFT JOIN DOCS_REQUEST_DETAIL appDetail ON appDetail.REQUEST_NO = req.REQUEST_NO AND appDetail.APPROVAL_STATUS_CD = 'APPROVAL'
		WHERE req.REQUEST_TYPE = 'PRINT'
		AND req.STATUS_CD = 'APPROVAL'
		<if test='requestStartDt != null and !requestStartDt.equals("")'>
			AND req.INSERT_DT BETWEEN TO_DATE(#{requestStartDt}, 'YYYY-MM-DD') AND TO_DATE(#{requestEndDt}, 'YYYY-MM-DD') + INTERVAL '1 DAY'
		</if>
		<if test='printTermYn != null and printTermYn.equals("Y")'>
			AND fileInfo.USE_END_YMD >= TO_CHAR(CURRENT_DATE - (SELECT SYSTEM_CONFIG_VALUE::INTEGER FROM DOCS_SYSTEM_CONFIG t WHERE t.SYSTEM_CONFIG_GROUP = 'SYSTEM_CONFIG' AND t.SYSTEM_CONFIG_CD = 'VALID_TERM'), 'YYYYMMDD')
			AND fileInfo.USE_END_YMD <![CDATA[ <= ]]> TO_CHAR(CURRENT_DATE, 'YYYYMMDD')
		</if>
		<if test='printDisposalTermYn != null and printDisposalTermYn.equals("Y")'>
			AND req.DESTROY_TODO_YMD >= TO_CHAR(CURRENT_DATE - (SELECT SYSTEM_CONFIG_VALUE::INTEGER FROM DOCS_SYSTEM_CONFIG t WHERE t.SYSTEM_CONFIG_GROUP = 'SYSTEM_CONFIG' AND t.SYSTEM_CONFIG_CD = 'VALID_TERM'), 'YYYYMMDD')
			AND req.DESTROY_TODO_YMD <![CDATA[ <= ]]> TO_CHAR(CURRENT_DATE, 'YYYYMMDD')
		</if>
		) A1
		) B1
		<if test='objectType != null and !objectType.equals("")'>
			AND objectType = #{objectType}
		</if>
		<if test='requestUserCd != null and !requestUserCd.equals("")'>
			AND requestUserCd = #{requestUserCd}
		</if>
		<if test='requestPurpose != null and !requestPurpose.equals("")'>
			AND requestPurpose = #{requestPurpose}
		</if>
		<if test='destroyStatusCd != null and !destroyStatusCd.equals("")'>
			AND destroyStatusCd = #{destroyStatusCd}
		</if>
		<if test='businessAreaCd != null and !businessAreaCd.equals("")'>
			AND businessAreaCd = #{businessAreaCd}
		</if>
		<if test='destroyRequestUserCd != null and !destroyRequestUserCd.equals("")'>
			AND destroyRequestUserCd = #{destroyRequestUserCd}
		</if>
	</select>

	<insert id="inserDestoryRequest" parameterType="kr.esob.fdms.controller.inside.distribution.printhistory.DestroyRequestParam">
		<selectKey keyProperty="destroyRequestNo" resultType="String" order="BEFORE">
			SELECT
			TO_CHAR(CURRENT_DATE, 'YYYYMMDD') || '-X' ||
			LPAD(CAST(COALESCE(SUBSTRING(MAX(DESTROY_REQUEST_NO) FROM 11)::INTEGER, 0) + 1 AS TEXT), 4, '0')
			AS DESTROY_REQUEST_NO
			FROM DOCS_DESTROY_REQUEST
			WHERE SUBSTRING(DESTROY_REQUEST_NO, 1, 10) = TO_CHAR(CURRENT_DATE, 'YYYYMMDD') || '-X';
		</selectKey>
		INSERT INTO DOCS_DESTROY_REQUEST
		(DESTROY_REQUEST_NO, APPROVAL_LINE_ID, CURRENT_PROCESS_SEQ_NO, STATUS_CD, INSERT_USER_CD, INSERT_DT, DESTROY_TYPE, DESTROY_STATUS_CD, BUSINESS_AREA_CD, REQUEST_TYPE)
		VALUES
		(#{destroyRequestNo}, CAST(#{approvalLineId} AS INTEGER), CAST(#{currentProcessSeqNo} AS INTEGER), 'REQUEST', #{sessionUser.userCd}, CURRENT_TIMESTAMP, '6', '2', #{businessAreaCd}, 'PRINT')
	</insert>

	<select id="getDocsApprovalLineDetail" parameterType="kr.esob.fdms.controller.inside.distribution.printhistory.DestroyRequestParam" resultType="kr.esob.fdms.controller.inside.distribution.commonrequest.ApprovalLineDetailVO">
		SELECT APPROVAL_STATUS_CD AS approvalStatusCd,
			   APPROVAL_GRADE_CD AS approvalGradeCd
		FROM DOCS_APPROVAL_LINE_DETAIL
		WHERE APPROVAL_LINE_ID = CAST(#{approvalLineId} AS INTEGER)
		ORDER BY PROCESS_SEQ_NO
	</select>

	<insert id="insertDocsDestroyRequestDetail" parameterType="kr.esob.fdms.controller.inside.distribution.printhistory.DestroyRequestParam">
		/* 폐기 요청 상세 추가 */
		INSERT INTO DOCS_DESTROY_REQUEST_DETAIL
		(
		DESTROY_REQUEST_NO,
		PROCESS_SEQ,
		APPROVAL_STATUS_CD,
		APPROVAL_GRADE_CD
		<if test='"REQUEST".equals(approvalStatusCd)'>
			, REQUEST_DESC,
			ACTION_DT,
			ACTION_CD,
			ORIGINAL_USER_CD,
			ACTUAL_USER_CD
		</if>
		<if test='"APPROVAL".equals(approvalStatusCd) and "TL".equals(approvalGradeCd)'>
			, ORIGINAL_USER_CD,
			ACTUAL_USER_CD
		</if>
		<if test='"APPROVAL".equals(approvalStatusCd) and "DEF".equals(approvalGradeCd)'>
			, ORIGINAL_USER_CD,
			ACTUAL_USER_CD
		</if>
		)
		VALUES
		(
		#{destroyRequestNo},
		CAST(#{processSeq} AS INTEGER),
		#{approvalStatusCd},
		#{approvalGradeCd}
		<if test='"REQUEST".equals(approvalStatusCd)'>
			, #{requestDesc},
			NOW(),
			'REQUEST',
			#{sessionUser.userCd},
			#{sessionUser.userCd}
		</if>
		<if test='"APPROVAL".equals(approvalStatusCd) and "TL".equals(approvalGradeCd)'>
			, (SELECT TEAM_LEADER_USER_CD
			FROM DOCS_DEPT
			WHERE DEPT_CD = #{sessionUser.deptCd}),
			#{teamLeaderUid}
		</if>
		<if test='"APPROVAL".equals(approvalStatusCd) and "DEF".equals(approvalGradeCd)'>
			<if test='"Development".equals(businessTypeCd)'>
				, #{developmentProtectUserUid},
				#{developmentProtectUserUid}
			</if>
			<if test='"Production".equals(businessTypeCd)'>
				, #{productProtectUid},
				#{productProtectUid}
			</if>
		</if>
		)
	</insert>



	<insert id="insertDocsDestoryRequestMapping" parameterType="kr.esob.fdms.controller.inside.distribution.printhistory.DestroyRequestParam">
		INSERT INTO DOCS_DESTROY_REQUEST_MAPPING
			(REQUEST_NO, OBJECT_ID, DESTROY_REQUEST_NO, DEPLOY_USER_CD)
		VALUES
			(#{requestNo}, #{objectId}, #{destroyRequestNo}, #{sessionUser.userCd})
	</insert>

	<select id="getProtectUser" resultType="HashMap" parameterType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonDistributionRequestParam">
		SELECT NULL AS BUSINESS_TYPE_CD, NULL AS USER_CD
		WHERE 1 = 0
	</select>

	<update id="updateApprovalFile" parameterType="kr.esob.fdms.controller.inside.distribution.printhistory.DestroyRequestParam">
		UPDATE DOCS_APPROVAL_FILE
		SET LAST_DESTROY_REQUEST_NO = #{destroyRequestNo}
		WHERE REQUEST_NO = #{requestNo}
		  AND OBJECT_ID = #{objectId}
	</update>
</mapper>
