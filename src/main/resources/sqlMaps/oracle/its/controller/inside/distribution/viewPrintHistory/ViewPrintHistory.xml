<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="sql.ViewPrintHistory">

    <select id="selectList" resultType="kr.esob.fdms.controller.inside.distribution.viewprinthistory.HistoryListVO">
        SELECT
        B1.*
        FROM (
        SELECT
        A1.*
        -- 		, ROW_NUMBER() OVER(ORDER BY A1.insertDt DESC) AS PAGEINDEX
        , ROW_NUMBER() OVER(
        ORDER BY
        <if test='sortColumn == null or "".equals(sortColumn)'>
            A1.insertDt DESC
        </if>
        <if test='sortColumn != null and !"".equals(sortColumn)'>
            <choose>
                <when test="sortColumn == 'revision'">
                    CASE
                    WHEN A1.${sortColumn} ~ '^\d+$' THEN CAST(A1.${sortColumn} AS INTEGER)
                    ELSE NULL
                    END ${order},
                    A1.${sortColumn} ${order}
                </when>
                <otherwise>
                    A1.${sortColumn} ${order}
                </otherwise>
            </choose>
        </if>
        ) AS PAGEINDEX
        FROM (
        SELECT
        CASE
            WHEN info.DISTRIBUTION_TYPE = 'FunctionCode' THEN 'Documents'
            WHEN info.DISTRIBUTION_TYPE = 'CCB' THEN '기술자료관리'
            ELSE info.DISTRIBUTION_TYPE
        END AS distributionType,
        info.DRAWING_NO AS drawingNo,
        <!--		FN_GET_CD_NM('businessTypeCd', info.BUSINESS_TYPE_CD, 'ko') AS businessTypeNm, -->
        info.OBJECT_ID AS objectId,
        info.ORG_FILE_NM AS orgFileNm,
        <!-- 		FN_GET_CD_NM('distributeTypeCd', info.DISTRIBUTE_TYPE_CD, 'ko') AS distributeTypeNm, -->
        info.REVISION AS revision,
        info.USER_ID AS userId,
        info.INSERT_DATE AS insertDt,
        info.USER_NM AS userNm,
        info.LOG_TYPE AS logType,
        '' AS checkSum
        FROM DOCS_HISTORY info
        WHERE 1=1
        <if test='drawingNo != null and !drawingNo.isEmpty()'>
            <choose>
                <when test='revision != null and !revision.isEmpty() and revision.equals("Y")'>
                    AND info.DRAWING_NO = UPPER(TRIM(#{drawingNo}))
                </when>
                <otherwise>
                    AND info.DRAWING_NO LIKE '%' || UPPER(TRIM(#{drawingNo})) || '%'
                </otherwise>
            </choose>
        </if>
        <if test='distributionType != null and !distributionType.isEmpty()'>
            <choose>
                <when test='distributionType.equals("기술자료관리")'>
                    AND info.DISTRIBUTION_TYPE = 'CCB'
                </when>
                <otherwise>
                    AND info.DISTRIBUTION_TYPE LIKE '%' || #{distributionType} || '%'
                </otherwise>
            </choose>
        </if>
        <if test='orgFileNm != null and !orgFileNm.isEmpty()'>
            AND info.ORG_FILE_NM LIKE '%' || #{orgFileNm} || '%'
        </if>
        <if test='revision != null and !revision.isEmpty()'>
            AND info.REVISION LIKE '%' || #{revision} || '%'
        </if>
        <if test='userId != null and !userId.isEmpty()'>
            AND info.USER_ID = #{userId}
        </if>
        <if test='insertDt != null and !insertDt.isEmpty()'>
            AND info.INSERT_DATE = #{insertDt}
        </if>
        <if test='userNm != null and !userNm.isEmpty()'>
            AND info.USER_NM LIKE '%' || TRIM(#{userNm}) || '%'
        </if>
        <if test='logType != null and !logType.isEmpty()'>
            AND info.LOG_TYPE = #{logType}
        </if>
<!--        <if test='viewPrintHistoryList != null and viewPrintHistoryList.size() != 0'>-->
<!--            <choose>-->
<!--                <when test='"Y".equals(useLike)'>-->
<!--                    AND (-->
<!--                    <foreach separator="OR" collection="viewPrintHistoryList" item="viewPrintHistoryInfo">-->
<!--                        (DRAWING_NO LIKE '%' || UPPER(TRIM(#{viewPrintHistoryInfo.drawingNo})) || '%')-->
<!--                    </foreach>-->
<!--                    )-->
<!--                </when>-->
<!--                <otherwise>-->
<!--                    AND (-->
<!--                    <foreach separator="OR" collection="viewPrintHistoryList" item="viewPrintHistoryInfo">-->
<!--                        (DRAWING_NO = UPPER(TRIM(#{viewPrintHistoryInfo.drawingNo})))-->
<!--                    </foreach>-->
<!--                    )-->
<!--                </otherwise>-->
<!--            </choose>-->
<!--        </if>-->
        <if test='sortColumn == null or "".equals(sortColumn)'>
            ORDER BY info.INSERT_DATE DESC
        </if>
        <if test='sortColumn != null and !"".equals(sortColumn)'>
            ORDER BY ${sortColumn} ${order}
        </if>
        ) A1
        ) B1
        WHERE 1=1
        <if test='end != null'>
            AND PAGEINDEX <![CDATA[<=]]> #{end}
        </if>
        <if test='start != null'>
            AND PAGEINDEX >= #{start}
        </if>
    </select>

    <select id="selectListCount" resultType="Integer">
        SELECT COUNT(*) AS TOTAL_COUNT
        FROM (
        SELECT
        A1.*
        FROM (
        SELECT
        CASE
            WHEN info.DISTRIBUTION_TYPE = 'FunctionCode' THEN 'Documents'
            WHEN info.DISTRIBUTION_TYPE = 'CCB' THEN '기술자료관리'
            ELSE info.DISTRIBUTION_TYPE
        END AS distributionType,
        <!--		FN_GET_CD_NM('businessTypeCd', info.BUSINESS_TYPE_CD, 'ko') AS businessTypeNm, -->
        info.OBJECT_ID AS objectId,
        info.ORG_FILE_NM AS orgFileNm,
        -- 		FN_GET_CD_NM('distributeTypeCd', info.DISTRIBUTE_TYPE_CD, 'ko') AS distributeTypeNm,
        info.REVISION AS revision,
        info.DRAWING_NO AS drawingNo,
        info.USER_ID AS userId,
        info.INSERT_DATE AS insertDt,
        info.USER_NM AS userNm,
        info.LOG_TYPE AS logType,
        '' AS checkSum
        FROM DOCS_HISTORY info
        WHERE 1=1
        <if test='distributionType != null and !distributionType.isEmpty()'>
            <choose>
                <when test='distributionType.equals("기술자료관리")'>
                    AND info.DISTRIBUTION_TYPE = 'CCB'
                </when>
                <otherwise>
                    AND info.DISTRIBUTION_TYPE = #{distributionType}
                </otherwise>
            </choose>
        </if>
        <if test='objectId != null and !objectId.isEmpty()'>
            AND info.OBJECT_ID LIKE '%' || #{objectId} || '%'
        </if>
        <if test='drawingNo != null and !drawingNo.isEmpty()'>
            <choose>
                <when test='revision != null and !revision.isEmpty() and revision.equals("Y")'>
                    AND info.DRAWING_NO = UPPER(TRIM(#{drawingNo}))
                </when>
                <otherwise>
                    AND info.DRAWING_NO LIKE '%' || UPPER(TRIM(#{drawingNo})) || '%'
                </otherwise>
            </choose>
        </if>
        <if test='orgFileNm != null and !orgFileNm.isEmpty()'>
            AND info.ORG_FILE_NM LIKE '%' || #{orgFileNm} || '%'
        </if>
        <if test='revision != null and !revision.isEmpty()'>
            AND info.REVISION = #{revision}
        </if>
        <if test='userId != null and !userId.isEmpty()'>
            AND info.USER_ID = #{userId}
        </if>
        <if test='insertDt != null and !insertDt.isEmpty()'>
            AND info.INSERT_DATE LIKE '%' || UPPER(TRIM(#{insertDt})) || '%'
        </if>
        <if test='userNm != null and !userNm.isEmpty()'>
            AND info.USER_NM = #{userNm}
        </if>
        <if test='logType != null and !logType.isEmpty()'>
            AND info.LOG_TYPE  = #{logType}
        </if>
<!--        <if test='viewPrintHistoryList != null and viewPrintHistoryList.size() != 0'>-->
<!--            <choose>-->
<!--                <when test='"Y".equals(useLike)'>-->
<!--                    AND (-->
<!--                    <foreach separator="OR" collection="viewPrintHistoryList" item="viewPrintHistoryInfo">-->
<!--                        (DRAWING_NO LIKE '%' || UPPER(TRIM(#{viewPrintHistoryInfo.drawingNo})) || '%')-->
<!--                    </foreach>-->
<!--                    )-->
<!--                </when>-->
<!--                <otherwise>-->
<!--                    AND (-->
<!--                    <foreach separator="OR" collection="viewPrintHistoryList" item="viewPrintHistoryInfo">-->
<!--                        (DRAWING_NO = UPPER(TRIM(#{viewPrintHistoryInfo.drawingNo})))-->
<!--                    </foreach>-->
<!--                    )-->
<!--                </otherwise>-->
<!--            </choose>-->
<!--        </if>-->
        ) A1
        ) B1
    </select>
</mapper>
