<select id="getUserInfoByUserCd" resultType="kr.esob.fdms.controller.inside.organizationmanage.insideuser.UserListVO">
	SELECT
		a.USER_ID AS userId
		 , a.USER_CD AS userCd
		 , a.EMAIL AS email
		 , a.USER_PWD AS userPwd
		 , a.COMPANY_CD AS companyCd
		 , '' AS companyNm
		 , a.USER_NM AS userNm
		 , a.DEPT_CD AS deptCd
		 , (SELECT d1.DEPT_NM FROM DOCS_DEPT d1 WHERE d1.DEPT_CD = a.DEPT_CD) AS deptNm
		 , a.POSITION_CD AS positionCd
		 , (SELECT p1.POSITION_NM FROM DOCS_POSITION p1 WHERE p1.POSITION_CD = a.POSITION_CD) AS positionNm
		 , a.ROLE_GROUP AS roleGroupCd
		 , (SELECT rg1.GROUP_NM FROM DOCS_ROLE_GROUP rg1 WHERE rg1.GROUP_CODE = a.ROLE_GROUP) AS roleGroupNm
		 , CASE WHEN a.PROTECT_YN IS NULL THEN 'N' ELSE a.PROTECT_YN END AS protectYn
	FROM DOCS_USER a
	WHERE USER_CD = #{userCd}
</select>

	<update id="editDeptInfo" parameterType="kr.esob.fdms.controller.inside.organizationmanage.insidedept.DeptPopupParam">
		UPDATE DOCS_DEPT
		<set>
			DEPT_CD = #{deptCd},
			DEPT_NM = #{deptNm},
			DEPT_SHORT_PATH = #{deptNm},
			USE_YN = #{useYn},
			DEL_YN = #{delYn},
			SORT_SEQ = #{sortSeq}
		</set>
		WHERE DEPT_CD = #{deptCd}
	</update>

	<update id="editUserInfo_resetPwd" parameterType="kr.esob.fdms.controller.inside.organizationmanage.insideuser.UserPopupParam">
		UPDATE DOCS_USER
		<set>
		    USER_PWD = #{userPwd}
		</set>
		WHERE USER_CD = #{userCd}
	</update>

	<select id="countUsersByDeptCd" resultType="int"  parameterType="kr.esob.fdms.controller.inside.organizationmanage.insidedept.DeptPopupParam">
		SELECT COUNT(*)
		FROM docs_user
		WHERE dept_cd = #{deptCd}
	</select>


</mapper>
