<mapper namespace="sql.OrganizationmanageInsidedept">

<select id="selectDeptInfo" resultType="kr.esob.fdms.controller.inside.organizationmanage.insidedept.InsidedeptListVO">
	SELECT
		(SELECT MAX(DEPT_CD) FROM DOCS_DEPT WHERE DEPT_CD ~ '^[A-Z0-9]*\d+$') AS deptCd,
		STRING_AGG(DEPT_NM, ',') AS allDeptNms
	FROM DOCS_DEPT;
</select>

	<select id="selectList" resultType="kr.esob.fdms.controller.inside.organizationmanage.insidedept.InsidedeptListVO">
		SELECT
		B1.*
		FROM
		(
		SELECT
		A1.*,
		ROW_NUMBER() OVER () AS pageIndex
		FROM
		(
		SELECT deptInfo.DEPT_CD        AS deptCd,          /* 사용자계정 */
		deptInfo.DEPT_NM        AS deptNm,
		deptInfo.USE_YN        AS useYn,          /* 사용자성명 */
		deptInfo.DEL_YN        AS delYn          /* 부서코드 */
		FROM DOCS_DEPT deptInfo
		<if test='sortColumn != null and !"".equals(sortColumn)'>
			ORDER BY ${sortColumn} ${order}
		</if>
		) A1
		WHERE 1=1
		<if test='deptCd != null and !deptCd.equals("")'>
			AND A1.deptCd LIKE CONCAT('%', #{deptCd}, '%')
		</if>
		<if test='deptNm != null and !deptNm.equals("")'>
			AND A1.deptNm LIKE CONCAT('%', #{deptNm}, '%')
		</if>
		<if test='useYn != null and !useYn.equals("")'>
			AND A1.useYnad = #{useYn}
		</if>
		) B1
		WHERE 1=1
		<if test='end != null and !end.equals("")'>
			AND B1.pageIndex <![CDATA[ <= ]]> #{end}
		</if>
		<if test='start != null and !start.equals("")'>
			AND B1.pageIndex >= #{start}
		</if>
	</select>

<select id="selectListCount" resultType="Integer">
	SELECT COUNT(deptInfo.DEPT_CD) AS TOTAL_COUNT
	FROM DOCS_DEPT deptInfo
	WHERE 1=1
	<if test='deptCd != null and !deptCd.equals("")'>
		AND deptInfo.DEPT_CD = #{deptCd}
	</if>
	<if test='useYn != null and !useYn.equals("")'>
		AND deptInfo.USE_YN = #{useYn}
	</if>
</select>

<update id="updateUnlock">
	UPDATE DOCS_USER
	SET LAST_LOGIN_DT = CURRENT_TIMESTAMP
	  , LOCK_YN = 'N'
	WHERE USER_NM = #{userNm}
</update>

<update id="resetPwd">
	UPDATE DOCS_USER
	SET USER_PWD = #{userPwd}
	WHERE USER_CD = #{userCd}
</update>


<select id="selectPurchaserCombo" resultType="kr.esob.fdms.commonlogic.combo.ComboInfoVO">
	SELECT
		'purchaser' AS comboCd
		 , USER_CD AS comboVal
		 , USER_NM || '[' || USER_ID || ']' AS comboLabel
		 , USER_NM || '[' || USER_ID || ']' AS comboTooltip
	FROM DOCS_USER docsUser
			 INNER JOIN DOCS_DEPT docsDept ON docsDept.DEPT_CD = docsUser.DEPT_CD
	WHERE docsDept.PURCHASE_YN = 'Y'
	  AND docsUser.USE_YN = 'Y'
	  AND docsUser.DEL_YN = 'N'
	ORDER BY USER_NM
</select>

<select id="selectPurchaserComboById" resultType="kr.esob.fdms.commonlogic.combo.ComboInfoVO">
	SELECT
		'purchaser' AS comboCd
		 , USER_ID AS comboVal
		 , USER_NM || '[' || USER_ID || ']' AS comboLabel
		 , USER_NM || '[' || USER_ID || ']' AS comboTooltip
	FROM DOCS_USER docsUser
			 INNER JOIN DOCS_DEPT docsDept ON docsDept.DEPT_CD = docsUser.DEPT_CD
	WHERE docsDept.PURCHASE_YN = 'Y'
	  AND docsUser.USE_YN = 'Y'
	  AND docsUser.DEL_YN = 'N'
	ORDER BY USER_NM
</select>

<select id="selectCompanyCombo" resultType="kr.esob.fdms.commonlogic.combo.ComboInfoVO">
	SELECT
		'company' AS comboCd
		 , '' AS comboVal
		 , '' AS comboLabel
	WHERE 1=0
</select>

<select id="selectUserCombo" resultType="kr.esob.fdms.commonlogic.combo.SearchComboInfoVO">
	SELECT X.*
	FROM (
	SELECT USER_ID AS id
	, USER_NM || '[' || USER_ID || ']' AS text
	, USER_NM || '[' || USER_ID || ']' AS title
	, ROW_NUMBER() OVER (ORDER BY USER_NM) AS pageindex
	FROM DOCS_USER
	WHERE 1=1
	AND USE_YN = 'Y'
	AND DEL_YN = 'N'
	<if test='term != null and !"".equals(term)'>
		AND USER_NM LIKE '%' || #{term} || '%'
	</if>
	) X
	<if test='page != null and !page.equals("")'>
		WHERE PAGEINDEX BETWEEN #{posStart} AND #{count} * #{page}
	</if>
</select>

<select id="selectUserComboUserCd" resultType="kr.esob.fdms.commonlogic.combo.SearchComboInfoVO">
	SELECT X.*
	FROM (
	SELECT USER_CD AS id
	, USER_NM || '[' || USER_ID || ']' AS text
	, USER_NM || '[' || USER_ID || ']' AS title
	, ROW_NUMBER() OVER (ORDER BY USER_NM) AS pageindex
	FROM DOCS_USER
	WHERE 1=1
	AND USE_YN = 'Y'
	AND DEL_YN = 'N'
	<if test='term != null and !"".equals(term)'>
		AND USER_NM LIKE '%' || #{term} || '%'
	</if>
	) X
	<if test='page != null and !page.equals("")'>
		WHERE PAGEINDEX BETWEEN #{posStart} AND #{count} * #{page}
	</if>
</select>

