	<insert id="insertRegisterDeptInfo" parameterType="kr.esob.fdms.controller.inside.organizationmanage.insidedept.DeptPopupParam">

		INSERT INTO DOCS_DEPT
		(
		DEPT_CD,
		DEPT_NM,
		DEPT_SHORT_PATH,
		USE_YN,
		DEL_YN,
		SORT_SEQ,
		COMPANY_CD
		)
		VALUES
		(
		#{deptCd},
		#{deptNm},
		#{deptNm},
		#{useYn},
		#{delYn},
		#{sortSeq},
	    'COMP_0000000999'
		)
	</insert>

<insert id="insertRegisterUserGroup" parameterType="kr.esob.fdms.controller.inside.organizationmanage.insideuser.UserPopupParam">
	INSERT INTO DOCS_ROLE_GROUP_MEMBER
	VALUES
	(
		#{roleGroupCd},
		#{userCd},
		'USER'
	)
</insert>
<insert id="insertRegisterDeptGroup" parameterType="kr.esob.fdms.controller.inside.organizationmanage.insideuser.UserPopupParam">
	INSERT INTO DOCS_ROLE_GROUP_MEMBER
	VALUES
	(
		#{roleGroupCd},
		#{deptCd},
		'DEPT'
	)
	ON CONFLICT (group_code, member_cd) DO NOTHING
</insert>

