<mapper namespace="sql.OrganizationmanageOutsideUser">


	<select id="selectList" resultType="kr.esob.fdms.controller.inside.organizationmanage.outsideuser.UserListVO">
		SELECT B1.*
		FROM (
		SELECT A1.*, ROW_NUMBER() OVER () AS PAGEINDEX
		FROM (
		SELECT
		a.USER_CD AS userCd,
		a.USER_NM AS userNm,
		a.EMAIL AS email,
		a.LAST_LOGIN_DT AS lastLoginDt,
		a.PWD_UPDATE_DT AS pwdUpdateDt,
		a.LOGIN_COUNT AS loginCount,
		CASE
		WHEN EXTRACT(DAY FROM (CURRENT_DATE - a.LAST_LOGIN_DT)) > 30 THEN 'Y'
		ELSE COALESCE(a.LOCK_YN, 'N')
		END AS lockYn,
		COALESCE(a.PROTECT_YN, 'N') AS protectYn,
		CASE WHEN b.approval_user_cd IS NULL THEN 'N' ELSE 'Y' END AS crYn,
		a.distribution_person_yn AS distributionYn
		FROM DOCS_USER a
		LEFT JOIN DOCS_COMPANY b ON a.USER_CD = b.APPROVAL_USER_CD
		WHERE a.COMPANY_CD = #{companyCd}
		AND a.USE_YN = 'Y'
		AND a.DEL_YN = 'N'
		<if test='userNm != null and !userNm.equals("")'>
			AND userNm ILIKE '%' || #{userNm} || '%'
		</if>
		<if test='sortColumn != null and !"".equals(sortColumn)'>
			ORDER BY ${sortColumn} ${order}
		</if>
		) A1
		) B1
		<if test='end != null and !end.equals("")'>
			WHERE B1.PAGEINDEX <![CDATA[ <= ]]> #{end}
		</if>
		<if test='start != null and !start.equals("")'>
			AND B1.PAGEINDEX >= #{start}
		</if>
	</select>




	<select id="selectListCount" resultType="Integer">
		SELECT COUNT(*)
		FROM (
		SELECT A1.*, ROW_NUMBER() OVER () AS row_num
		FROM (
		SELECT
		USER_CD AS userCd,
		USER_NM AS userNm,
		EMAIL AS email,
		LAST_LOGIN_DT AS lastLoginDt,
		PWD_UPDATE_DT AS pwdUpdateDt,
		LOGIN_COUNT AS loginCount
		FROM DOCS_USER
		WHERE COMPANY_CD = #{companyCd}
		AND USE_YN = 'Y'
		AND DEL_YN = 'N'
		) A1
		) B1
		WHERE 1=1
		<if test='userNm != null and !userNm.equals("")'>
			AND userNm LIKE '%' || #{userNm} || '%'
		</if>
		<if test='end != null and !end.equals("")'>
			AND B1.row_num <![CDATA[ <= ]]> #{end}
		</if>
	</select>


<select id="selectUserCd" resultType="String">
	SELECT
			'USER_' || COALESCE(LPAD(CAST(CAST(SUBSTR(MAX(USER_CD), 6) AS INTEGER) + 1 AS TEXT), 10, '0'), '0000000001')
	FROM DOCS_USER

</select>

<insert id="insertUser">
	INSERT INTO DOCS_USER(
						   USER_CD
						 , USER_ID
						 , USER_NM
						 , EMAIL
						 , USER_PWD
						 , COMPANY_CD
						 , USE_YN
						 , DEL_YN
						 , LOCK_YN
						 , PROTECT_YN
						 , ROLE_GROUP
						 , LOGIN_COUNT
						 , AUTH_SITE
						 , INSERT_UID
						 , INSERT_DT
						 , UPDATE_UID
						 , UPDATE_DT
						 , PWD_UPDATE_DT
						 , DISTRIBUTION_PERSON_YN
	)
	VALUES (
			   #{userCd}
		   , (SELECT COALESCE(MAX(CAST(USER_ID AS INTEGER)),0)+1
			  FROM DOCS_USER
			  WHERE AUTH_SITE = 'E'
				AND REGEXP_INSTR(USER_ID,'[^0-9]') = 0
			   )
		   , #{userNm}
		   , #{email}
		   , #{userPwd}
		   , #{companyCd}
		   , 'Y'
		   , 'N'
		   , 'N'
		   , 'N'
		   , 'RG_006'
		   , 0
		   , 'E'
		   , #{sessionUser.userCd}
		   , CURRENT_TIMESTAMP
		   , #{sessionUser.userCd}
		   , CURRENT_TIMESTAMP
		   , CURRENT_TIMESTAMP
		   , #{distributionYn}
		   )
</insert>

<update id="updateUser">
	UPDATE DOCS_USER
	<set>
		<if test="userNm != null">USER_NM = #{userNm},</if>
		<if test="email != null">EMAIL = #{email},</if>
		<if test="userPwd != null">USER_PWD = #{userPwd},</if>
		<if test="companyCd != null">COMPANY_CD = #{companyCd},</if>
		<if test="protectYn != null">PROTECT_YN = #{protectYn},</if>
		<if test="sessionUser != null and sessionUser.userCd != null">UPDATE_UID = #{sessionUser.userCd},</if>
		<if test="distributionYn != null">DISTRIBUTION_PERSON_YN = #{distributionYn},</if>
		UPDATE_DT = CURRENT_TIMESTAMP
	</set>
	WHERE USER_CD = #{userCd}
</update>

<update id="updateAppUserCd">
	UPDATE DOCS_COMPANY
	SET APPROVAL_USER_CD = CASE WHEN #{crYn} = 'Y' THEN #{userCd} ELSE NULL END
	  , UPDATE_USER_CD = #{sessionUser.userCd}
	  , UPDATE_DT = CURRENT_TIMESTAMP
	WHERE COMPANY_CD = #{companyCd}
</update>

	<select id="selectUser" resultType="kr.esob.fdms.controller.inside.organizationmanage.outsideuser.UserListVO">
		SELECT
			a.USER_ID AS userId,
			a.USER_CD AS userCd,
			a.EMAIL AS email,
<!--			a.USER_PWD AS userPwd, -->
			a.COMPANY_CD AS companyCd,
			(SELECT b1.COMPANY_NM FROM DOCS_COMPANY b1 WHERE b1.COMPANY_CD = a.COMPANY_CD) AS companyNm,
			a.USER_NM AS userNm,
			CASE
				WHEN a.PROTECT_YN IS NULL THEN 'N'
				ELSE a.PROTECT_YN
				END AS protectYn,
			CASE
				WHEN b.APPROVAL_USER_CD IS NULL THEN 'N'
				ELSE 'Y'
				END AS crYn,
			COALESCE(a.DISTRIBUTION_PERSON_YN, 'N') AS distributionYn
		FROM DOCS_USER a
				 LEFT JOIN DOCS_COMPANY b ON a.USER_CD = b.APPROVAL_USER_CD
		WHERE a.USER_CD = #{userCd}
	</select>

<update id="updateUnlockAccount">
	/* lock 해제 */
	UPDATE DOCS_USER
	SET LOCK_YN = 'N'
	  , LOGIN_COUNT = 0
	  , LAST_LOGIN_DT = CURRENT_TIMESTAMP
	  , UPDATE_UID = #{sessionUser.userCd}
	  , UPDATE_DT = CURRENT_TIMESTAMP
	WHERE USER_CD = #{userCd}
</update>

</mapper>

