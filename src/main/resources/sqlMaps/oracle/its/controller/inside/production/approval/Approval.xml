	</if>
	<if test="'SW'.equals(objectType)">
		, fileInfo.SW_NO AS objectNo, fileInfo.SW_NM AS objectNm, fileInfo.SW_CLASS_CD2 AS objectType, fileInfo.PRODUCT_NO AS productNo
	</if>
	, fileInfo.OBJECT_ID AS objectId
	<if test="'DOC'.equals(objectType)">
		, 1 AS fileNo
	</if>
	<if test="'SW'.equals(objectType)">
		, fileInfo.FILE_NO AS fileNo
	</if>
	, req.REQUEST_NO AS requestNo
	FROM DOCS_REQUEST_MAPPING reqMap
	JOIN DOCS_REQUEST req ON reqMap.REQUEST_NO = req.REQUEST_NO
	<if test="'DOC'.equals(objectType)">
		JOIN DOCS_PRODUCT_DOCUMENT fileInfo ON reqMap.OBJECT_ID = fileInfo.OBJECT_ID
	</if>
	<if test="'SW'.equals(objectType)">
		JOIN DOCS_PRODUCT_SW fileInfo ON reqMap.OBJECT_ID = fileInfo.OBJECT_ID
	</if>
	WHERE reqMap.REQUEST_NO = #{requestNo}
</select>

<select id="getRequestInfo" resultType="kr.esob.fdms.controller.inside.production.approval.ApprovalPopupVO">
	SELECT reqDtl.REQUEST_DESC AS requestDesc
	FROM DOCS_REQUEST_DETAIL reqDtl
	WHERE reqDtl.APPROVAL_STATUS_CD = 'REQUEST' AND reqDtl.REQUEST_NO = #{requestNo}
</select>

<insert id="insertApprovalFile" parameterType="kr.esob.fdms.controller.inside.production.approval.ApprovalPopupParam">
	/* 최종 승인(DOCS_APPROVAL_FILE)에 추가 */
	INSERT INTO DOCS_APPROVAL_FILE
	(
		REQUEST_NO,
		INSERT_USER_CD,
		INSERT_DT,
		UPDATE_USER_CD,
		UPDATE_DT,
		OBJECT_ID,
		DEPLOY_USER_CD,
		FILE_NO
	)
	VALUES
		(
			#{requestNo},
			#{sessionUser.userCd},
			CURRENT_TIMESTAMP,
			#{sessionUser.userCd},
			CURRENT_TIMESTAMP,
			#{objectId},
			#{deployUserCd},
			1
		)
</insert>

<select id="selectReplaceRequestList" resultType="kr.esob.fdms.controller.inside.production.approval.ApprovalPopupVO">
	SELECT rm.OBJECT_CLASS_CD2, FN_GET_CD_NM('objectClassCd2', rm.OBJECT_CLASS_CD2, #{sessionLang}) AS objectClassNm2, r.OBJECT_TYPE, FN_GET_CD_NM('productionObjectType', r.OBJECT_TYPE, #{sessionLang}) AS objectTypeNm, rm.OBJECT_NO, rm.OBJECT_NM, rm.REV_NO AS rev, di.DEPLOY_DEPT_CD AS deptCd, (SELECT DEPT_NM FROM DOCS_DEPT WHERE DEPT_CD = di.DEPLOY_DEPT_CD) AS deptNm, di.DEPLOY_USER_CD AS userCd, (SELECT USER_NM FROM DOCS_USER WHERE USER_CD = di.DEPLOY_USER_CD) AS userNm, di.DEPLOY_COUNT, di.DESTROY_COUNT, di.COPY, di.OBJECT_ID, (di.DEPLOY_COUNT * di.COPY) AS totalCount
	FROM DOCS_REQUEST r
			 INNER JOIN DOCS_REQUEST_MAPPING rm ON r.REQUEST_NO = rm.REQUEST_NO
			 INNER JOIN DOCS_DEPLOY_INFO di ON r.REQUEST_NO = di.REQUEST_NO AND rm.OBJECT_ID = di.OBJECT_ID
	WHERE r.REQUEST_NO = #{requestNo}
</select>

<update id="updateDeployInfoReject">
	UPDATE DOCS_DEPLOY_INFO
	SET DEPLOY_ACCEPT_YN = 'Y'
	WHERE REQUEST_NO = #{requestNo}
</update>

<update id="updateDeployInfo">
	UPDATE DOCS_DEPLOY_INFO
	SET DEPLOY_ACCEPT_YN = 'Y'
	WHERE OBJECT_NO = #{objectNo} AND DEPLOY_DEPT_CD = #{deployDeptCd} AND DEPLOY_USER_CD = #{deployUserCd}
</update>

</mapper>
