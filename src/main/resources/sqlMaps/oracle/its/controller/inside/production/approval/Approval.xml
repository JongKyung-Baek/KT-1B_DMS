<update id="updateProductionStatus">
	UPDATE DOCS_PRODUCT_STATUS
	SET CURRENT_COUNT = #{currentCount}, UPDATE_DT = CURRENT_TIMESTAMP, LAST_REQUEST_NO = #{lastRequestNo}, OBJECT_TYPE = #{objectType}, LAST_DEPLOY_REV_NO = #{lastDeployRevNo}
	WHERE OBJECT_NO = #{objectNo} AND DEPT_CD = #{deptCd} AND USER_CD = #{userCd}
</update>

<insert id="insertProductionStatus">
	INSERT INTO DOCS_PRODUCT_STATUS
	(
		OBJECT_NO,
		DEPT_CD,
		CURRENT_COUNT,
		INSERT_DT,
		UPDATE_DT,
		LAST_REQUEST_NO,
		OBJECT_TYPE,
		DISPOSAL_REQUEST_YN,
		USER_CD,
		LAST_DEPLOY_REV_NO
	)
	VALUES
		(
			#{objectNo},
			#{deptCd},
			#{currentCount},
			CURRENT_TIMESTAMP,
			CURRENT_TIMESTAMP,
			#{lastRequestNo},
			#{objectType},
			'N',
			#{userCd},
			#{lastDeployRevNo}
		)
</insert>

