<!-- 현재 결재 라인 조회 -->
<select id="getCurrentApprovalInfo" resultType="kr.esob.fdms.controller.inside.distribution.commonrequest.CommonApprovalParam">
	SELECT lineDtl.APPROVAL_GRADE_CD AS approvalGradeCd, lineDtl.APPROVAL_STATUS_CD AS approvalStatusCd, lineDtl.APPROVAL_LINE_ID AS approvalLineId, req.CURRENT_PROCESS_SEQ_NO AS currentProcessSeqNo, req.PROTECT_YN AS protectYn
	FROM DOCS_APPROVAL_LINE_DETAIL lineDtl
			 JOIN DOCS_APPROVAL_LINE line ON lineDtl.APPROVAL_LINE_ID = line.APPROVAL_LINE_ID
