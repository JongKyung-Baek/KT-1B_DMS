<mapper namespace="sql.ProductionApproval">

<select id="selectList" resultType="kr.esob.fdms.controller.inside.production.approval.ApprovalListVO">
	SELECT
	B1.*
	FROM
	(
	SELECT
	requestNo,
	requestNo AS hiddenRequestNo,
	deployTypeCd,
	deployTypeNm,
	TO_CHAR(TO_DATE(deployDt, 'YYYYMMDD'), 'YYYY-MM-DD') AS deployDt,
	requestUserNm,
	requestUserCd,
	TO_CHAR(requestDt, 'YYYY-MM-DD') AS requestDt,
	requestReason,
	businessAreaCd,
	businessAreaNm,
	objectType,
	objectTypeNm,
	requestPurpose,
	requestType,
	requestTypeNm,
	ROW_NUMBER() OVER() AS PAGEINDEX
	FROM
	(
	SELECT
	request.REQUEST_NO AS requestNo,
	REQUEST_PURPOSE AS deployTypeCd,
	FN_GET_CD_NM('deployType', REQUEST_PURPOSE, #{sessionLang}) AS deployTypeNm,
	USE_START_YMD AS deployDt,
	(
	SELECT USER_NM
	FROM DOCS_USER tmp
	WHERE tmp.USER_CD = request.INSERT_USER_CD
	) AS requestUserNm,
	INSERT_USER_CD AS requestUserCd,
	request.INSERT_DT AS requestDt,
	reqDetail.REQUEST_DESC AS requestReason,
	request.BUSINESS_AREA_CD AS businessAreaCd,
	FN_GET_CD_NM('businessAreaCd', request.BUSINESS_AREA_CD, #{sessionLang}) AS businessAreaNm,
	request.OBJECT_TYPE AS objectType,
	FN_GET_CD_NM('objectType', request.OBJECT_TYPE, #{sessionLang}) AS objectTypeNm,
	request.REQUEST_PURPOSE AS requestPurpose,
	CASE request.REQUEST_PURPOSE
	WHEN 'NEW' THEN 'DISTRIBUTION'
	WHEN 'REPLACE' THEN 'DISTRIBUTION'
	ELSE 'PRINT'
	END AS requestType,
	CASE request.REQUEST_PURPOSE
	WHEN 'NEW' THEN (SELECT LANG_DESC FROM DOCS_LANG t WHERE t.LANG_CD='btn.distributionRequest' AND LANG_TYPE=#{sessionLang})
	WHEN 'REPLACE' THEN (SELECT LANG_DESC FROM DOCS_LANG t WHERE t.LANG_CD='btn.distributionRequest' AND LANG_TYPE=#{sessionLang})
	ELSE (SELECT LANG_DESC FROM DOCS_LANG t WHERE t.LANG_CD='label.print' AND LANG_TYPE=#{sessionLang})
	END AS requestTypeNm
	FROM DOCS_REQUEST request
	INNER JOIN DOCS_REQUEST_DETAIL reqDetail ON reqDetail.REQUEST_NO = request.REQUEST_NO AND reqDetail.APPROVAL_STATUS_CD = 'REQUEST'
	INNER JOIN DOCS_REQUEST_DETAIL appDetail ON appDetail.REQUEST_NO = request.REQUEST_NO AND appDetail.APPROVAL_STATUS_CD = 'APPROVAL'
	INNER JOIN DOCS_REQUEST_DETAIL currDetail ON currDetail.REQUEST_NO = request.REQUEST_NO AND currDetail.PROCESS_SEQ = request.CURRENT_PROCESS_SEQ_NO
	WHERE currDetail.APPROVAL_STATUS_CD = 'APPROVAL'
	AND request.STATUS_CD = 'REQUEST'
	AND currDetail.ACTUAL_USER_CD = #{sessionUser.userCd}
	AND REQUEST_TYPE = 'PRODUCT'
	<if test='requestStartDt != null and !requestStartDt.equals("")'>
		AND request.INSERT_DT BETWEEN TO_DATE(#{requestStartDt}, 'YYYY-MM-DD') AND TO_DATE(#{requestEndDt}, 'YYYY-MM-DD') + INTERVAL '1 DAY'
	</if>
	<if test='sortColumn == null or "".equals(sortColumn)'>
		ORDER BY requestDt DESC
	</if>
	<if test='sortColumn != null and !"".equals(sortColumn)'>
		ORDER BY ${sortColumn} ${order}
	</if>
	) A1
	WHERE 1=1
	<if test='requestNo != null and !requestNo.equals("")'>
		AND requestNo = #{requestNo}
	</if>
	<if test='requestType != null and !requestType.equals("")'>
		AND requestType = #{requestType}
	</if>
	<if test='requestUserCd != null and !requestUserCd.equals("")'>
		AND requestUserCd = #{requestUserCd}
	</if>
	<if test='deployTypeCd != null and !deployTypeCd.equals("")'>
		AND deployTypeCd = #{deployTypeCd}
	</if>
	<if test='businessAreaCd != null and !businessAreaCd.equals("")'>
		AND businessAreaCd = #{businessAreaCd}
	</if>
	<if test='objectType != null and !objectType.equals("")'>
		AND objectType = #{objectType}
	</if>
	<if test='end != null and !end.equals("")'>
		AND ROW_NUMBER() OVER() <![CDATA[ <= ]]> #{end}
	</if>
	) B1
	<if test='start != null and !start.equals("")'>
		WHERE PAGEINDEX >= #{start}
	</if>
</select>

<select id="selectListCount" resultType="Integer">
	SELECT COUNT(*) AS TOTAL_COUNT
	FROM
	(
	SELECT A1.*, ROW_NUMBER() OVER() AS PAGEINDEX
	FROM
	(
	SELECT
	request.REQUEST_NO AS requestNo,
	REQUEST_PURPOSE AS deployTypeCd,
	CASE
	WHEN USE_START_YMD IS NULL THEN NULL
	ELSE SUBSTR(USE_START_YMD, 0, 4) || '-' || SUBSTR(USE_START_YMD, 5, 2) || '-' || SUBSTR(USE_START_YMD, 7, 2)
	END AS useStartYmd,
	(
	SELECT USER_NM
	FROM DOCS_USER tmp
	WHERE tmp.USER_CD = request.INSERT_USER_CD
	) AS requestUserNm,
	INSERT_USER_CD AS requestUserCd,
	TO_CHAR(request.INSERT_DT, 'YYYY-MM-DD') AS requestDt,
	reqDetail.REQUEST_DESC AS requestReason,
	request.BUSINESS_AREA_CD AS businessAreaCd,
	request.OBJECT_TYPE AS objectType,
	CASE request.REQUEST_PURPOSE
	WHEN 'NEW' THEN 'DISTRIBUTION'
	WHEN 'REPLACE' THEN 'DISTRIBUTION'
	ELSE 'PRINT'
	END AS requestType,
	CASE request.REQUEST_PURPOSE
	WHEN 'NEW' THEN (SELECT LANG_DESC FROM DOCS_LANG t WHERE t.LANG_CD='btn.distributionRequest' AND LANG_TYPE=#{sessionLang})
	WHEN 'REPLACE' THEN (SELECT LANG_DESC FROM DOCS_LANG t WHERE t.LANG_CD='btn.distributionRequest' AND LANG_TYPE=#{sessionLang})
	ELSE (SELECT LANG_DESC FROM DOCS_LANG t WHERE t.LANG_CD='label.print' AND LANG_TYPE=#{sessionLang})
	END AS requestTypeNm
	FROM DOCS_REQUEST request
	INNER JOIN DOCS_REQUEST_DETAIL reqDetail ON reqDetail.REQUEST_NO = request.REQUEST_NO AND reqDetail.APPROVAL_STATUS_CD = 'REQUEST'
	INNER JOIN DOCS_REQUEST_DETAIL appDetail ON appDetail.REQUEST_NO = request.REQUEST_NO AND appDetail.APPROVAL_STATUS_CD = 'APPROVAL'
	INNER JOIN DOCS_REQUEST_DETAIL currDetail ON currDetail.REQUEST_NO = request.REQUEST_NO AND currDetail.PROCESS_SEQ = request.CURRENT_PROCESS_SEQ_NO
	WHERE currDetail.APPROVAL_STATUS_CD = 'APPROVAL'
	AND request.STATUS_CD = 'REQUEST'
	AND currDetail.ACTUAL_USER_CD = #{sessionUser.userCd}
	AND REQUEST_TYPE = 'PRODUCT'
	<if test='requestStartDt != null and !requestStartDt.equals("")'>
		AND request.INSERT_DT BETWEEN TO_DATE(#{requestStartDt}, 'YYYY-MM-DD') AND TO_DATE(#{requestEndDt}, 'YYYY-MM-DD') + INTERVAL '1 DAY'
	</if>
	) A1
	WHERE 1=1
	<if test='requestNo != null and !requestNo.equals("")'>
		AND requestNo = #{requestNo}
	</if>
	<if test='requestUserCd != null and !requestUserCd.equals("")'>
		AND requestUserCd = #{requestUserCd}
	</if>
	<if test='deployTypeCd != null and !deployTypeCd.equals("")'>
		AND deployTypeCd = #{deployTypeCd}
	</if>
	<if test='requestType != null and !requestType.equals("")'>
		AND requestType = #{requestType}
	</if>
	<if test='businessAreaCd != null and !businessAreaCd.equals("")'>
		AND businessAreaCd = #{businessAreaCd}
	</if>
	<if test='objectType != null and !objectType.equals("")'>
		AND objectType = #{objectType}
	</if>
	) B1
</select>

<!-- 접수자 정보 리스트 조회 [2019.10.24(최금영)] -->
<select id="selectRequestUserList" parameterType="kr.esob.fdms.controller.inside.production.approval.ApprovalPopupParam" resultType="kr.esob.fdms.controller.inside.production.approval.ApprovalPopupVO">
	/* 생산기술자료 접수자 리스트 조회 */
	SELECT dept.DEPT_NM AS deptNm, userInfo.BUSINESS_AREA_CD AS businessAreaCd, userInfo.USER_NM AS userNm, depInfo.COPY AS copy, depInfo.DEPLOY_COUNT * depInfo.COPY AS totalCount, userInfo.USER_CD AS userCd
	FROM DOCS_REQUEST_DEPLOY reqDep
	INNER JOIN
	(
	SELECT REQUEST_NO, MAX(OBJECT_ID) AS OBJECT_ID, DEPLOY_USER_CD, COPY, SUM(DEPLOY_COUNT) AS DEPLOY_COUNT
	FROM DOCS_DEPLOY_INFO
	GROUP BY REQUEST_NO, DEPLOY_USER_CD, COPY
	) depInfo ON reqDep.REQUEST_NO = depInfo.REQUEST_NO AND reqDep.DEPLOY_USER_CD = depInfo.DEPLOY_USER_CD
	LEFT JOIN DOCS_REQUEST_MAPPING reqMap ON reqDep.REQUEST_NO = reqMap.REQUEST_NO AND reqMap.OBJECT_ID = depInfo.OBJECT_ID
	JOIN DOCS_USER userInfo ON reqDep.DEPLOY_USER_CD = userInfo.USER_CD
	JOIN DOCS_DEPT dept ON userInfo.DEPT_CD = dept.DEPT_CD
	WHERE reqDep.REQUEST_NO = #{requestNo}
	<if test='sortColumn == null or "".equals(sortColumn)'>
		ORDER BY userNm DESC
	</if>
	<if test='sortColumn != null and !"".equals(sortColumn)'>
		ORDER BY ${sortColumn} ${order}
	</if>
</select>

<!-- 접수자 정보 리스트 갯수 [2019.10.24(최금영)] -->
<select id="selectRequestUserListCount" parameterType="kr.esob.fdms.controller.inside.production.approval.ApprovalPopupParam" resultType="Integer">
	/* 접수자 정보 리스트 갯수 */
	SELECT COUNT(*) AS TOTAL_COUNT
	FROM DOCS_REQUEST_DEPLOY deploy
			 LEFT JOIN DOCS_REQUEST req ON deploy.REQUEST_NO = req.REQUEST_NO
			 LEFT JOIN DOCS_USER userInfo ON deploy.DEPLOY_USER_CD = userInfo.USER_CD
	WHERE req.REQUEST_NO = #{requestNo}
</select>

<!-- 배포승인 자료 리스트 [2019.10.24(최금영)] -->
<select id="selectObjectList" parameterType="kr.esob.fdms.controller.inside.production.approval.ApprovalPopupParam" resultType="kr.esob.fdms.controller.inside.production.approval.ApprovalPopupVO">
	/* 배포승인 자료 리스트 */
	SELECT mapping.OBJECT_NO, mapping.OBJECT_NM, mapping.OBJECT_CLASS_NM2 AS objectTypeNm, mapping.REV_NO, fileInfo.fileNo AS itemCount, depInfo.DEPLOY_COUNT, depInfo.DESTROY_COUNT, mapping.PRODUCT_CD, COALESCE(mapping.PRODUCT_CD, '') AS productNm, mapping.OBJECT_ID AS objectId
	FROM DOCS_REQUEST_MAPPING mapping
	INNER JOIN
	(
	SELECT REQUEST_NO, OBJECT_ID, DEPLOY_COUNT, DESTROY_COUNT
	FROM DOCS_DEPLOY_INFO
	GROUP BY REQUEST_NO, OBJECT_ID, DEPLOY_COUNT, DESTROY_COUNT
	) depInfo ON mapping.REQUEST_NO = depInfo.REQUEST_NO AND mapping.OBJECT_ID = depInfo.OBJECT_ID
	<if test="'DOC'.equals(objectType)">
		INNER JOIN DOCS_PRODUCT_DOCUMENT product ON product.OBJECT_ID = mapping.OBJECT_ID
	</if>
	<if test="'SW'.equals(objectType)">
		INNER JOIN DOCS_PRODUCT_SW product ON product.OBJECT_ID = mapping.OBJECT_ID
	</if>
	<if test="'DOC'.equals(objectType)">
		INNER JOIN
		(
		SELECT OBJECT_ID, MAX(FILE_NO) AS fileNo
		FROM DOCS_PRODUCT_DOCUMENT_FILE
		GROUP BY OBJECT_ID
		) fileInfo ON product.OBJECT_ID = fileInfo.OBJECT_ID
	</if>
	<if test="'SW'.equals(objectType)">
		INNER JOIN
		(
		SELECT OBJECT_ID, MAX(FILE_NO) AS fileNo
		FROM DOCS_PRODUCT_SW_FILE
		GROUP BY OBJECT_ID
		) fileInfo ON product.OBJECT_ID = fileInfo.OBJECT_ID
	</if>
	WHERE mapping.REQUEST_NO = #{requestNo}
	ORDER BY OBJECT_NM DESC
</select>

<!-- 배포승인 자료 갯수 [2019.10.24(최금영)] -->
<select id="selectObjectListCount" parameterType="kr.esob.fdms.controller.inside.production.approval.ApprovalPopupParam" resultType="Integer">
