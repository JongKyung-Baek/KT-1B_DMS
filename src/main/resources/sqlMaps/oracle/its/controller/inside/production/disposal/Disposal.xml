<select id="selectDisposalList" resultType="kr.esob.fdms.controller.inside.production.disposal.DisposalRequestPopupParam">
	SELECT request.REQUEST_NO
		 , mapping.OBJECT_ID
		 , #{destroyRequestNo} AS destroyRequestNo
		 , #{acceptUserCd} AS acceptUserCd
		 , #{businessAreaCd} AS businessAreaCd
		 , #{objectNo} AS objectNo
		 , 1 AS fileNo
	FROM DOCS_REQUEST request
			 INNER JOIN DOCS_REQUEST_MAPPING mapping
						ON request.REQUEST_NO = mapping.REQUEST_NO
			 INNER JOIN DOCS_REQUEST_DEPLOY deploy
						ON request.REQUEST_NO = deploy.REQUEST_NO
	WHERE request.REQUEST_TYPE = 'PRODUCT'
	  AND deploy.DEPLOY_USER_CD = #{acceptUserCd}
	  AND mapping.OBJECT_NO = #{objectNo}
</select>

