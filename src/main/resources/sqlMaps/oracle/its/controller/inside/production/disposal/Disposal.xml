<!-- 배포 정보에 폐기 정보 추가 입력 [2019.10.23(최금영)] -->
<update id="updateApprovalFile" parameterType="kr.esob.fdms.controller.inside.distribution.history.DestroyPopupParam">
	/* 배포 정보에 폐기 정보 추가 입력 */
