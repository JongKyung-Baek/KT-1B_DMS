<mapper namespace="sql.ProductionDisposal">

<select id="selectList" resultType="kr.esob.fdms.controller.inside.production.disposal.DisposalListVO">
	SELECT B1.*
	FROM
	(
	SELECT A1.*
	, ROW_NUMBER() OVER() AS PAGEINDEX
	FROM
	(
	SELECT status.OBJECT_NO								AS objectNo
	, status.OBJECT_TYPE							AS objectType
	, FN_GET_CD_NM('productionObjectType', status.OBJECT_TYPE, #{sessionLang}) AS objectTypeNm
	, status.LAST_DEPLOY_REV_NO						AS revNo
	, objectClassCd2
	, FN_GET_CD_NM('objectClassCd2', objectClassCd2, #{sessionLang}) AS objectClassNm2
	, productCd
	,COALESCE(productCd, '')												AS productNm
	, status.USER_CD								AS acceptUserCd
	, (SELECT USER_NM FROM DOCS_USER WHERE USER_CD = status.USER_CD) AS acceptUserNm
	, applyHogiNo
	, objectNm
	, businessAreaCd
	, FN_GET_CD_NM('businessAreaCd', businessAreaCd, #{sessionLang}) AS businessAreaNm
	, deploy.ACCEPT_DT								AS acceptDt
	, deploy.DEPLOY_DT								AS deployDt
	, request.INSERT_USER_CD						AS requestUserCd
	, (SELECT USER_NM FROM DOCS_USER WHERE USER_CD = request.INSERT_USER_CD) AS requestUserNm
	, status.CURRENT_COUNT                          AS currentCount
	FROM DOCS_PRODUCT_STATUS status
	INNER JOIN
	(
	SELECT DOCUMENT_NO					AS objectNo
	, TO_CHAR(DOCUMENT_NM)			AS objectNm
	, DOC_CLASS_CD2					AS objectClassCd2
	, APPLY_PRODUCT_NO				AS productCd
	, APPLY_HOGI_NO					AS applyHogiNo
	, REV_NO						AS revNo
	, BUSINESS_AREA_CD				AS businessAreaCd
	FROM DOCS_PRODUCT_DOCUMENT
	UNION ALL
	SELECT SW_NO						AS objectNo
	, TO_CHAR(SW_NM)				AS objectNm
	, SW_CLASS_CD2					AS objectClassCd2
	, PRODUCT_NO					AS productCd
	, CAST('' AS VARCHAR(255)) 	    AS applyHogiNo
	, REV_NO						AS revNo
	, BUSINESS_AREA_CD				AS businessAreaCd
	FROM DOCS_PRODUCT_SW
	) product
	ON status.OBJECT_NO = product.objectNo
	AND status.LAST_DEPLOY_REV_NO = product.revNo
	INNER JOIN DOCS_REQUEST request
	ON status.LAST_REQUEST_NO = request.REQUEST_NO
	INNER JOIN
	(
	SELECT MAX(DEPLOY_DT) DEPLOY_DT
	, MAX(ACCEPT_DT) ACCEPT_DT
	, DEPLOY_USER_CD
	FROM DOCS_REQUEST_DEPLOY
	WHERE ACCEPT_YN = 'Y'
	GROUP BY DEPLOY_USER_CD
	)  deploy
	ON status.USER_CD = deploy.DEPLOY_USER_CD
	AND deploy.DEPLOY_USER_CD = #{sessionUser.userCd}
	AND status.USER_CD = #{sessionUser.userCd}
	WHERE 1=1
	AND status.DISPOSAL_REQUEST_YN = 'N'
	AND status.CURRENT_COUNT != 0
	<if test='objectNo != null and !objectNo.equals("")'>
		AND objectNo LIKE '%' || UPPER(TRIM(#{objectNo})) || '%'
	</if>
	<if test='objectType != null and !objectType.equals("")'>
		AND status.OBJECT_TYPE = #{objectType}
	</if>
	<if test='objectClassCd2 != null and !objectClassCd2.equals("")'>
		AND objectClassCd2 = #{objectClassCd2}
	</if>
	<if test='requestUserCd != null and !requestUserCd.equals("")'>
		AND request.INSERT_USER_CD = #{requestUserCd}
	</if>
	<if test='deployStartDt != null and !deployStartDt.equals("")'>
		AND deploy.DEPLOY_DT BETWEEN TO_DATE(#{deployStartDt}, 'YYYY-MM-DD')
		AND TO_DATE(#{deployEndDt}, 'YYYY-MM-DD') + INTERVAL '1 DAY'
	</if>
	<if test='sortColumn == null or "".equals(sortColumn)'>
		ORDER BY ACCEPT_DT desc
	</if>
	<if test='sortColumn != null and !"".equals(sortColumn)'>
		ORDER BY ${sortColumn} ${order}
	</if>
	) A1
	) B1
	<if test='start != null and !start.equals("")'>
		WHERE PAGEINDEX >= #{start}
	</if>
</select>

<select id="selectListCount" resultType="Integer">
	SELECT COUNT(objectNo) AS TOTAL_COUNT
	FROM
	(
	SELECT status.OBJECT_NO								AS objectNo
	, status.OBJECT_TYPE							AS objectType
	, FN_GET_CD_NM('productionObjectType', status.OBJECT_TYPE, #{sessionLang}) AS objectTypeNm
	, status.LAST_DEPLOY_REV_NO						AS revNo
	, objectClassCd2
	, FN_GET_CD_NM('objectClassCd2', objectClassCd2, #{sessionLang}) AS objectClassNm2
	, productCd
	,COALESCE(productCd, '')												AS productNm
	, status.USER_CD								AS acceptUserCd
	, (SELECT USER_NM FROM DOCS_USER WHERE USER_CD = status.USER_CD) AS acceptUserNm
	, applyHogiNo
	, objectNm
	, businessAreaCd
	, FN_GET_CD_NM('businessAreaCd', businessAreaCd, #{sessionLang}) AS businessAreaNm
	, deploy.ACCEPT_DT								AS acceptDt
	, deploy.DEPLOY_DT								AS deployDt
	, request.INSERT_USER_CD						AS requestUserCd
	, (SELECT USER_NM FROM DOCS_USER WHERE USER_CD = request.INSERT_USER_CD) AS requestUserNm
	, status.CURRENT_COUNT                          AS currentCount
	FROM DOCS_PRODUCT_STATUS status
	INNER JOIN
	(
	SELECT DOCUMENT_NO					AS objectNo
	, TO_CHAR(DOCUMENT_NM)			AS objectNm
	, DOC_CLASS_CD2					AS objectClassCd2
	, APPLY_PRODUCT_NO				AS productCd
	, APPLY_HOGI_NO					AS applyHogiNo
	, REV_NO						AS revNo
	, BUSINESS_AREA_CD				AS businessAreaCd
	FROM DOCS_PRODUCT_DOCUMENT
	UNION ALL
	SELECT SW_NO						AS objectNo
	, TO_CHAR(SW_NM)				AS objectNm
	, SW_CLASS_CD2					AS objectClassCd2
	, PRODUCT_NO					AS productCd
	, CAST('' AS VARCHAR(255)) 	    AS applyHogiNo
	, REV_NO						AS revNo
	, BUSINESS_AREA_CD				AS businessAreaCd
	FROM DOCS_PRODUCT_SW
	) product
	ON status.OBJECT_NO = product.objectNo
	AND status.LAST_DEPLOY_REV_NO = product.revNo
	INNER JOIN DOCS_REQUEST request
	ON status.LAST_REQUEST_NO = request.REQUEST_NO
	INNER JOIN
	(
	SELECT MAX(DEPLOY_DT) DEPLOY_DT
	, MAX(ACCEPT_DT) ACCEPT_DT
	, DEPLOY_USER_CD
	FROM DOCS_REQUEST_DEPLOY
	WHERE ACCEPT_YN = 'Y'
	GROUP BY DEPLOY_USER_CD
	)  deploy
	ON status.USER_CD = deploy.DEPLOY_USER_CD
	AND deploy.DEPLOY_USER_CD = #{sessionUser.userCd}
	AND status.USER_CD = #{sessionUser.userCd}
	WHERE 1=1
	AND status.DISPOSAL_REQUEST_YN = 'N'
	AND status.CURRENT_COUNT != 0
	<if test='objectNo != null and !objectNo.equals("")'>
		AND objectNo LIKE '%' || UPPER(TRIM(#{objectNo})) || '%'
	</if>
	<if test='objectType != null and !objectType.equals("")'>
		AND status.OBJECT_TYPE = #{objectType}
	</if>
	<if test='objectClassCd2 != null and !objectClassCd2.equals("")'>
		AND objectClassCd2 = #{objectClassCd2}
	</if>
	<if test='requestUserCd != null and !requestUserCd.equals("")'>
		AND request.INSERT_USER_CD = #{requestUserCd}
	</if>
	<if test='deployStartDt != null and !deployStartDt.equals("")'>
		AND deploy.DEPLOY_DT BETWEEN TO_DATE(#{deployStartDt}, 'YYYY-MM-DD')
		AND TO_DATE(#{deployEndDt}, 'YYYY-MM-DD') + INTERVAL '1 DAY'
	</if>
	<if test='sortColumn == null or "".equals(sortColumn)'>
		ORDER BY ACCEPT_DT desc
	</if>
	<if test='sortColumn != null and !"".equals(sortColumn)'>
		ORDER BY ${sortColumn} ${order}
	</if>
	) A1
</select>

<!-- 생산기술자료 폐기 요청 추가 [2019.10.23(최금영)] -->
<insert id="inserDestoryRequest" parameterType="kr.esob.fdms.controller.inside.production.disposal.DisposalRequestPopupParam">
	<selectKey keyProperty="destroyRequestNo" resultType="String" order="BEFORE">
		SELECT TO_CHAR(CURRENT_DATE,'YYYYMMDD')||'-X'||LPAD(COALESCE(SUBSTR(MAX(DESTROY_REQUEST_NO),11)::INTEGER,0)+1,4,'0') AS DESTROY_REQUEST_NO
		FROM DOCS_DESTROY_REQUEST
		WHERE SUBSTR(DESTROY_REQUEST_NO,1,10) = TO_CHAR(CURRENT_DATE,'YYYYMMDD')||'-X'
	</selectKey>
	/* 생산기술자료 폐기 요청 추가 */
	INSERT INTO DOCS_DESTROY_REQUEST
	( DESTROY_REQUEST_NO
	, APPROVAL_LINE_ID
	, CURRENT_PROCESS_SEQ_NO
	, STATUS_CD
	, INSERT_USER_CD
	, INSERT_DT
	, APPROVAL_DT
	, DESTROY_TYPE
	, DESTROY_STATUS_CD
	, BUSINESS_AREA_CD
	, REQUEST_TYPE
	)
	VALUES
	( #{destroyRequestNo}
	, '3'
	, '2'
	, 'REQUEST'
	, #{sessionUser.userCd}
	, CURRENT_DATE
	, CURRENT_DATE
	, '5'									/* 생산기술자료 폐기 */
	, '1'									/* 폐기중 */
	, #{businessAreaCd}
	, 'PRODUCT'
	)
</insert>

