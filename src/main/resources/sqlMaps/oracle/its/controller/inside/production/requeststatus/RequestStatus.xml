	B1.*
	FROM
	(
	SELECT
	requestNo
	, deployTypeCd
	, deployTypeNm
	, TO_CHAR(TO_DATE(deployDt, 'YYYYMMDD'), 'YYYY-MM-DD') AS deployDt
	, approvalUserNm
	, approvalUserCd
	, TO_CHAR(requestDt, 'YYYY-MM-DD') AS requestDt
	, TO_CHAR(approvalDt, 'YYYY-MM-DD') AS approvalDt
	, businessAreaCd
	, businessAreaNm
	, objectType
	, objectTypeNm
	, statusCd
	, statusNm
	, requestType
	, requestTypeNm
	, requestUserNm
	, ROW_NUMBER() OVER () AS PAGEINDEX
	FROM
	(
	SELECT
	request.REQUEST_NO AS requestNo
	, REQUEST_PURPOSE AS deployTypeCd
	, FN_GET_CD_NM('deployType', REQUEST_PURPOSE, #{sessionLang}) AS deployTypeNm
	, USE_START_YMD AS deployDt
	, (
	SELECT USER_NM
	FROM DOCS_USER tmp
	WHERE tmp.USER_CD = appDetail.ACTUAL_USER_CD
	) AS approvalUserNm
	, appDetail.ACTUAL_USER_CD AS approvalUserCd
	, request.INSERT_DT AS requestDt
	, request.APPROVAL_DT AS approvalDt
	, request.BUSINESS_AREA_CD AS businessAreaCd
	, FN_GET_CD_NM('businessAreaCd', request.BUSINESS_AREA_CD, #{sessionLang}) AS businessAreaNm
	, request.OBJECT_TYPE AS objectType
	, FN_GET_CD_NM('objectType', request.OBJECT_TYPE, #{sessionLang}) AS objectTypeNm
	, request.STATUS_CD AS statusCd
	, (SELECT USER_NM FROM DOCS_USER t WHERE t.USER_CD = request.INSERT_USER_CD) AS requestUserNm
	, FN_GET_CD_NM('requestStatusCd', request.STATUS_CD, #{sessionLang}) AS statusNm
	, CASE request.REQUEST_PURPOSE
	WHEN 'NEW' THEN 'DISTRIBUTION'
	WHEN 'REPLACE' THEN 'DISTRIBUTION'
	ELSE 'PRINT'
	END AS requestType
	, CASE request.REQUEST_PURPOSE
	WHEN 'NEW' THEN (SELECT LANG_DESC FROM DOCS_LANG t WHERE t.LANG_CD='btn.distributionRequest' AND LANG_TYPE=#{sessionLang})
	WHEN 'REPLACE' THEN (SELECT LANG_DESC FROM DOCS_LANG t WHERE t.LANG_CD='btn.distributionRequest' AND LANG_TYPE=#{sessionLang})
	ELSE (SELECT LANG_DESC FROM DOCS_LANG t WHERE t.LANG_CD='label.print' AND LANG_TYPE=#{sessionLang})
	END AS requestTypeNm
	FROM DOCS_REQUEST request
	INNER JOIN DOCS_REQUEST_DETAIL reqDetail ON reqDetail.REQUEST_NO = request.REQUEST_NO AND reqDetail.APPROVAL_STATUS_CD = 'REQUEST'
	INNER JOIN DOCS_REQUEST_DETAIL appDetail ON appDetail.REQUEST_NO = request.REQUEST_NO AND appDetail.APPROVAL_STATUS_CD = 'APPROVAL'
	INNER JOIN DOCS_REQUEST_DETAIL currDetail ON currDetail.REQUEST_NO = request.REQUEST_NO AND currDetail.PROCESS_SEQ = request.CURRENT_PROCESS_SEQ_NO
	WHERE REQUEST_TYPE = 'PRODUCT'
	<if test='requestUserCd != null and !requestUserCd.equals("")'>
		AND request.INSERT_USER_CD = #{requestUserCd}
	</if>
	<if test='requestStartDt != null and !requestStartDt.equals("")'>
		AND request.INSERT_DT BETWEEN TO_DATE(#{requestStartDt}, 'YYYY-MM-DD')
		AND TO_DATE(#{requestEndDt}, 'YYYY-MM-DD') + INTERVAL '1 day'
	</if>
	<if test='sortColumn == null or "".equals(sortColumn)'>
		ORDER BY requestDt desc
	</if>
	<if test='sortColumn != null and !"".equals(sortColumn)'>
		ORDER BY ${sortColumn} ${order}
	</if>
	) A1
	WHERE 1=1
	<if test='requestNo != null and !requestNo.equals("")'>
		AND requestNo = #{requestNo}
	</if>
	<if test='approvalUserCd != null and !approvalUserCd.equals("")'>
		AND approvalUserCd = #{approvalUserCd}
	</if>
	<if test='deployTypeCd != null and !deployTypeCd.equals("")'>
		AND deployTypeCd = #{deployTypeCd}
	</if>
	<if test='statusCd != null and !statusCd.equals("")'>
		AND statusCd = #{statusCd}
	</if>
	<if test='objectType != null and !objectType.equals("")'>
		AND objectType = #{objectType}
	</if>
	<if test='end != null and !end.equals("")'>
		AND ROW_NUMBER() OVER () <![CDATA[ <= ]]> #{end}
	</if>
	) B1
	<if test='start != null and !start.equals("")'>
		WHERE PAGEINDEX >= #{start}
	</if>
</select>

<select id="selectListCount" resultType="Integer">
	SELECT
	COUNT(*) AS TOTAL_COUNT
	FROM
	(
	SELECT
	A1.*
	, ROW_NUMBER() OVER () AS PAGEINDEX
	FROM
	(
	SELECT
	request.REQUEST_NO AS requestNo
	, REQUEST_PURPOSE AS deployTypeCd
	, CASE
	WHEN USE_START_YMD IS NULL THEN NULL
	ELSE SUBSTRING(USE_START_YMD, 0, 4) || '-' || SUBSTRING(USE_START_YMD, 5, 2) || '-' || SUBSTRING(USE_START_YMD, 7, 2)
	END AS useStartYmd
	, (
	SELECT USER_NM
	FROM DOCS_USER tmp
	WHERE tmp.USER_CD = appDetail.ACTUAL_USER_CD
	) AS approvalUserNm
	, appDetail.ACTUAL_USER_CD AS approvalUserCd
	, TO_CHAR(request.INSERT_DT, 'YYYY-MM-DD') AS requestDt
	, TO_CHAR(request.APPROVAL_DT, 'YYYY-MM-DD') AS approvalDt
	, request.BUSINESS_AREA_CD AS businessAreaCd
	, request.OBJECT_TYPE AS objectType
	, request.STATUS_CD AS statusCd
	, CASE request.REQUEST_PURPOSE
	WHEN 'NEW' THEN 'DISTRIBUTION'
	WHEN 'REPLACE' THEN 'DISTRIBUTION'
	ELSE 'PRINT'
	END AS requestType
	, CASE request.REQUEST_PURPOSE
	WHEN 'NEW' THEN (SELECT LANG_DESC FROM DOCS_LANG t WHERE t.LANG_CD='btn.distributionRequest' AND LANG_TYPE=#{sessionLang})
	WHEN 'REPLACE' THEN (SELECT LANG_DESC FROM DOCS_LANG t WHERE t.LANG_CD='btn.distributionRequest' AND LANG_TYPE=#{sessionLang})
	ELSE (SELECT LANG_DESC FROM DOCS_LANG t WHERE t.LANG_CD='label.print' AND LANG_TYPE=#{sessionLang})
	END AS requestTypeNm
	FROM DOCS_REQUEST request
	INNER JOIN DOCS_REQUEST_DETAIL reqDetail ON reqDetail.REQUEST_NO = request.REQUEST_NO AND reqDetail.APPROVAL_STATUS_CD = 'REQUEST'
	INNER JOIN DOCS_REQUEST_DETAIL appDetail ON appDetail.REQUEST_NO = request.REQUEST_NO AND appDetail.APPROVAL_STATUS_CD = 'APPROVAL'
	INNER JOIN DOCS_REQUEST_DETAIL currDetail ON currDetail.REQUEST_NO = request.REQUEST_NO AND currDetail.PROCESS_SEQ = request.CURRENT_PROCESS_SEQ_NO
	WHERE REQUEST_TYPE = 'PRODUCT'
	<if test='requestUserCd != null and !requestUserCd.equals("")'>
		AND request.INSERT_USER_CD = #{requestUserCd}
	</if>
	<if test='requestStartDt != null and !requestStartDt.equals("")'>
		AND request.INSERT_DT BETWEEN TO_DATE(#{requestStartDt}, 'YYYY-MM-DD')
		AND TO_DATE(#{requestEndDt}, 'YYYY-MM-DD') + INTERVAL '1 day'
	</if>
	) A1
	WHERE 1=1
	<if test='requestNo != null and !requestNo.equals("")'>
		AND requestNo = #{requestNo}
	</if>
	<if test='approvalUserCd != null and !approvalUserCd.equals("")'>
		AND approvalUserCd = #{approvalUserCd}
	</if>
	<if test='deployTypeCd != null and !deployTypeCd.equals("")'>
		AND deployTypeCd = #{deployTypeCd}
	</if>
	<if test='statusCd != null and !statusCd.equals("")'>
		AND statusCd = #{statusCd}
	</if>
	<if test='objectType != null and !objectType.equals("")'>
		AND objectType = #{objectType}
	</if>
	) B1
</select>

<select id="getRequestInfo" parameterType="kr.esob.fdms.controller.inside.production.requeststatus.RequestStatusPopupParam" resultType="kr.esob.fdms.controller.inside.production.requeststatus.RequestStatusPopupVO">
	SELECT req.REQUEST_NO AS requestNo
		 , ( SELECT USER_NM
			 FROM DOCS_USER
			 WHERE USER_CD = req.INSERT_USER_CD) AS userNm
		 , ( SELECT USER_NM
			 FROM DOCS_USER
			 WHERE USER_CD = appDtl.ACTUAL_USER_CD) AS approvalUserNm
		 , TO_CHAR(TO_DATE(req.USE_START_YMD, 'YYMMDD'), 'YYYY-MM-DD') AS deployDate
		 , TO_CHAR(TO_DATE(req.USE_END_YMD, 'YYMMDD'), 'YYYY-MM-DD') AS deployTerm
		 , FN_GET_CD_NM('deployType', req.REQUEST_PURPOSE, #{sessionLang}) AS deployType
		 , req.WATERMARK_YN AS watermarkYn
		 , reqDtl.REQUEST_DESC AS requestReason
		 , appDtl.REQUEST_DESC AS rejectReason
		 , FN_GET_CD_NM('requestStatusCd', req.STATUS_CD, #{sessionLang}) AS statusNm
		 , appDtl.ACTION_CD AS actionCd
	FROM DOCS_REQUEST req
			 JOIN DOCS_REQUEST_DETAIL appDtl
				  ON req.REQUEST_NO = appDtl.REQUEST_NO AND appDtl.APPROVAL_STATUS_CD = 'APPROVAL'
			 JOIN DOCS_REQUEST_DETAIL reqDtl
				  ON req.REQUEST_NO = reqDtl.REQUEST_NO AND reqDtl.APPROVAL_STATUS_CD = 'REQUEST'
	WHERE req.REQUEST_NO = #{requestNo}
</select>

<select id="selectAcceptanceUserList"  parameterType="kr.esob.fdms.controller.inside.production.requeststatus.RequestStatusPopupParam" resultType="kr.esob.fdms.controller.inside.production.requeststatus.RequestStatusPopupVO">
	SELECT dept.DEPT_NM AS deptNm
	, userInfo.USER_NM AS acceptUserNm
	, depInfo.COPY AS copy
	, depInfo.DEPLOY_COUNT * depInfo.COPY AS totalCount
	FROM DOCS_REQUEST_DEPLOY reqDep
	INNER JOIN
	(
	SELECT REQUEST_NO
	, MAX(OBJECT_ID) OBJECT_ID
	, DEPLOY_USER_CD
	, COPY
	, SUM(DEPLOY_COUNT) DEPLOY_COUNT
	FROM DOCS_DEPLOY_INFO
	GROUP BY REQUEST_NO, DEPLOY_USER_CD, COPY
	) depInfo
	ON reqDep.REQUEST_NO = depInfo.REQUEST_NO AND reqDep.DEPLOY_USER_CD = depInfo.DEPLOY_USER_CD
	LEFT JOIN DOCS_REQUEST_MAPPING reqMap
	ON reqDep.REQUEST_NO = reqMap.REQUEST_NO
	AND reqMap.OBJECT_ID = depInfo.OBJECT_ID
	JOIN DOCS_USER userInfo
	ON reqDep.DEPLOY_USER_CD = userInfo.USER_CD
	JOIN DOCS_DEPT dept
	ON userInfo.DEPT_CD = dept.DEPT_CD
	WHERE reqDep.REQUEST_NO = #{requestNo}
	<if test='sortColumn == null or "".equals(sortColumn)'>
		ORDER BY acceptUserNm desc
	</if>
	<if test='sortColumn != null and !"".equals(sortColumn)'>
		ORDER BY ${sortColumn} ${order}
	</if>
</select>

<select id="selectAcceptanceUserListCount"  parameterType="kr.esob.fdms.controller.inside.production.requeststatus.RequestStatusPopupParam" resultType="Integer">
	SELECT COUNT(*) AS TOTAL_COUNT
	FROM DOCS_REQUEST_DEPLOY reqDep
			 JOIN DOCS_USER userInfo
				  ON reqDep.DEPLOY_USER_CD = userInfo.USER_CD
			 JOIN DOCS_DEPT dept
				  ON userInfo.DEPT_CD = dept.DEPT_CD
	WHERE reqDep.REQUEST_NO = #{requestNo}
</select>

<select id="selectProductionList"  parameterType="kr.esob.fdms.controller.inside.production.requeststatus.RequestStatusPopupParam" resultType="kr.esob.fdms.controller.inside.production.requeststatus.RequestStatusPopupVO">
	SELECT mapping.OBJECT_NO
	, mapping.OBJECT_NM
	, mapping.OBJECT_CLASS_NM2
	, mapping.REV_NO
	, mapping.REQUEST_NO
	, mapping.OBJECT_ID
	<if test="'SW'.equals(objectType)">
		, (SELECT COUNT(*) FROM DOCS_PRODUCT_SW_FILE WHERE OBJECT_ID = mapping.OBJECT_ID ) AS itemCount
	</if>
	<if test="'DOC'.equals(objectType)">
		, product.TOTAL_PAGE_CNT AS itemCount
	</if>
	, depInfo.DEPLOY_COUNT
	, depInfo.DESTROY_COUNT
	, mapping.PRODUCT_CD
	, #{objectType} AS objectTypeData
	, COALESCE(mapping.PRODUCT_CD, '') AS productNm
	FROM DOCS_REQUEST_MAPPING mapping
	INNER JOIN
	(
	SELECT REQUEST_NO
	, OBJECT_ID
	, DEPLOY_COUNT
	, DESTROY_COUNT
	FROM DOCS_DEPLOY_INFO
	GROUP BY REQUEST_NO, OBJECT_ID, DEPLOY_COUNT, DESTROY_COUNT
	) depInfo
	ON mapping.REQUEST_NO = depInfo.REQUEST_NO
	AND mapping.OBJECT_ID = depInfo.OBJECT_ID
	<if test="'DOC'.equals(objectType)">
		INNER JOIN DOCS_PRODUCT_DOCUMENT product
	</if>
	<if test="'SW'.equals(objectType)">
		INNER JOIN DOCS_PRODUCT_SW product
	</if>
	ON product.OBJECT_ID = mapping.OBJECT_ID
	WHERE mapping.REQUEST_NO = #{requestNo}
	ORDER BY OBJECT_NM DESC
</select>

<update id="updateRequestInfo" parameterType="kr.esob.fdms.controller.inside.production.requeststatus.RequestStatusPopupParam">
	UPDATE DOCS_REQUEST
	SET STATUS_CD = #{statusCd}
	<if test='"APPROVAL".equals(statusCd)'>
		, APPROVAL_DT = CURRENT_TIMESTAMP
	</if>
	WHERE REQUEST_NO = #{requestNo}
</update>

<update id="updateRequestDetail" parameterType="kr.esob.fdms.controller.inside.production.requeststatus.RequestStatusPopupParam">
	UPDATE DOCS_REQUEST_DETAIL
	SET REQUEST_DESC = #{rejectDesc}
	  , ACTION_CD = #{actionCd}
	  , ACTION_DT = CURRENT_TIMESTAMP
	WHERE REQUEST_NO = #{requestNo}
	  AND APPROVAL_STATUS_CD = 'APPROVAL'
	  AND APPROVAL_GRADE_CD = 'TL'
</update>

<select id="getPrintRequestInfo" resultType="kr.esob.fdms.controller.inside.production.requeststatus.PrintRequestStatusVO">
	SELECT reqDtl.REQUEST_DESC AS requestDesc
		 , reject.REQUEST_DESC AS rejectDesc
		 , req.REQUEST_NO AS requestNo
		 , req.OBJECT_TYPE AS objectType
		 , appDtl.ACTION_CD AS actionCd
	FROM DOCS_REQUEST req
			 JOIN DOCS_REQUEST_DETAIL reqDtl
				  ON req.REQUEST_NO = reqDtl.REQUEST_NO AND reqDtl.APPROVAL_STATUS_CD = 'REQUEST'
			 LEFT JOIN DOCS_REQUEST_DETAIL reject
					   ON req.REQUEST_NO = reject.REQUEST_NO AND reject.APPROVAL_STATUS_CD = 'REJECT'
			 LEFT JOIN DOCS_REQUEST_DETAIL appDtl
					   ON req.REQUEST_NO = appDtl.REQUEST_NO AND appDtl.APPROVAL_STATUS_CD = 'APPROVAL'
	WHERE req.REQUEST_NO = #{requestNo}
</select>

<select id="selectPrintRequestList" parameterType="kr.esob.fdms.controller.inside.production.requeststatus.RequestStatusPopupParam" resultType="kr.esob.fdms.controller.inside.production.requeststatus.PrintRequestStatusVO">
	SELECT fileInfo.REV_NO AS rev
	, fileInfo.INSERT_UID AS insertUid
	, fileInfo.INSERT_DT AS insertDt
	, fileInfo.UPDATE_DT AS updateDt
	, fileInfo.SECURITY_TYPE_CD AS securityTypeCd
	, reqMap.OBJECT_NO AS objectNo
	, reqMap.OBJECT_NM AS objectNm
	, reqMap.OBJECT_CLASS_CD2 AS objectType
	, reqMap.TOTAL_PAGE_NO AS totalCount
	, reqMap.APPLY_HOGI_NO AS applyProductNo
	, req.OBJECT_TYPE AS objectTypeData
	<if test="'DOC'.equals(objectType)">
		, fileInfo.CALL_ID AS callId
	</if>
	<if test="'SW'.equals(objectType)">
		, fileInfo.PRODUCT_NO AS productNo
	</if>
	, reqMap.OBJECT_ID AS objectId
	, req.REQUEST_NO AS requestNo
	, req.INSERT_USER_CD AS requestUserCd
	FROM DOCS_REQUEST_MAPPING reqMap
	JOIN DOCS_REQUEST req
	ON reqMap.REQUEST_NO = req.REQUEST_NO
	<if test="'DOC'.equals(objectType)">
		JOIN DOCS_PRODUCT_DOCUMENT fileInfo
	</if>
	<if test="'SW'.equals(objectType)">
		JOIN DOCS_PRODUCT_SW fileInfo
	</if>
	ON reqMap.OBJECT_ID = fileInfo.OBJECT_ID
	WHERE reqMap.REQUEST_NO = #{requestNo}
</select>

</mapper>

