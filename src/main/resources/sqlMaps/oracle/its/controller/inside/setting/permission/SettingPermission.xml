<mapper namespace="sql.SettingPermission">

<select id="getMenuCombo" resultType="kr.esob.fdms.commonlogic.tree.TreeVO" parameterType="String">
	WITH RECURSIVE PARENT AS (
            SELECT MENU_CD,
                   PARENT_MENU_CD,
                   MENU_NM AS MENU_NM,
                   MENU_URL AS MENU_URL,
                   1 AS MENU_LEVEL,
                   MENU_TYPE,
                   MENU_CD AS MAIN_CODE
            FROM DOCS_MENU
            WHERE PARENT_MENU_CD IN (#{pageType}, 'B')
				   UNION ALL
				   SELECT MENU.MENU_CD,
					   MENU.PARENT_MENU_CD,
					   MENU.MENU_NM AS MENU_NM,
					   MENU.MENU_URL,
					   PARENT.MENU_LEVEL + 1 AS MENU_LEVEL,
					   MENU.MENU_TYPE,
					   PARENT.MAIN_CODE AS MAIN_CODE
				   FROM DOCS_MENU MENU
					   JOIN PARENT ON MENU.PARENT_MENU_CD = PARENT.MENU_CD
					   )
				   SELECT MENU_CD AS id,
					   CASE WHEN A.MENU_LEVEL = 1 THEN '#' ELSE COALESCE(A.PARENT_MENU_CD, '#') END AS parent,
					   TREE_TYPE AS type,
					   COALESCE((SELECT LANG_DESC FROM DOCS_LANG WHERE LANG_CODE = A.MESSAGE_CD AND LANG_TYPE = #{sessionLang}), A.MENU_NM) AS text
				   FROM PARENT A
				   WHERE MENU_NM LIKE '%' || UPPER(#{value}) || '%'
				   ORDER BY MAIN_CODE, MENU_CD
</select>

</mapper>




