<insert id="insertRequest" parameterType="kr.esob.fdms.controller.inside.unregisted.request.DistributionRequestPopupParam">
	<selectKey keyProperty="requestNo" resultType="String" order="BEFORE">
		SELECT TO_CHAR(CURRENT_TIMESTAMP, 'YYYYMMDD') || '-N' || LPAD(NVL(SUBSTR(MAX(request_no), 11), 0) + 1, 4, '0') AS requestNo
		FROM DOCS_REQUEST
		WHERE SUBSTR(request_no, 1, 10) = TO_CHAR(CURRENT_TIMESTAMP, 'YYYYMMDD') || '-N'
	</selectKey>
	INSERT INTO DOCS_REQUEST
	(REQUEST_NO, REQUEST_TYPE, REQUEST_PURPOSE, APPROVAL_LINE_ID, CURRENT_PROCESS_SEQ_NO, DEPLOY_TERM, USE_START_YMD, USE_END_YMD, PRINT_YN, DEPLOY_NORMAL_YN, DEPLOY_SPECIAL_YN, INSERT_USER_CD, INSERT_DT, UPDATE_USER_CD, UPDATE_DT, STATUS_CD, OBJECT_TYPE, DEPLOY_COMPANY_CD, PROTECT_YN, BUSINESS_AREA_CD)
	VALUES
	(#{requestNo}, 'NO-REG', #{requestPurpose}, #{approvalLineId}, #{currentProcessSeqNo}, #{deployTerm}, #{useStartYmd}, #{useEndYmd}, #{printYn}, #{deployNormalYn}, #{deploySpecialYn}, #{sessionUser.userCd}, CURRENT_TIMESTAMP, #{sessionUser.userCd}, CURRENT_TIMESTAMP, 'REQUEST', #{objectType}, #{companyCd}, 'N', #{businessAreaCd})
</insert>

<insert id="insertRequestDeploy" parameterType="kr.esob.fdms.controller.inside.unregisted.request.DistributionRequestPopupParam">
	INSERT INTO DOCS_REQUEST_DEPLOY
		(REQUEST_NO, DEPLOY_USER_CD, DEPLOY_USER_EMAIL, DEPLOY_EMAIL_CC)
	VALUES
		(#{requestNo}, #{companyUserCd}, #{deployUserEmail}, #{securityEmailCC})
</insert>

