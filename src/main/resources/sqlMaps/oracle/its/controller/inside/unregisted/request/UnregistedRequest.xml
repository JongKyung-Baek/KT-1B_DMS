<insert id="insertDocsRequestDetail" parameterType="kr.esob.fdms.controller.inside.unregisted.request.DistributionRequestPopupParam">
	INSERT INTO DOCS_REQUEST_DETAIL
	(REQUEST_NO, PROCESS_SEQ, APPROVAL_STATUS_CD, APPROVAL_GRADE_CD, ORIGINAL_USER_CD, ACTUAL_USER_CD
	<if test='"REQUEST".equals(approvalStatusCd)'>, REQUEST_DESC</if>
	<if test='!"APPROVAL".equals(approvalStatusCd)'>, ACTION_DT, ACTION_CD</if>
	)
	VALUES
	(#{requestNo}, #{processSeq}, #{approvalStatusCd}, #{approvalGradeCd}
