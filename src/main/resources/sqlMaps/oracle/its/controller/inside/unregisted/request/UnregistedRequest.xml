	<if test='"ACCEPT".equals(approvalStatusCd)'>, #{purchaseTeam}, #{sessionUser.userCd}</if>
	<if test='"TL".equals(approvalGradeCd)'>, (SELECT TEAM_LEADER_USER_CD FROM DOCS_DEPT WHERE DEPT_CD = #{sessionUser.deptCd}), #{teamLeader}</if>
	<if test='"REQUEST".equals(approvalStatusCd)'>, #{requestDesc}</if>
	<if test='!"APPROVAL".equals(approvalStatusCd)'>, CURRENT_TIMESTAMP,
		<if test='"REQUEST".equals(approvalStatusCd)'> 'REQUEST'</if>
		<if test='"ACCEPT".equals(approvalStatusCd)'> 'ACCEPT'</if>
	</if>
	)
</insert>

