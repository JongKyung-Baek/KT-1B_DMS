</insert>

<insert id="insertUnregisterFileX" parameterType="kr.esob.fdms.controller.inside.unregisted.request.UnregisterPopupParam">
	<selectKey keyProperty="fileNo" resultType="String" order="BEFORE">
		SELECT COALESCE(MAX(CAST(file_no AS INTEGER)), 0) + 1 AS fileNo
