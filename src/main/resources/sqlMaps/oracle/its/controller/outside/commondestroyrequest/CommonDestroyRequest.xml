<update id="updateRequestFileDestroy">
	UPDATE DOCS_REQUEST_FILE
	SET DESTROY_STATUS_CD = '2'
	WHERE REQUEST_NO = #{requestNo}
	  AND OBJECT_ID = #{objectId}
	  AND FILE_NO::integer = #{fileNo}
</update>

	<update id="updateApprovalFile">
		UPDATE DOCS_APPROVAL_FILE
		SET DESTROY_NO = CAST(#{destroyNo} AS INTEGER),
			DESTROY_TYPE = #{destroyType},
			DESTROY_STATUS_CD = '2',
			LAST_DESTROY_REQUEST_NO = #{destroyRequestNo}
		WHERE REQUEST_NO = #{requestNo}
		  AND OBJECT_ID = #{objectId}
		  AND FILE_NO::integer = #{fileNo}
	</update>

<update id="updateUnderDestroy">
	UPDATE DOCS_REQUEST_FILE
	SET DESTROY_TYPE = '5'
	  , DESTROY_STATUS_CD = '1'
	WHERE REQUEST_NO = #{requestNo}
	  AND OBJECT_ID = #{objectId}
	  AND FILE_NO = #{fileNo}
</update>

</mapper>
