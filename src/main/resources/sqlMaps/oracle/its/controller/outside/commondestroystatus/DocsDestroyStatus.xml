<mapper namespace="sql.DocsDestroyStatus">
<select id="selectDestroyStatus" resultType="kr.esob.fdms.controller.outside.commondestroystatus.DestroyStatusInfoVO">
	SELECT
		destroyRequest.DESTROY_TYPE,
		requestDetail.REQUEST_DESC,
		destroyRequest.DESTROY_NO
	FROM DOCS_DESTROY_REQUEST destroyRequest
			 INNER JOIN DOCS_DESTROY_REQUEST_DETAIL requestDetail
						ON destroyRequest.DESTROY_REQUEST_NO = requestDetail.DESTROY_REQUEST_NO
	WHERE destroyRequest.DESTROY_REQUEST_NO = #{lastDestroyRequestNo}
	  AND requestDetail.APPROVAL_STATUS_CD = 'REQUEST'
</select>

<select id="selectDestroyFileList" resultType="kr.esob.fdms.controller.outside.commondestroystatus.DestroyFileVO">
	SELECT
		DESTROY_NO,
		DESTROY_FILE_SEQ,
		SUBSTRING(FILE_PATH FROM '.*/([^/]*)$') AS fileName
	FROM DOCS_DESTROY_FILE
	WHERE DESTROY_NO = #{destroyNo}
</select>

<select id="selectFilePath" resultType="kr.esob.fdms.controller.outside.commondestroystatus.DestroyFileVO">
	SELECT *
	FROM DOCS_DESTROY_FILE
	WHERE DESTROY_NO = #{destroyNo}
	  AND DESTROY_FILE_SEQ = #{destroyFileSeq}
</select>
</mapper>
