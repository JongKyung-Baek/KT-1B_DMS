<select id="getDrawingInfo" resultType="kr.esob.fdms.controller.outside.drawing.request.DrawingInfoVO">
	SELECT item.WERKS AS businessAreaCd
		 , item.MATNR AS materialsCd
		 , item.C0003 AS drawingNo
		 , item.C0001 AS productCd
		 , item.CN_PDM_PART_NO AS partNo
		 , (SELECT draw.DRAWING_NM
			FROM DOCS_DRAWING draw
			WHERE draw.DRAWING_NO = item.C0003
			  AND draw.DRAWING_REV = item.C0004
				LIMIT 1
	) AS drawingNm
		 , item.C0008_1 || item.C0008_2 || item.C0008_3 AS partNm
		 , item.C0037 AS insertDt
		 , item.C0004 AS revNo
		 , item.C0006 AS stdPartNo
	FROM DOCS_ITEM item
	WHERE item.WERKS = #{businessAreaCd}
	  AND item.CN_PDM_PART_NO = #{partNo}
	  AND item.CN_PART_REV  = ( SELECT MAX(CN_PART_REV)
								FROM DOCS_ITEM
								WHERE WERKS = #{businessAreaCd}
								  AND CN_PDM_PART_NO = #{partNo}
	)
	ORDER BY C0004 DESC
		LIMIT 1
</select>

