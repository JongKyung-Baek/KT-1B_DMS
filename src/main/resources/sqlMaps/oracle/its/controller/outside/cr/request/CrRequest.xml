<mapper namespace="sql.OutsideCrRequest">
<select id="selectList" resultType="kr.esob.fdms.controller.outside.cr.request.RequestListVO">
	SELECT
	B1.*
	FROM
	(
	SELECT
	A1.*
	, ROW_NUMBER() OVER () AS PAGEINDEX
	FROM
	(
	SELECT
	cr.CR_NO 															AS crNo				/* cr번호 */
	, cr.DRAWING_NO 													AS drawingNo		/* 도번 */
	, cr.DRAWING_NM 													AS drawingNm		/* 도명 */
	, cr.REV_NO 														AS revNo			/* rev */
	, cr.CR_TITLE_NM 													AS crTitleNm		/* 제목 */
	, purchaser.USER_CD 												AS purchaserUserCd	/* 구매담당자 */
	, purchaser.USER_NM 												AS purchaserUserNm	/* 구매담당자 */
	, req.INSERT_DT														AS requestDt 		/* 요청일 */
	, req.APPROVAL_DT 													AS approvalDt		/* 승인일 */
	, req.STATUS_CD 													AS statusCd			/* 결재상태 */
	, cr.STATUS_CD 														AS crStatusCd		/* 진행상태 */
	, FN_GET_CD_NM('crStatusCd', cr.STATUS_CD, #{sessionLang}) 			AS crStatusNm		/* 진행상태 */
	, FN_GET_CD_NM('crRequestStatusCd', req.STATUS_CD, #{sessionLang}) 	AS statusNm			/* 결재상태 */
	, requestUser.USER_CD												AS companyUserCd	/* 업체담당자 */
	, requestUser.USER_NM 												AS companyUserNm	/* 업체담당자 */
	, companyApprovalUser.USER_CD										AS companyApprovalUserCd	/* 업체결재자 */
	, companyApprovalUser.USER_NM										AS companyApprovalUserNm	/* 업체결재자 */
	, cr.CR_TYPE_CD														AS crTypeCd			/* 제의사유 */
	, FN_GET_CD_NM('crTypeCd', cr.CR_TYPE_CD, #{sessionLang}) 			AS crTypeNm
	, cr.MATERIAL_NO    												AS materialNo		/* 자재코드*/
	, cr.PART_NO      													AS partNo			/* 규격화 품번*/
	, '' 																AS "comment"			/* 검토의견 */
	, #{sessionUser.approvalYn}											AS approvalYn
	FROM DOCS_REQUEST req
	INNER JOIN DOCS_REQUEST_MAPPING mapping ON mapping.REQUEST_NO = req.REQUEST_NO AND req.OBJECT_TYPE = 'CR'
	INNER JOIN DOCS_REQUEST_DETAIL requestDetail ON requestDetail.REQUEST_NO = req.REQUEST_NO AND APPROVAL_STATUS_CD = 'WAITING'	/* WAITING이 업체결재자*/
	INNER JOIN DOCS_USER companyApprovalUser ON companyApprovalUser.USER_CD = requestDetail.ACTUAL_USER_CD
	INNER JOIN ITN_CR cr ON cr.CR_NO = mapping.OBJECT_ID
	INNER JOIN DOCS_USER purchaser ON purchaser.USER_ID = cr.PURCHASER_UID
	INNER JOIN DOCS_USER requestUser ON requestUser.USER_ID = cr.VENDOR_UID
	<!-- 					<if test='"Y".equals(sessionUser.approvalYn)'> -->
	WHERE requestUser.COMPANY_CD = #{sessionUser.companyCd}
	<!-- 					</if> -->
	<!-- 					<if test='"N".equals(sessionUser.approvalYn)'> -->
	<!-- 					WHERE requestUser.USER_CD = #{sessionUser.userCd} -->
	<!-- 					</if> -->
	<if test='requestStartDt != null and !requestStartDt.equals("")'>
		AND req.INSERT_DT BETWEEN TO_DATE(#{requestStartDt}, 'YYYY-MM-DD')
		AND TO_DATE(#{requestEndDt}, 'YYYY-MM-DD')+1
	</if>
	<if test='sortColumn == null or "".equals(sortColumn)'>
		ORDER BY requestDt desc
	</if>
	<if test='sortColumn != null and !"".equals(sortColumn)'>
		ORDER BY ${sortColumn} ${order}
	</if>
	) A1
	WHERE 1=1
	<if test='crNo != null and !crNo.equals("")'>
		AND crNo LIKE '%' || UPPER(TRIM(#{crNo})) || '%'
	</if>
	<if test='requestReason != null and !requestReason.equals("")'>
		AND requestReason = #{requestReason}
	</if>
	<if test='purchaserUserCd != null and !purchaserUserCd.equals("")'>
		AND purchaserUserCd = #{purchaserUserCd}
	</if>
	<if test='companyUserCd != null and !companyUserCd.equals("")'>
		AND companyUserCd = #{companyUserCd}
	</if>
	<if test='companyApprovalUserCd != null and !companyApprovalUserCd.equals("")'>
		AND companyApprovalUserCd = #{companyApprovalUserCd}
	</if>
	<if test='statusCd != null and !statusCd.equals("")'>
		AND statusCd = #{statusCd}
	</if>
	<if test='crStatusCd != null and !crStatusCd.equals("")'>
		AND crStatusCd = #{crStatusCd}
	</if>
	<if test='crTypeCd != null and !crTypeCd.equals("")'>
		AND crTypeCd = #{crTypeCd}
	</if>
	<if test='end != null and !end.equals("")'>
		AND ROWNUM <![CDATA[ <= ]]> #{end}
	</if>
	) B1
	<if test='start != null and !start.equals("")'>
		WHERE PAGEINDEX >= #{start}
	</if>
</select>

