<select id="selectCrNo" resultType="string">
	SELECT 'CR' || TO_CHAR(CURRENT_DATE,'YYYY')||'-'||LPAD(COALESCE(SUBSTRING(MAX(CR_NO),8)::INTEGER,0)+1,4,'0') AS CR_NO
	FROM ITN_CR
	WHERE SUBSTRING(CR_NO,3,4) = TO_CHAR(CURRENT_DATE,'YYYY')
</select>

<select id="getCrRequestInfo" parameterType="kr.esob.fdms.controller.outside.cr.request.CrRequestParam" resultType="kr.esob.fdms.controller.outside.cr.request.RequestStatusPopupVO">
	SELECT cr.CR_NO                                                   				AS crNo
		 , ( SELECT USER_NM
			 FROM DOCS_USER
			 WHERE USER_ID = cr.VENDOR_UID
				 LIMIT 1 )                                            			AS vendorUserNm      /* 업체 담당자 */
		 , ( SELECT USER_NM
			 FROM DOCS_USER
			 WHERE USER_CD = reqDtl.ACTUAL_USER_CD
				 LIMIT 1 )                                            			AS approvalUser      /* 결재자 */
		 , reqDtl.ACTUAL_USER_CD														AS approvalUserCd
		 , FN_GET_CD_NM('businessAreaCd', reqMap.BUSINESS_AREA_CD, #{sessionLang}) 	AS  businessAreaNm
		 , ( SELECT USER_NM
			 FROM DOCS_USER
			 WHERE USER_ID = cr.PURCHASER_UID
				 LIMIT 1 )                                            			AS purchaserUserNm   /* 구매담당자 */
		 , reqMap.OBJECT_NO                                              			AS drawingNo
		 , FN_GET_CD_NM('crTypeCd', cr.CR_TYPE_CD, #{sessionLang})                 	AS crTypeCd
		 , COALESCE(cr.PRODUCT_NO, '')                               			AS productNm
		 , cr.MATERIAL_NO                                                			AS materialNo
		 , reqMap.OBJECT_NM                                              			AS drawingNm
		 , reqMap.REV_NO                                                 			AS revNo
		 , cr.PART_NO                                                    			AS partNo
		 , cr.INSERT_DT                                                 				AS insertDt
		 , cr.AS_IS_DESC                                                 			AS asIsDesc
		 , cr.TO_BE_DESC                                                 			AS toBeDesc
		 , cr.CR_TITLE_NM															AS crTitleNm
		 , req.STATUS_CD																AS statusCd
		 , rejDtl.REQUEST_DESC                                                       AS rejectDesc
		 , cr.DEVICE_NM																AS deviceNm
	FROM DOCS_REQUEST_MAPPING reqMap
			 JOIN ITN_CR cr
				  ON reqMap.OBJECT_ID = cr.CR_NO
			 JOIN DOCS_REQUEST_DETAIL reqDtl
				  ON reqMap.REQUEST_NO = reqDtl.REQUEST_NO AND reqDtl.APPROVAL_STATUS_CD = 'WAITING'
			 JOIN DOCS_REQUEST req
				  ON req.REQUEST_NO =  reqMap.REQUEST_NO
			 LEFT JOIN DOCS_REQUEST_DETAIL rejDtl
					   ON reqMap.REQUEST_NO = rejDtl.REQUEST_NO AND rejDtl.ACTION_CD = 'REJECT'
	WHERE cr.CR_NO = #{crNo}
</select>

<!-- CR 외부사용자 승인 [2019.11.20(최금영)] -->
<update id="updateRequest">
	/* CR 외부사용자 승인 */
	UPDATE DOCS_REQUEST
	SET STATUS_CD = #{reqStatusCd}
	, UPDATE_DT = CURRENT_TIMESTAMP
	, UPDATE_USER_CD = #{sessionUser.userCd}
	<if test="'REQUEST'.equals(reqStatusCd)">
		, CURRENT_PROCESS_SEQ_NO = 3
	</if>
	WHERE REQUEST_NO = (SELECT REQUEST_NO FROM DOCS_REQUEST_MAPPING WHERE OBJECT_ID = #{crNo} LIMIT 1)
</update>

<!-- CR 외부사용자 승인 상세정보 수정 [2019.11.20(최금영)] -->
<update id="updateRequestDetail">
	/* CR 외부사용자 승인 상세정보 수정 */
	UPDATE DOCS_REQUEST_DETAIL
	SET ACTION_DT = CURRENT_TIMESTAMP
	  , ACTION_CD = #{actionCd}
	  , REQUEST_DESC = #{rejectDesc}
	WHERE REQUEST_NO = (SELECT REQUEST_NO FROM DOCS_REQUEST_MAPPING WHERE OBJECT_ID = #{crNo} LIMIT 1)
	  AND APPROVAL_STATUS_CD = 'WAITING'
</update>

<update id="updateCr">
	/* 외부업체 팀장 - 승인/반려 */
	UPDATE ITN_CR
	SET REJECT_REASON = #{rejectDesc}
	  , STATUS_CD = #{statusCd}
	WHERE CR_NO = #{crNo}
</update>
