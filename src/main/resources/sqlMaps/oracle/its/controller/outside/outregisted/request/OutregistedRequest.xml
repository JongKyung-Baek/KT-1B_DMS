<insert id="insertRequest" parameterType="kr.esob.fdms.controller.outside.outregisted.request.DistributionRequestPopupParam">
	<selectKey keyProperty="requestNo" resultType="String" order="BEFORE">
		/* 요청 번호 구하기 */
		SELECT TO_CHAR(CURRENT_DATE, 'YYYYMMDD')||'-T'||LPAD(COALESCE(SUBSTRING(MAX(REQUEST_NO), 11)::INTEGER, 0) + 1, 4, '0') AS REQUEST_NO
		FROM DOCS_REQUEST
		WHERE SUBSTRING(REQUEST_NO, 1, 10) = TO_CHAR(CURRENT_DATE, 'YYYYMMDD')||'-T'
	</selectKey>
	/* 배포 요청 추가 */
	INSERT INTO DOCS_REQUEST
	( REQUEST_NO
	, REQUEST_TYPE
	, REQUEST_PURPOSE
	, APPROVAL_LINE_ID
	, CURRENT_PROCESS_SEQ_NO
	, DEPLOY_TERM
	, USE_START_YMD
	, USE_END_YMD
	, PRINT_YN
	, DEPLOY_NORMAL_YN
	, DEPLOY_SPECIAL_YN
	, INSERT_USER_CD
	, INSERT_DT
	, UPDATE_USER_CD
	, UPDATE_DT
	, STATUS_CD
	, OBJECT_TYPE
	, DEPLOY_COMPANY_CD
	, PROTECT_YN
	, BUSINESS_AREA_CD
	)
	VALUES
	( #{requestNo}
	, 'OUT-REG'
	, #{requestPurpose}
	, #{approvalLineId}
	, #{currentProcessSeqNo}
	, #{deployTerm}
	, #{useStartYmd}
	, #{useEndYmd}
	, 'N'
	, 'Y'
	, 'N'
	, #{sessionUser.userCd}
	, CURRENT_DATE
	, #{sessionUser.userCd}
	, CURRENT_DATE
	, 'ACCEPT'
	, NULL
	, #{sessionUser.companyCd}
	, 'N'
	, NULL
	)
</insert>

