<mapper namespace="sql.OutregistedRequest">

<select id="selectList" resultType="kr.esob.fdms.controller.outside.outregisted.request.RequestListVO">
	SELECT
	B1.*
	FROM
	(
	SELECT
	A1.*
	, ROW_NUMBER() OVER () AS PAGEINDEX
	FROM
	(
	SELECT
	OBJECT_NO                    AS objectNo       /* 자료번호 */
	, OBJECT_TYPE                AS objectType      /* 자료유형 */
	, OBJECT_NM                  AS objectNm        /* 자료명 */
	, docsFile.FILE_NM           AS fileNm          /* 파일명 */
	, docsFile.FILE_NM           AS fileViewNm      /* 파일명 */
	, insertUser.USER_CD         AS userCd          /* 등록자 */
	, insertUser.USER_NM         AS insertUserNm    /* 등록자 */
	, TO_CHAR(unreg.INSERT_DT, 'YYYY-MM-DD') AS insertDt /* 등록일 */
	, unreg.BUSINESS_AREA_CD     AS businessAreaCd  /* 사업장 코드 */
	, docsFile.FILE_CD           AS objectId
	, docsFile.FILE_PATH         AS filePath
	, docsFile.FILE_SIZE         AS fileSize
	, docsFile.FILE_NO           AS fileNo
	FROM DOCS_OUTREG_INFO unreg
	INNER JOIN DOCS_OUTREG_FILE docsFile ON docsFile.FILE_CD = unreg.FILE_CD
	INNER JOIN DOCS_USER insertUser ON insertUser.USER_CD = unreg.INSERT_USER_CD
	<if test='sortColumn == null or "".equals(sortColumn)'>
		ORDER BY insertDt desc, objectNo desc
	</if>
	<if test='sortColumn != null and !"".equals(sortColumn)'>
		ORDER BY ${sortColumn} ${order}, objectNo ${order}
	</if>
	) A1
	WHERE userCd = #{sessionUser.userCd}
	<if test='objectNo != null and !objectNo.equals("")'>
		AND objectNo LIKE '%' || UPPER(TRIM(#{objectNo})) || '%'
	</if>
	<if test='objectType != null and !objectType.equals("")'>
		AND objectType = #{objectType}
	</if>
	<if test='objectNm != null and !objectNm.equals("")'>
		AND objectNm LIKE '%' || #{objectNm} || '%'
	</if>
	<if test='insertStartDt != null and !insertStartDt.equals("")'>
		AND insertDt BETWEEN TO_DATE(#{insertStartDt}, 'YYYY-MM-DD')
		AND TO_DATE(#{insertEndDt}, 'YYYY-MM-DD') + INTERVAL '1 day'
	</if>
	<if test='end != null and !end.equals("")'>
		AND ROW_NUMBER() OVER () <![CDATA[ <= ]]> #{end}
	</if>
	) B1
	<if test='start != null and !start.equals("")'>
		WHERE PAGEINDEX >= #{start}
	</if>
</select>

<select id="selectListCount" resultType="Integer">
	SELECT COUNT(*) AS TOTAL_COUNT
	FROM (
	SELECT
	B1.*
	FROM
	(
	SELECT
	A1.*
	FROM
	(
	SELECT
	OBJECT_NO                    AS objectNo       /* 자료번호 */
	, OBJECT_TYPE                AS objectType      /* 자료유형 */
	, OBJECT_NM                  AS objectNm        /* 자료명 */
	, docsFile.FILE_NM           AS fileNm          /* 파일명 */
	, docsFile.FILE_NM           AS fileViewNm      /* 파일명 */
	, insertUser.USER_CD         AS userCd          /* 등록자 */
	, insertUser.USER_NM         AS userNm          /* 등록자 */
	, unreg.INSERT_DT            AS insertDt        /* 등록일 */
	, docsFile.FILE_CD           AS objectId
	, docsFile.FILE_PATH         AS filePath
	, docsFile.FILE_SIZE         AS fileSize
	, docsFile.FILE_NO           AS fileNo
	FROM DOCS_OUTREG_INFO unreg
	INNER JOIN DOCS_OUTREG_FILE docsFile ON docsFile.FILE_CD = unreg.FILE_CD
	INNER JOIN DOCS_USER insertUser ON insertUser.USER_CD = unreg.INSERT_USER_CD
	) A1
	WHERE userCd = #{sessionUser.userCd}
	<if test='objectNo != null and !objectNo.equals("")'>
		AND objectNo LIKE '%' || UPPER(TRIM(#{objectNo})) || '%'
	</if>
	<if test='objectNm != null and !objectNm.equals("")'>
		AND objectNm LIKE '%' || #{objectNm} || '%'
	</if>
	<if test='objectType != null and !objectType.equals("")'>
		AND objectType = #{objectType}
	</if>
	<if test='insertStartDt != null and !insertStartDt.equals("")'>
		AND insertDt BETWEEN TO_DATE(#{insertStartDt}, 'YYYY-MM-DD')
		AND TO_DATE(#{insertEndDt}, 'YYYY-MM-DD') + INTERVAL '1 day'
	</if>
	) B1
	) C1
