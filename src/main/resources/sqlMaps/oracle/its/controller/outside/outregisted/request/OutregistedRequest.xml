<select id="getDocsApprovalLineDetail" resultType="kr.esob.fdms.controller.inside.distribution.commonrequest.ApprovalLineDetailVO">
	/* 결재 라인 상세정보 */
	SELECT APPROVAL_STATUS_CD         AS approvalStatusCd
		 , APPROVAL_GRADE_CD        AS approvalGradeCd
	FROM DOCS_APPROVAL_LINE_DETAIL
	WHERE APPROVAL_LINE_ID = #{approvalLineId}
	ORDER BY PROCESS_SEQ_NO
</select>

<insert id="insertDocsRequestDetail" parameterType="kr.esob.fdms.controller.outside.outregisted.request.DistributionRequestPopupParam">
	/* 요청 상세 추가 */
	INSERT INTO DOCS_REQUEST_DETAIL
	( REQUEST_NO
	, PROCESS_SEQ
	, APPROVAL_STATUS_CD
	, APPROVAL_GRADE_CD
	, ORIGINAL_USER_CD
	, ACTUAL_USER_CD
	<if test='"REQUEST".equals(approvalStatusCd)'>    <!-- 요청 내용 입력 -->
		, REQUEST_DESC
	</if>
	<if test='!"APPROVAL".equals(approvalStatusCd)'> <!-- 결재 아닐 경우  -->
		, ACTION_DT
		, ACTION_CD
	</if>
	)
	VALUES
	( #{requestNo}
	, #{processSeq}
	, #{approvalStatusCd}
	, #{approvalGradeCd}
	<if test='"REQUEST".equals(approvalStatusCd)'>                    <!-- 요청자 -->
		, #{sessionUser.userCd}                                        <!-- 로그인된 사용자 -->
		, #{sessionUser.userCd}                                        <!-- 로그인된 사용자 -->
	</if>
	<if test='"ACCEPT".equals(approvalStatusCd)'>                    <!-- 수신자 -->
		, #{receiveUserCd}                                                <!--  실제 선택된 수신자 -->
		, #{receiveUserCd}                                                <!--  현재 선택된 수신자 -->
	</if>
	<if test='"REQUEST".equals(approvalStatusCd)'>                <!--  요청 내용 입력 -->
		, #{transDesc}
	</if>
	, CURRENT_DATE
	<if test='"REQUEST".equals(approvalStatusCd)'>
		, 'REQUEST'
	</if>
	<if test='"ACCEPT".equals(approvalStatusCd)'>
		, 'ACCEPT'
	</if>
	)
</insert>

