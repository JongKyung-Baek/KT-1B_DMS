<mapper namespace="sql.OutregistedRequestStatus">

<select id="selectList" resultType="kr.esob.fdms.controller.outside.outregisted.requeststatus.RequestStatusListVO">
	SELECT
	B1.*
	FROM
	(
	SELECT
	A1.*
	, ROW_NUMBER() OVER () AS PAGEINDEX
	FROM
	(
	SELECT
	req.REQUEST_NO AS requestNo /* 요청번호 */
	, req.REQUEST_NO AS requestOrgNo /* 요청번호 */
	, (
	SELECT COMPANY_NM
	FROM DOCS_COMPANY company
	WHERE company.COMPANY_CD = req.DEPLOY_COMPANY_CD
	) AS deployCompanyNm
	, req.DEPLOY_COMPANY_CD AS deployCompanyCd /* 배포업체 */
	, CASE
	WHEN DEPLOY_NORMAL_YN = 'Y'
	THEN (SELECT LANG_DESC FROM DOCS_LANG lang WHERE lang.LANG_CD = 'combo.deployType.normalArea' AND lang.LANG_TYPE = #{sessionLang})
	WHEN DEPLOY_SPECIAL_YN = 'Y'
	THEN (SELECT LANG_DESC FROM DOCS_LANG lang WHERE lang.LANG_CD = 'combo.deployType.specialArea' AND lang.LANG_TYPE = #{sessionLang})
	ELSE (SELECT LANG_DESC FROM DOCS_LANG lang WHERE lang.LANG_CD = 'combo.deployType.viewing' AND lang.LANG_TYPE = #{sessionLang})
	END AS distributeMethodNm /* 배포방식 */
	, req.REQUEST_PURPOSE AS requestPurpose /* 용도 */
	, req.INSERT_USER_CD AS requestUserCd /* 요청자 */
	, reqUser.USER_NM AS requestUserNm /* 요청자 */
	, TO_CHAR(req.INSERT_DT, 'YYYY-MM-DD') AS requestDt /* 요청일 */
	, (
	SELECT MAX(TO_CHAR(TO_DATE(fileInfo.USE_END_YMD, 'YYYYMMDD'), 'YYYY-MM-DD'))
	FROM DOCS_REQUEST_FILE fileInfo
	WHERE fileInfo.REQUEST_NO = req.REQUEST_NO
	) AS useEndYmd /* 유효기간 */
	, accUser.USER_CD AS purchaserUserCd
	, accUser.USER_NM AS purchaserUserNm /* 구매담당자 */
	, req.BUSINESS_AREA_CD AS businessAreaCd /* 사업장 */
	, req.STATUS_CD AS statusCd /* 상태 */
	, req.OBJECT_TYPE AS objectType
	, companyUser.USER_CD AS companyUserCd /* 업체담당자 */
	, companyUser.USER_NM AS companyUserNm /* 업체담당자 */
	, (
	SELECT USER_NM
	FROM DOCS_REQUEST_DETAIL requestDetail
	INNER JOIN DOCS_USER docsUser ON docsUser.USER_CD = requestDetail.ACTUAL_USER_CD
	WHERE requestDetail.REQUEST_NO = req.REQUEST_NO
	AND requestDetail.APPROVAL_STATUS_CD = 'ACCEPT'
	) AS deployUserNm /* 배포자 */
	, TO_CHAR(req.APPROVAL_DT, 'YYYY-MM-DD') AS approvalDt /* 결재일 */
	, req.VENDOR_ACCEPT_YN AS vendorAcceptYn /* 업체접수여부 */
	, FN_GET_CD_NM('vendorAcceptYn', req.VENDOR_ACCEPT_YN, 'ko') AS vendorAcceptNm /* 업체접수여부 */
	FROM DOCS_REQUEST req
	INNER JOIN DOCS_REQUEST_DETAIL accDetail ON accDetail.REQUEST_NO = req.REQUEST_NO AND accDetail.APPROVAL_STATUS_CD = 'ACCEPT'
	INNER JOIN DOCS_USER accUser ON accUser.USER_CD = accDetail.ORIGINAL_USER_CD
	INNER JOIN DOCS_USER reqUser ON reqUser.USER_CD = req.INSERT_USER_CD
	INNER JOIN DOCS_REQUEST_DEPLOY deployInfo ON deployInfo.REQUEST_NO = req.REQUEST_NO
	INNER JOIN DOCS_USER companyUser ON companyUser.USER_CD = deployInfo.DEPLOY_USER_CD
	WHERE REQUEST_TYPE = 'OUT-REG'
	<if test='sortColumn == null or "".equals(sortColumn)'>
		ORDER BY requestDt desc, requestNo desc
	</if>
	<if test='sortColumn != null and !"".equals(sortColumn)'>
		ORDER BY ${sortColumn} ${order}, requestNo ${order}
	</if>
	) A1
	WHERE 1=1
	<if test='requestNo != null and !requestNo.equals("")'>
		AND requestNo = #{requestNo}
	</if>
	<if test='deployCompanyCd != null and !deployCompanyCd.equals("")'>
		AND deployCompanyCd = #{deployCompanyCd}
	</if>
	<if test='objectNm != null and !objectNm.equals("")'>
		AND objectNm = #{objectNm}
	</if>
	<if test='requestUserCd != null and !requestUserCd.equals("")'>
		AND requestUserCd = #{requestUserCd}
	</if>
	<if test='businessAreaCd != null and !businessAreaCd.equals("")'>
		AND businessAreaCd = #{businessAreaCd}
	</if>
	<if test='statusCd != null and !statusCd.equals("")'>
		AND statusCd = #{statusCd}
	</if>
	<if test='objectType != null and !objectType.equals("")'>
		AND objectType = #{objectType}
	</if>
	<if test='requestStartDt != null and !requestStartDt.equals("")'>
		AND requestDt BETWEEN TO_DATE(#{requestStartDt}, 'YYYY-MM-DD')
		AND TO_DATE(#{requestEndDt}, 'YYYY-MM-DD') + INTERVAL '1 day'
	</if>
	<if test='end != null and !end.equals("")'>
		AND ROW_NUMBER() OVER () <![CDATA[ <= ]]> #{end}
	</if>
	) B1
	<if test='start != null and !start.equals("")'>
		WHERE PAGEINDEX >= #{start}
	</if>
</select>

