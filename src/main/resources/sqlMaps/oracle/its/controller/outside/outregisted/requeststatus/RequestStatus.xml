	FROM DOCS_REQUEST_DETAIL requestDetail
	INNER JOIN DOCS_USER docsUser ON docsUser.USER_CD = requestDetail.ACTUAL_USER_CD
	WHERE requestDetail.REQUEST_NO = req.REQUEST_NO
	AND requestDetail.APPROVAL_STATUS_CD = 'ACCEPT'
	) AS deployUserNm /* 배포자 */
	, TO_CHAR(req.APPROVAL_DT, 'YYYY-MM-DD') AS approvalDt /* 결재일 */
	, req.VENDOR_ACCEPT_YN AS vendorAcceptYn /* 업체접수여부 */
	, FN_GET_CD_NM('vendorAcceptYn', req.VENDOR_ACCEPT_YN, 'ko') AS vendorAcceptNm /* 업체접수여부 */
	FROM DOCS_REQUEST req
	INNER JOIN DOCS_REQUEST_DETAIL accDetail ON accDetail.REQUEST_NO = req.REQUEST_NO AND accDetail.APPROVAL_STATUS_CD = 'ACCEPT'
	INNER JOIN DOCS_USER accUser ON accUser.USER_CD = accDetail.ORIGINAL_USER_CD
	INNER JOIN DOCS_USER reqUser ON reqUser.USER_CD = req.INSERT_USER_CD
	INNER JOIN DOCS_REQUEST_DEPLOY deployInfo ON deployInfo.REQUEST_NO = req.REQUEST_NO
	INNER JOIN DOCS_USER companyUser ON companyUser.USER_CD = deployInfo.DEPLOY_USER_CD
	WHERE REQUEST_TYPE = 'OUT-REG'
	) A1
	WHERE 1=1
	<if test='requestNo != null and !requestNo.equals("")'>
		AND requestNo = #{requestNo}
	</if>
	<if test='deployCompanyCd != null and !deployCompanyCd.equals("")'>
		AND deployCompanyCd = #{deployCompanyCd}
	</if>
	<if test='objectNm != null and !objectNm.equals("")'>
		AND objectNm = #{objectNm}
	</if>
	<if test='requestUserCd != null and !requestUserCd.equals("")'>
		AND requestUserCd = #{requestUserCd}
	</if>
	<if test='businessAreaCd != null and !businessAreaCd.equals("")'>
		AND businessAreaCd = #{businessAreaCd}
	</if>
	<if test='statusCd != null and !statusCd.equals("")'>
		AND statusCd = #{statusCd}
	</if>
	<if test='objectType != null and !objectType.equals("")'>
		AND objectType = #{objectType}
	</if>
	<if test='requestStartDt != null and !requestStartDt.equals("")'>
		AND requestDt BETWEEN TO_DATE(#{requestStartDt}, 'YYYY-MM-DD')
		AND TO_DATE(#{requestEndDt}, 'YYYY-MM-DD') + INTERVAL '1 day'
	</if>
	) B1
	) C1
</select>

<select id="getRequestInfo" parameterType="kr.esob.fdms.controller.outside.outregisted.requeststatus.RequestStatusPopupParam" resultType="kr.esob.fdms.controller.outside.outregisted.requeststatus.RequestStatusPopupVO">
	/*  자료 전송  정보 조회 */
	SELECT req.REQUEST_NO AS requestNo
		 , (SELECT USER_NM FROM DOCS_USER WHERE USER_CD = deploy.DEPLOY_USER_CD) AS deployUserNm
		 , (SELECT USER_NM FROM DOCS_USER WHERE USER_CD = reqAccDtl.ACTUAL_USER_CD) AS receiveUserNm
		 , req.REQUEST_PURPOSE AS requestPurpose
		 , req.DEPLOY_TERM AS deployTerm
		 , reqDtl.REQUEST_DESC AS transDesc
	FROM DOCS_REQUEST req
			 JOIN DOCS_REQUEST_DEPLOY deploy ON req.REQUEST_NO = deploy.REQUEST_NO
			 JOIN DOCS_USER userInfo ON deploy.DEPLOY_USER_CD = userInfo.USER_CD
			 LEFT JOIN DOCS_REQUEST_DETAIL reqDtl ON req.REQUEST_NO = reqDtl.REQUEST_NO AND reqDtl.APPROVAL_STATUS_CD = 'REQUEST'
			 LEFT JOIN DOCS_REQUEST_DETAIL reqAccDtl ON req.REQUEST_NO = reqAccDtl.REQUEST_NO AND reqAccDtl.ACTION_CD = 'ACCEPT'
	WHERE req.REQUEST_NO = #{requestNo}
</select>

<select id="selectPopupList" parameterType="kr.esob.fdms.controller.outside.outregisted.requeststatus.RequestStatusPopupParam" resultType="kr.esob.fdms.controller.outside.outregisted.requeststatus.RequestStatusPopupVO">
	/* 미등록 자료 배포 요청 아이템 리스트 조회 */
	SELECT outreg.OBJECT_NM AS objectNm
		 , outreg.OBJECT_TYPE AS objectType
		 , reqFile.ORG_FILE_NM AS fileNm
		 , reqFile.OBJECT_ID AS objectId
		 , reqFile.REQUEST_NO AS requestNo
		 , reqFile.ORG_FILE_NM AS orgFileNm
	FROM DOCS_REQUEST_MAPPING reqMap
			 JOIN DOCS_REQUEST_FILE reqFile
				  ON reqMap.OBJECT_ID = reqFile.OBJECT_ID
					  AND reqMap.REQUEST_NO = reqFile.REQUEST_NO
			 JOIN DOCS_OUTREG_INFO outreg
				  ON reqFile.OBJECT_ID = outreg.OBJECT_ID
	WHERE reqMap.REQUEST_NO = #{requestNo}
</select>

<select id="getDeployEmailCC" resultType="String" parameterType="kr.esob.fdms.controller.outside.outregisted.requeststatus.RequestStatusPopupParam">
	/* 미등록자료 배포 보안팀 참조자 조회 */
	SELECT DEPLOY_EMAIL_CC
	FROM DOCS_REQUEST_DEPLOY
	WHERE REQUEST_NO = #{requestNo}
</select>

